    </div>
    <div class="art-tb-spacer"></div>
    <div class="art-tb-group">
      <button id="artSeoToggle" title="Toggle SEO inspector">SEO</button>
    </div>
    <div class="art-tb-sep"></div>
    <div class="art-tb-group">
      <button id="artEditToggle">Edit</button>
