---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="About - Rafaela Solis">
    <style>
        /* ===== LAYOUT ===== */
        .about-page {
            min-height: 100vh;
            display: flex;
            padding-top: var(--nav-h);
        }

        /* ===== LEFT PANEL ===== */
        .about-left {
            width: 38%;
            flex-shrink: 0;
            position: sticky;
            top: var(--nav-h);
            height: calc(100vh - var(--nav-h));
            background: var(--accent);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 3rem;
            border-right: 3px solid var(--border);
            text-align: center;
            gap: 0;
        }

        .headshot-circle {
            width: 240px;
            height: 240px;
            border-radius: 50%;
            border: 5px solid rgba(245, 242, 235, 0.9);
            box-shadow: 10px 10px 0 var(--border);
            object-fit: cover;
            display: block;
            margin-bottom: 2rem;
            flex-shrink: 0;
        }

        .left-name {
            font-size: clamp(1.9rem, 2.5vw, 2.6rem);
            font-weight: 700;
            color: var(--bg);
            letter-spacing: -0.02em;
            line-height: 1.05;
            margin-bottom: 0.6rem;
        }

        .left-title {
            font-size: 0.8rem;
            font-weight: 700;
            color: rgba(245, 242, 235, 0.65);
            text-transform: uppercase;
            letter-spacing: 0.22em;
            margin-bottom: 2.25rem;
        }

        .left-divider {
            width: 64px;
            height: 3px;
            background: rgba(245, 242, 235, 0.35);
            margin: 0 auto 2.25rem;
        }

        .left-stats {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            width: 100%;
            text-align: left;
        }

        .stat-item {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
            padding-left: 0.85rem;
            border-left: 2px solid rgba(245, 242, 235, 0.2);
        }

        .stat-label {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.16em;
            color: rgba(245, 242, 235, 0.45);
        }

        .stat-value {
            font-size: 0.97rem;
            font-weight: 600;
            color: rgba(245, 242, 235, 0.9);
            line-height: 1.4;
        }

        /* ===== RIGHT PANEL ===== */
        .about-right {
            flex: 1;
            padding: 4.5rem 3.5rem 5rem;
            min-width: 0;
        }

        .section-eyebrow {
            font-size: 0.68rem;
            font-weight: 700;
            color: var(--accent-sage);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            margin-bottom: 0.5rem;
        }

        h1 {
            font-size: clamp(2.2rem, 3.5vw, 3rem);
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 0.75rem;
        }

        .accent-rule {
            width: 60px;
            height: 4px;
            background: var(--accent);
            margin-bottom: 2.25rem;
        }

        .bio {
            font-size: 0.96rem;
            line-height: 1.9;
            color: var(--text-secondary);
        }

        .bio p + p { margin-top: 1.25rem; }

        .content-divider {
            width: 100%;
            height: 1px;
            background: var(--border);
            opacity: 0.15;
            margin: 3rem 0;
        }

        h2 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 1.25rem;
            padding-left: 0.85rem;
            border-left: 4px solid var(--accent);
            letter-spacing: 0.01em;
        }

        /* ===== SKILLS GRID ===== */
        .skills-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.85rem;
        }

        .skills-category {
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            padding: 1.1rem 1.35rem;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
        }

        .skills-category:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0 var(--border);
            border-color: var(--accent);
        }

        .skills-category.wide { grid-column: span 2; }

        .skills-category h3 {
            font-size: 0.64rem;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.14em;
            margin-bottom: 0.75rem;
            padding-bottom: 0.35rem;
            border-bottom: 1.5px solid var(--accent);
            display: inline-block;
        }

        .skills {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
        }

        .skill-badge {
            background: transparent;
            color: var(--text-primary);
            padding: 0.28rem 0.6rem;
            font-weight: 600;
            font-size: 0.77rem;
            border: 1.5px solid rgba(26,26,26,0.28);
            letter-spacing: 0.01em;
            transition: background 0.15s, color 0.15s;
            cursor: default;
        }

        .skill-badge:hover { background: var(--accent); color: var(--bg); }

        /* ===== LOOKING FOR ===== */
        .looking-for-card {
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            padding: 1.4rem 1.75rem;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            font-size: 0.94rem;
            line-height: 1.85;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        /* ===== RESUME ===== */
        .resume-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 2px solid rgba(26,26,26,0.1);
        }

        .resume-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.85rem 2rem;
            background: var(--accent);
            color: var(--bg);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            transition: transform 0.15s, box-shadow 0.15s;
        }

        .resume-button:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0 var(--border);
        }

        .resume-button.secondary {
            background: transparent;
            color: var(--accent);
            border-color: var(--accent);
            box-shadow: 4px 4px 0 var(--accent);
        }

        .resume-button.secondary:hover { box-shadow: 6px 6px 0 var(--accent); }

        /* ===== MOBILE ===== */
        @media (max-width: 768px) {
            .about-page { flex-direction: column; }
            .about-left {
                position: relative;
                width: 100%;
                height: auto;
                padding: 3rem 2rem 2.5rem;
            }
            .about-right { padding: 2.5rem 1.5rem 4rem; }
            .skills-grid { grid-template-columns: 1fr; }
            .skills-category.wide { grid-column: span 1; }
        }
    </style>

    <div class="about-page">

        <!-- ── LEFT: sticky photo panel ── -->
        <aside class="about-left">
            <img
                src="/headshot.jpg"
                alt="Rafaela Solis"
                class="headshot-circle"
                onerror="this.style.display='none'"
            >
            <p class="left-name">Rafaela Solis</p>
            <p class="left-title">Game Developer &amp; Designer</p>
            <div class="left-divider"></div>
            <div class="left-stats">
                <div class="stat-item">
                    <span class="stat-label">School</span>
                    <span class="stat-value">Champlain College '28</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Major</span>
                    <span class="stat-value">Game Design &amp; Programming</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Based in</span>
                    <span class="stat-value">Austin, TX / Burlington, VT</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Open to</span>
                    <span class="stat-value">Internships &amp; Projects — US / CA / EU</span>
                </div>
            </div>
        </aside>

        <!-- ── RIGHT: scrollable content ── -->
        <main class="about-right">
            <p class="section-eyebrow">Introduction</p>
            <h1>About Me</h1>
            <div class="accent-rule"></div>

            <div class="bio">
                <p>Hi! I'm Rafaela Solis, a passionate game developer dedicated to creating engaging, immersive, and emotional player-focused gaming experiences. My journey in game development started as a tiny baby. My father started a company during the tech boom, and performed IT services for the city of Austin, Texas. He always had every kind of computer, and quite often we would sit down together in front of a 4 inch thick laptop to play obscure cobbled together kids games that my tiny brain could understand. I've been hooked ever since.</p>

                <p>I major in Game Design and Game Programming at Champlain College (2028), with specific focus in gameplay programming, system design, level design, technical design, narrative design, rapid prototyping, and more. I have experience with Unity, Unreal Engine, C#, C++, Python, Java, and Blueprints. I don't just love the games — I love the puzzle of making people happy. I've worked across a plethora of genres: Maze-Puzzle, Action-Adventure, Educational, Drawing-Combat, Multiplayer Coop/Competitive, and more.</p>

                <p>I've shipped two non-academic large-team projects — Mega Market Mayhem and Scriptorium — both in demo stages with Scriptorium in active development. Beyond that, dozens of indie and jam games, and a plethora of academic prototypes. Each project has taught me invaluable lessons about teamwork, scope, design, and the importance of the player.</p>
            </div>

            <div class="content-divider"></div>

            <h2>Skills &amp; Expertise</h2>
            <div class="skills-grid">
                <div class="skills-category">
                    <h3>Game Engines</h3>
                    <div class="skills">
                        <span class="skill-badge">Unity</span>
                        <span class="skill-badge">Unreal Engine</span>
                        <span class="skill-badge">UEFN</span>
                    </div>
                </div>

                <div class="skills-category">
                    <h3>Programming Languages</h3>
                    <div class="skills">
                        <span class="skill-badge">C#</span>
                        <span class="skill-badge">C++</span>
                        <span class="skill-badge">Python</span>
                        <span class="skill-badge">Java</span>
                    </div>
                </div>

                <div class="skills-category wide">
                    <h3>Game Development</h3>
                    <div class="skills">
                        <span class="skill-badge">Game Design</span>
                        <span class="skill-badge">Game Programming</span>
                        <span class="skill-badge">Level Design</span>
                        <span class="skill-badge">Systems Design</span>
                        <span class="skill-badge">Technical Design</span>
                        <span class="skill-badge">Implementation</span>
                        <span class="skill-badge">Documentation</span>
                        <span class="skill-badge">Scrum / Agile / Waterfall</span>
                        <span class="skill-badge">UI/UX Design</span>
                        <span class="skill-badge">Gameplay Programming</span>
                        <span class="skill-badge">AI / Neural Model Development</span>
                        <span class="skill-badge">Game Infrastructure Design</span>
                    </div>
                </div>

                <div class="skills-category wide">
                    <h3>Tools &amp; Software</h3>
                    <div class="skills">
                        <span class="skill-badge">Git</span>
                        <span class="skill-badge">Subversion</span>
                        <span class="skill-badge">Blender</span>
                        <span class="skill-badge">Aseprite</span>
                        <span class="skill-badge">Photoshop</span>
                        <span class="skill-badge">Illustrator</span>
                        <span class="skill-badge">DaVinci Resolve</span>
                        <span class="skill-badge">Audacity</span>
                        <span class="skill-badge">Taiga</span>
                        <span class="skill-badge">Jira + Confluence</span>
                        <span class="skill-badge">Google Suite</span>
                        <span class="skill-badge">CMake</span>
                    </div>
                </div>
            </div>

            <div class="content-divider"></div>

            <h2>What I'm Looking For</h2>
            <div class="looking-for-card">
                I'm currently seeking passionately led projects and game industry internships in the US, Canada, and EU regions. I'm particularly excited about work involving player psychology, narrative-driven experiences, large-scale multiplayer, and community-driven development.
            </div>

            <div class="resume-buttons">
                <a href="/resume.pdf" class="resume-button" download>Download Resume</a>
                <a href="https://docs.google.com/document/d/1v0lK7-rZYCnJ68tqIrMUsZItaMFcUgHx-enojmvdkaY/edit?usp=sharing" class="resume-button secondary" target="_blank">View Resume Online</a>
            </div>
        </main>

    </div>
</Layout>
