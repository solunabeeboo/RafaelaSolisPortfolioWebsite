---
import Layout from '../../layouts/Layout.astro';
import projectsData from '../../data/projects.json';

const projects = projectsData.projects;
---
<Layout title="Projects - Rafaela Solis">
    <style is:global>
        :root { --compact-h: 36px; }

        .sections-stage {
            position: sticky;
            top: var(--nav-h);
            overflow: hidden;
        }

        /* ===== STRIP ===== */
        .section-strip {
            width: 100%;
            overflow: hidden;
            border-bottom: 2px solid var(--border);
            position: relative;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }

        /* ===== THUMBNAIL — absolute, covers full left side including header ===== */
        .strip-thumbnail {
            position: absolute;
            top: 0; bottom: 0; left: 0;
            width: 58.33%; /* 7fr out of 12fr */
            z-index: 1;
            opacity: 0;
            transition: opacity 0.4s;
            overflow: hidden;
            background: #111;
        }

        .section-strip.strip-active .strip-thumbnail { opacity: 1; }

        .strip-thumb-slide {
            position: absolute;
            inset: 0;
            display: none;
        }

        .strip-thumb-slide.active { display: block; }

        .strip-thumb-slide img {
            width: 100%; height: 100%;
            object-fit: cover; object-position: center; display: block;
        }

        .strip-thumb-slide video {
            width: 100%; height: 100%;
            object-fit: contain; background: #000; display: block;
        }

        .strip-thumbnail-overlay {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            padding: 3rem 2rem 1.75rem;
            background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.35) 55%, transparent 100%);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            z-index: 2;
            pointer-events: none;
        }

        /* ===== CAROUSEL CONTROLS ===== */
        .gallery-btn {
            position: absolute; top: 50%; transform: translateY(-50%);
            width: 64px; height: 64px;
            background: rgba(0,0,0,0.65); border: 1px solid rgba(255,255,255,0.25);
            color: #fff; font-size: 1.8rem; line-height: 1;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 10; transition: background 0.15s; user-select: none;
        }

        .gallery-btn:hover { background: rgba(0,0,0,0.85); }
        .gallery-btn-prev { left: 0.4rem; }
        .gallery-btn-next { right: 0.4rem; }

        .gallery-counter {
            position: absolute; bottom: 0.55rem; right: 0.7rem;
            font-size: 0.62rem; font-weight: 600; color: rgba(255,255,255,0.45);
            pointer-events: none; font-variant-numeric: tabular-nums; letter-spacing: 0.04em;
            z-index: 10;
        }

        .strip-thumbnail-title {
            font-size: clamp(1.8rem, 2.8vw, 3rem);
            font-weight: 700;
            color: rgba(255,255,255,0.96);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            line-height: 1;
            text-shadow: 0 2px 16px rgba(0,0,0,0.5);
        }

        /* ===== STRIP HEADER (36px) ===== */
        .strip-header {
            height: var(--compact-h);
            min-height: var(--compact-h);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0 0.85rem 0 54px; /* 54px = icon width + gap */
            position: relative;
            z-index: 2;
            background: var(--bg);
            border-bottom: 1px solid rgba(26, 26, 26, 0.1);
            transition: background 0.3s, backdrop-filter 0.3s;
        }

        .strip-title-group {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            overflow: hidden;
            min-width: 0;
        }

        .section-strip.strip-active .strip-header {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(26, 26, 26, 0.15);
        }

        .strip-title {
            font-size: 2rem; font-weight: 700; color: var(--text-primary);
            text-transform: uppercase; letter-spacing: 0.04em;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
            line-height: 1;
        }

        .strip-hint {
            font-size: 0.6rem; color: var(--text-muted);
            flex-shrink: 0; margin-left: auto; line-height: 1;
        }

        .section-strip.strip-active .strip-hint { opacity: 0; }

        /* ===== OVERVIEW ROW ===== */
        .strip-overview-row {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0 0.85rem 0 54px;
            position: relative;
            z-index: 2;
            background: var(--bg);
            overflow: hidden;
        }

        .section-strip.strip-active .strip-overview-row { display: none; }

        /* ===== ICON — full-height circle on left ===== */
        .strip-icon {
            position: absolute;
            left: 3px; top: 3px; bottom: 3px;
            width: auto;
            aspect-ratio: 1;
            z-index: 3;
            border-radius: 50%;
            background-size: cover;
            background-position: center;
            background-color: var(--accent-sage);
            transition: opacity 0.3s;
        }

        /* Hide icon when project is expanded (thumbnail covers left side) */
        .section-strip.strip-active .strip-icon {
            opacity: 0;
            pointer-events: none;
        }

        .strip-sep { width: 1px; height: 12px; background: rgba(26,26,26,0.2); flex-shrink: 0; }

        .strip-short-desc {
            position: absolute;
            left: 18%; right: 5%; top: 0; bottom: 0;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
            font-size: 0.92rem; color: var(--text-secondary);
            pointer-events: none;
        }
        .strip-short-desc > span {
            display: inline-block; max-width: 100%;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }

        /* ===== EXPANDED CONTENT — info panel in right 41.67% ===== */
        .strip-content {
            flex: 0 0 0;
            position: relative; z-index: 2;
            opacity: 0; transition: opacity 0.35s;
            overflow: hidden; display: flex;
            margin-left: 58.33%;
        }

        .section-strip.strip-active .strip-content { opacity: 1; flex: 1; }

        /* ===== INFO PANEL ===== */
        .strip-info {
            padding: 1.5rem 1.75rem;
            background: rgba(245, 242, 235, 0.97);
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            display: flex; flex-direction: column; gap: 0.8rem;
            overflow-y: auto; border-left: 2px solid var(--border);
            width: 100%;
        }

        .strip-label {
            font-size: 0.64rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.14em; color: var(--accent);
            padding-left: 0.5rem; border-left: 3px solid var(--accent);
        }

        .strip-description { font-size: 0.87rem; color: var(--text-secondary); line-height: 1.75; white-space: pre-line; }

        .strip-meta-row { display: flex; gap: 1.5rem; flex-wrap: wrap; }
        .strip-meta-item { display: flex; flex-direction: column; gap: 0.1rem; }
        .strip-meta-label { font-size: 0.59rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.13em; color: var(--accent); }
        .strip-meta-value { font-size: 0.8rem; color: var(--text-secondary); font-weight: 500; }

        .strip-tags-full { display: flex; flex-wrap: wrap; gap: 0.35rem; }

        .tag {
            font-size: 0.72rem; font-weight: 600;
            border: 2px solid var(--border); padding: 0.2rem 0.55rem;
            color: var(--text-primary);
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }

        .tag:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }

        .strip-link {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: var(--accent); color: var(--bg); text-decoration: none;
            padding: 0.65rem 1.4rem; border: 2px solid var(--border);
            box-shadow: 3px 3px 0 var(--border); font-weight: 700; font-size: 0.78rem;
            text-transform: uppercase; letter-spacing: 0.05em;
            transition: transform 0.15s, box-shadow 0.15s;
            align-self: flex-start; margin-top: auto; flex-shrink: 0;
        }

        .strip-link:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--border); }

        /* ===== LOADING ===== */
        .loading-state {
            display: flex; align-items: center; justify-content: center;
            height: 100%; font-size: 1rem; color: var(--text-muted);
        }

        /* ===== MOBILE ===== */
        @media (max-width: 768px) {
            #scrollDriver { height: auto !important; }
            .sections-stage { position: static; height: auto !important; overflow: visible; }
            .section-strip { height: auto !important; min-height: 100svh; cursor: default; border-bottom: 3px solid var(--border); }
            .strip-icon { display: none; }
            .strip-header { background: rgba(255,255,255,0.92) !important; backdrop-filter: blur(12px); flex-wrap: wrap; height: auto !important; min-height: 36px; padding: 0.5rem 1rem; gap: 0.5rem; }
            /* Hide overview row — full content is always expanded on mobile */
            .strip-overview-row { display: none; }
            /* Thumbnail: static, full width, fixed height */
            .strip-thumbnail { position: static; width: 100%; height: 260px; opacity: 1; }
            /* Info panel: full width, no left margin */
            .strip-content { opacity: 1 !important; flex: 1 !important; margin-left: 0; min-height: calc(100svh - 300px); }
            .strip-info { border-left: none; overflow-y: visible; }
        }

        /* ===== LIGHTBOX ===== */
        .lightbox {
            position: fixed; inset: 0; z-index: 1200;
            background: rgba(0,0,0,0.95);
            display: flex; flex-direction: column;
            align-items: stretch; justify-content: center;
            padding: 1.75rem;
            gap: 0.75rem;
        }
        .lightbox-header {
            display: flex; align-items: center; gap: 1rem; flex-shrink: 0;
        }
        .lightbox-title {
            flex: 1; font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.14em; color: rgba(255,255,255,0.55);
        }
        .lightbox-counter {
            font-size: 0.75rem; color: rgba(255,255,255,0.4);
            font-weight: 600; letter-spacing: 0.06em;
        }
        .lightbox-close {
            background: none; border: 2px solid rgba(255,255,255,0.3);
            color: rgba(255,255,255,0.7); cursor: pointer;
            padding: 0.35rem 0.85rem; font-size: 0.72rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.08em; font-family: inherit;
            transition: border-color 0.15s, color 0.15s;
        }
        .lightbox-close:hover { border-color: #fff; color: #fff; }
        .lightbox-body {
            flex: 1; min-height: 0;
            display: flex; align-items: center; justify-content: center;
            position: relative;
        }
        .lightbox-media {
            max-width: 100%; max-height: 100%;
            object-fit: contain; display: block;
        }
        .lightbox-media-video {
            max-width: 100%; max-height: 100%;
            display: block; outline: none;
        }
        .lightbox-nav {
            position: absolute; top: 50%; transform: translateY(-50%);
            background: rgba(255,255,255,0.08); border: 2px solid rgba(255,255,255,0.2);
            color: #fff; cursor: pointer; font-size: 1.25rem; line-height: 1;
            padding: 0.6rem 0.9rem; transition: background 0.15s, border-color 0.15s;
        }
        .lightbox-nav:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.5); }
        .lightbox-nav-prev { left: 0; }
        .lightbox-nav-next { right: 0; }
        /* make thumbnail clickable */
        .strip-thumbnail { cursor: zoom-in; }

        /* ===== GAME EMBED OVERLAY ===== */
        .play-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.92);
            z-index: 1100; /* above nav (1000) */
            display: flex; flex-direction: column;
            align-items: stretch;
            justify-content: center;
            padding: 1.75rem 1.75rem 5rem; /* extra bottom room for itch.io footer bar */
            gap: 0.75rem;
        }

        .play-overlay-header {
            display: flex; align-items: center; gap: 1rem;
            flex-shrink: 0;
        }

        .play-overlay-title {
            flex: 1; font-size: 0.8rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.14em;
            color: rgba(255,255,255,0.55);
        }

        .play-close-btn {
            background: none; border: 2px solid rgba(255,255,255,0.3);
            color: rgba(255,255,255,0.7); cursor: pointer;
            padding: 0.35rem 0.85rem; font-size: 0.72rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.08em; font-family: inherit;
            transition: border-color 0.15s, color 0.15s;
        }
        .play-close-btn:hover { border-color: #fff; color: #fff; }
        .play-fs-btn {
            background: none; border: 2px solid rgba(255,255,255,0.3);
            color: rgba(255,255,255,0.7); cursor: pointer;
            padding: 0.35rem 0.85rem; font-size: 0.72rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.08em; font-family: inherit;
            transition: border-color 0.15s, color 0.15s;
        }
        .play-fs-btn:hover { border-color: #fff; color: #fff; }

        .play-iframe-wrap {
            /* Widest possible 16:9 box that fits within the viewport height.
               max-width caps the width so height = width*(9/16) never exceeds that. */
            width: 100%;
            max-width: calc((100vh - 8.75rem) * 16 / 9);
            aspect-ratio: 16 / 9;
            align-self: center;
            background: #000;
            border: 3px solid var(--border);
            position: relative;
            overflow: visible;   /* lets the itch.io footer bar hang below the border */
        }
        .play-iframe-wrap iframe {
            position: absolute; top: 0; left: 0;
            border: none; display: block;
            transform-origin: top left;
        }

        /* Play Now button in info panel */
        .strip-play-btn {
            display: inline-flex; align-items: center; gap: 0.45rem;
            background: transparent; color: var(--accent); text-decoration: none;
            padding: 0.65rem 1.4rem; border: 2px solid var(--accent);
            box-shadow: 3px 3px 0 var(--accent); font-weight: 700; font-size: 0.78rem;
            text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer;
            font-family: inherit;
            transition: transform 0.15s, box-shadow 0.15s, background 0.15s, color 0.15s;
            align-self: flex-start; flex-shrink: 0;
        }
        .strip-play-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0 var(--accent);
            background: var(--accent); color: var(--bg);
        }

        /* ===== EDIT MODE ===== */

        /* Per-strip edit button */
        .strip-edit-btn {
            display: none;
            position: absolute; right: 2.5rem; top: 50%; transform: translateY(-50%);
            background: var(--accent); color: var(--bg);
            border: 2px solid var(--border); box-shadow: 2px 2px 0 var(--border);
            padding: 0.15rem 0.65rem; cursor: pointer;
            font-size: 0.62rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.08em; font-family: inherit; z-index: 10;
            transition: transform 0.12s, box-shadow 0.12s;
            white-space: nowrap;
        }
        .strip-edit-btn:hover {
            transform: translateY(calc(-50% - 1px)) translateX(-1px);
            box-shadow: 3px 3px 0 var(--border);
        }
        body.edit-mode .strip-edit-btn { display: block; }
        body.edit-mode .strip-hint { display: none; }

        .strip-reorder-btns {
            display: none; position: absolute; right: 8rem; top: 50%;
            transform: translateY(-50%); gap: 0.2rem; z-index: 10;
        }
        body.edit-mode .strip-reorder-btns { display: flex; }
        .strip-reorder-btn {
            background: rgba(245,242,235,0.12); color: var(--text-primary);
            border: 2px solid var(--border); padding: 0.1rem 0.45rem;
            cursor: pointer; font-size: 0.7rem; font-family: inherit;
            transition: background 0.12s;
        }
        .strip-reorder-btn:hover { background: var(--accent); color: var(--bg); }
        .strip-reorder-btn:disabled { opacity: 0.25; cursor: default; }
        .strip-reorder-btn:disabled:hover { background: rgba(245,242,235,0.12); color: var(--text-primary); }

        /* Edit toolbar */
        .edit-toolbar {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            background: var(--border);
            color: var(--bg);
            padding: 0.65rem 1.5rem;
            display: flex; align-items: center; gap: 0.75rem;
            z-index: 900; border-top: 3px solid var(--accent);
        }
        .edit-mode-badge {
            font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.16em; color: var(--accent);
        }
        .edit-toolbar-spacer { flex: 1; }

        /* Overlay backdrop */
        .edit-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.72);
            z-index: 1000;
            display: flex; align-items: center; justify-content: center;
            backdrop-filter: blur(4px);
        }

        /* Modal box */
        .edit-modal-box {
            background: var(--bg);
            border: 3px solid var(--border);
            box-shadow: 8px 8px 0 var(--border);
            width: min(92vw, 700px);
            max-height: 88vh;
            display: flex; flex-direction: column;
            overflow: hidden;
        }
        .edit-modal-sm { width: min(90vw, 380px); max-height: none; }

        .edit-modal-head {
            padding: 1.1rem 1.5rem;
            border-bottom: 2px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0;
        }
        .edit-modal-head h3 {
            font-size: 0.82rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.12em; color: var(--text-primary); margin: 0;
        }
        .edit-close-btn {
            background: none; border: none; cursor: pointer;
            font-size: 1.15rem; color: var(--text-muted);
            padding: 0.2rem 0.4rem; line-height: 1;
            transition: color 0.15s; font-family: inherit;
        }
        .edit-close-btn:hover { color: var(--text-primary); }

        /* Tabs */
        .edit-tab-bar {
            display: flex; border-bottom: 2px solid var(--border);
            flex-shrink: 0; background: #f0ede6;
        }
        .edit-tab {
            padding: 0.6rem 1.2rem; background: none; border: none; cursor: pointer;
            font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.1em; color: var(--text-muted);
            border-bottom: 3px solid transparent; margin-bottom: -2px;
            transition: color 0.15s, border-color 0.15s; font-family: inherit;
        }
        .edit-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
        .edit-tab:hover:not(.active) { color: var(--text-primary); }

        /* Tab content */
        .edit-tab-content {
            flex: 1; overflow-y: auto;
            padding: 1.25rem 1.5rem;
            display: flex; flex-direction: column; gap: 0.9rem;
        }

        /* Form fields */
        .edit-field { display: flex; flex-direction: column; gap: 0.35rem; }
        .edit-label {
            font-size: 0.62rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.13em; color: var(--accent);
        }
        .edit-input, .edit-textarea, .edit-select {
            background: var(--bg); border: 2px solid var(--border);
            color: var(--text-primary); font-family: inherit; font-size: 0.85rem;
            padding: 0.5rem 0.7rem; width: 100%; box-sizing: border-box;
            transition: border-color 0.15s;
        }
        .edit-input:focus, .edit-textarea:focus, .edit-select:focus {
            outline: none; border-color: var(--accent);
        }
        .edit-textarea { resize: vertical; min-height: 76px; line-height: 1.6; }
        .edit-row { display: flex; gap: 0.85rem; }
        .edit-row .edit-field { flex: 1; }

        /* Buttons */
        .edit-btn-primary {
            background: var(--accent); color: var(--bg);
            border: 2px solid var(--border); box-shadow: 3px 3px 0 var(--border);
            padding: 0.55rem 1.35rem; cursor: pointer;
            font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.06em; font-family: inherit;
            transition: transform 0.12s, box-shadow 0.12s; white-space: nowrap;
        }
        .edit-btn-primary:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--border); }

        .edit-btn-secondary {
            background: transparent; color: var(--bg);
            border: 2px solid rgba(245,242,235,0.5); box-shadow: 3px 3px 0 rgba(0,0,0,0.3);
            padding: 0.55rem 1.35rem; cursor: pointer;
            font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.06em; font-family: inherit;
            transition: transform 0.12s, box-shadow 0.12s; white-space: nowrap;
        }
        .edit-btn-secondary:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--border); }

        .edit-btn-danger {
            background: transparent; color: #c0392b;
            border: 2px solid #c0392b; box-shadow: 3px 3px 0 #c0392b;
            padding: 0.55rem 1.35rem; cursor: pointer;
            font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.06em; font-family: inherit;
            transition: transform 0.12s, box-shadow 0.12s; white-space: nowrap;
        }
        .edit-btn-danger:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #c0392b; }

        /* Modal footer */
        .edit-modal-footer {
            padding: 0.9rem 1.5rem;
            border-top: 2px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0; gap: 0.75rem; flex-wrap: wrap;
        }
        .edit-modal-footer-right { display: flex; gap: 0.65rem; }

        /* Media tab */
        .icon-preview {
            width: 72px; height: 72px; border-radius: 50%;
            background-size: cover; background-position: center;
            background-color: var(--accent-sage);
            border: 2px solid var(--border); flex-shrink: 0;
        }
        .icon-row { display: flex; align-items: center; gap: 1rem; }
        .icon-row-fields { flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }
        .media-list { display: flex; flex-direction: column; gap: 0.4rem; }
        .media-item {
            display: flex; align-items: center; gap: 0.6rem;
            padding: 0.4rem 0.6rem; border: 2px solid var(--border);
        }
        .media-item-thumb {
            width: 52px; height: 36px; object-fit: cover;
            background: #111; flex-shrink: 0;
            border: 1px solid var(--border);
        }
        .media-item-thumb-vid {
            width: 52px; height: 36px; flex-shrink: 0;
            border: 1px solid var(--border);
            background: #222; display: flex; align-items: center; justify-content: center;
            font-size: 0.58rem; color: #888; font-weight: 700;
        }
        .media-item-name {
            flex: 1; font-size: 0.75rem; color: var(--text-secondary);
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .media-item-btns { display: flex; gap: 0.25rem; flex-shrink: 0; }
        .media-item-btn {
            background: none; border: 1px solid var(--border); cursor: pointer;
            padding: 0.2rem 0.42rem; font-size: 0.68rem; color: var(--text-muted);
            font-family: inherit; transition: color 0.12s, background 0.12s;
