    <script define:vars={{ projects }}>
        const NAV_H     = 60;
        const COMPACT   = 36;
        const BUF_VH    = 0.25;
        const SEC_VH    = 0.80;
        const HERO_HOLD = 0.25;
        const HERO_FRAC = 0.80;

        // ── Edit mode uses a mutable copy of the server-rendered project list ──
        let liveProjects = JSON.parse(JSON.stringify(projects));

        let isMobile = false;

        function checkMobile() {
            isMobile = window.matchMedia('(max-width: 768px)').matches;
        }

        function isVideo(src) {
            return /\.(mp4|webm|ogg)$/i.test(src);
        }

        function buildThumbSlides(media) {
            return media.map((src, idx) => {
                const inner = isVideo(src)
                    ? `<video src="${src}" controls muted playsinline loop></video>`
                    : `<img src="${src}" alt="" loading="lazy" onerror="this.style.display='none'">`;
                return `<div class="strip-thumb-slide${idx === 0 ? ' active' : ''}">${inner}</div>`;
            }).join('');
        }

        function buildStrips(projectList) {
            const stage  = document.getElementById('sectionsStage');
            const driver = document.getElementById('scrollDriver');
            const N = projectList.length;
            const stageH = window.innerHeight - NAV_H;

            const slotSize = 1 + HERO_HOLD;
            stage.style.height  = stageH + 'px';
            driver.style.height = ((BUF_VH + N * slotSize * SEC_VH) * window.innerHeight) + 'px';
            stage.innerHTML = '';

            projectList.forEach((project, i) => {
                const strip = document.createElement('div');
                strip.className = 'section-strip';
                strip.id = `strip-${i}`;

                const bgSrc      = project.image || (project.screenshots && project.screenshots[0]) || '';
                const bgFallback = project.gradient || 'linear-gradient(135deg, #2d5016, #6b8f47)';
                const bgStyle    = bgSrc ? `background-image: url('${bgSrc}')` : `background: ${bgFallback}`;

                const fullTags   = project.tags.map(t => `<span class="tag">${t}</span>`).join('');

                const metaItems = [
                    project.developmentTime && `<div class="strip-meta-item"><span class="strip-meta-label">Dev Time</span><span class="strip-meta-value">${project.developmentTime}</span></div>`,
                    project.teamSize        && `<div class="strip-meta-item"><span class="strip-meta-label">Team</span><span class="strip-meta-value">${project.teamSize}</span></div>`,
                    project.tools && project.tools.length && `<div class="strip-meta-item"><span class="strip-meta-label">Tools</span><span class="strip-meta-value">${project.tools.slice(0, 4).join(', ')}</span></div>`,
                ].filter(Boolean).join('');

                const desc      = project.fullDescription || project.shortDescription || '';
                const linkHref  = project.playLink || '#';
                const linkText  = project.linkText || 'View Project';
                const canPlay   = project.hasEmbed && project.embedType === 'game' && project.embedUrl;

                const iconStyle = project.image
                    ? `background-image: url('${project.image}')`
                    : '';

                // Build media array: main image → videos → other screenshots
                const mediaArr = [];
                if (project.image) mediaArr.push(project.image);
                if (project.screenshots) {
                    const rest   = project.screenshots.filter(s => s !== project.image);
                    const videos = rest.filter(s => isVideo(s));
                    const imgs   = rest.filter(s => !isVideo(s));
                    videos.forEach(s => mediaArr.push(s));
                    imgs.forEach(s => mediaArr.push(s));
                }
                if (mediaArr.length === 0) mediaArr.push('');

                const hasMultiple = mediaArr.length > 1;
                const thumbSlides = buildThumbSlides(mediaArr.filter(Boolean));

                strip.innerHTML = `
                    <div class="strip-thumbnail">
                        ${thumbSlides}
                        <div class="strip-thumbnail-overlay">
                            <span class="strip-thumbnail-title">${project.title}</span>
                        </div>
                        ${hasMultiple ? `
                            <button class="gallery-btn gallery-btn-prev" aria-label="Previous">&#8592;</button>
                            <button class="gallery-btn gallery-btn-next" aria-label="Next">&#8594;</button>
                            <span class="gallery-counter"><span class="gallery-cur">1</span> / ${mediaArr.filter(Boolean).length}</span>
                        ` : ''}
                    </div>
                    <div class="strip-icon" style="${iconStyle}"></div>
                    <div class="strip-header">
                        <div class="strip-title-group">
                            <span class="strip-title">${project.title}</span>
                        </div>
                        <span class="strip-hint">&#8597;</span>
                    </div>
                    <div class="strip-overview-row">
                        <span class="strip-short-desc"><span>${project.shortDescription || ''}</span></span>
                    </div>
                    <div class="strip-content">
                        <div class="strip-info">
                            <span class="strip-label">About</span>
                            <div class="strip-description">${desc}</div>
                            ${metaItems ? `<div class="strip-meta-row">${metaItems}</div>` : ''}
                            <div class="strip-tags-full">${fullTags}</div>
                            ${project.challenges ? `<span class="strip-label">Challenges</span><div class="strip-description">${project.challenges}</div>` : ''}
                            ${project.learnings  ? `<span class="strip-label">Learnings</span><div class="strip-description">${project.learnings}</div>`  : ''}
                            <div style="display:flex;gap:0.65rem;flex-wrap:wrap;align-items:flex-start;margin-top:auto">
                                <a href="${linkHref}" class="strip-link" target="_blank" rel="noopener noreferrer">${linkText} &rarr;</a>
                                ${canPlay ? `<button class="strip-play-btn" data-embed="${project.embedUrl}" data-title="${project.title}">&#9654; Play Now</button>` : ''}
                            </div>
                        </div>
                    </div>
                `;

                // Lightbox: click thumbnail to expand
                const thumb = strip.querySelector('.strip-thumbnail');
                thumb.addEventListener('click', e => {
                    if (e.target.closest('.gallery-btn')) return; // ignore nav arrow clicks
                    const validMedia = mediaArr.filter(Boolean);
                    // Find current visible slide index
                    const activeSlide = thumb.querySelector('.strip-thumb-slide.active');
                    const slides = Array.from(thumb.querySelectorAll('.strip-thumb-slide'));
                    const startIdx = activeSlide ? slides.indexOf(activeSlide) : 0;
                    openLightbox(validMedia, startIdx, project.title);
                });

                if (hasMultiple) {
                    const slides = Array.from(thumb.querySelectorAll('.strip-thumb-slide'));
                    const curEl  = thumb.querySelector('.gallery-cur');
                    let cur = 0;

                    function goTo(idx) {
                        slides[cur].classList.remove('active');
                        cur = (idx + slides.length) % slides.length;
                        slides[cur].classList.add('active');
                        if (curEl) curEl.textContent = cur + 1;
                    }

                    thumb.querySelector('.gallery-btn-prev').addEventListener('click', e => { e.stopPropagation(); goTo(cur - 1); });
                    thumb.querySelector('.gallery-btn-next').addEventListener('click', e => { e.stopPropagation(); goTo(cur + 1); });
                }

                strip.querySelector('.strip-header').addEventListener('click', () => {
                    if (strip.classList.contains('strip-active') || isMobile) return;
                    const slotSize = 1 + HERO_HOLD;
                    window.scrollTo({ top: BUF_VH * window.innerHeight + i * slotSize * SEC_VH * window.innerHeight, behavior: 'smooth' });
                });

                const playBtn = strip.querySelector('.strip-play-btn');
                if (playBtn) {
                    playBtn.addEventListener('click', e => {
                        e.stopPropagation();
                        openGameEmbed(playBtn.dataset.embed, playBtn.dataset.title);
                    });
                }

                stage.appendChild(strip);
            });
        }

        function initScrollEngine() {
            const stage = document.getElementById('sectionsStage');
            let ticking = false;

            function update() {
                if (isMobile) { ticking = false; return; }

                const strips = Array.from(stage.querySelectorAll('.section-strip'));
                const N = strips.length;
                if (!N) { ticking = false; return; }

                const stageH   = window.innerHeight - NAV_H;
                const heroH    = stageH * HERO_FRAC;
                const otherH   = N > 1 ? (stageH - heroH) / (N - 1) : 0;
                const bufPx    = BUF_VH * window.innerHeight;
                const secPx    = SEC_VH * window.innerHeight;
                const slotSize = 1 + HERO_HOLD;
                const scrollY  = window.scrollY;

                const heights = new Array(N).fill(otherH);
                let activeIdx = -1;

                if (scrollY <= bufPx) {
                    const t      = bufPx > 0 ? scrollY / bufPx : 1;
                    const equalH = stageH / N;
                    const h0     = equalH + (heroH - equalH) * t;
                    const hRest  = N > 1 ? (stageH - h0) / (N - 1) : 0;
                    heights[0]   = h0;
                    for (let i = 1; i < N; i++) heights[i] = hRest;
                    activeIdx = h0 >= heroH ? 0 : -1;
                } else {
                    const frac     = (scrollY - bufPx) / secPx;
                    const slotIdx  = Math.floor(frac / slotSize);
                    const slotFrac = frac - slotIdx * slotSize;
                    const lo       = Math.min(slotIdx, N - 1);

                    if (lo >= N - 1) {
                        heights[N - 1] = heroH;
                        for (let i = 0; i < N - 1; i++) heights[i] = otherH;
                        activeIdx = N - 1;
                    } else if (slotFrac <= HERO_HOLD) {
                        heights[lo] = heroH;
                        for (let i = 0; i < N; i++) if (i !== lo) heights[i] = otherH;
                        activeIdx = lo;
                    } else {
                        const t  = slotFrac - HERO_HOLD;
                        const hi = lo + 1;
                        heights[lo] = heroH * (1 - t) + otherH * t;
                        heights[hi] = otherH * (1 - t) + heroH * t;
                        for (let i = 0; i < N; i++) {
                            if (i !== lo && i !== hi) heights[i] = otherH;
                        }
                        activeIdx = t < 0.5 ? lo : hi;
                    }
                }

                strips.forEach((s, i) => {
                    s.style.height = Math.max(0, heights[i]) + 'px';
                    s.classList.toggle('strip-active', i === activeIdx);
                });
                ticking = false;
            }

            window.addEventListener('scroll', () => {
                if (!ticking) { requestAnimationFrame(update); ticking = true; }
            }, { passive: true });

            window.addEventListener('resize', () => {
                checkMobile();
                if (!isMobile) {
                    const stage  = document.getElementById('sectionsStage');
                    const driver = document.getElementById('scrollDriver');
                    const N = stage.querySelectorAll('.section-strip').length;
                    const slotSize = 1 + HERO_HOLD;
                    stage.style.height  = (window.innerHeight - NAV_H) + 'px';
                    driver.style.height = ((BUF_VH + N * slotSize * SEC_VH) * window.innerHeight) + 'px';
                    requestAnimationFrame(update);
                }
            });

            update();
        }

        function snapshotIconHeights() {
            requestAnimationFrame(() => {
                document.querySelectorAll('.strip-icon').forEach(icon => {
                    const h = icon.getBoundingClientRect().height;
                    if (h > 0) icon.style.maxHeight = h + 'px';
                });
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            checkMobile();
            buildStrips(liveProjects);
            initScrollEngine();
            snapshotIconHeights();

            // ── Triple-click the footer to open the edit password prompt ──────
            // Footer lives in the Layout (after the slot), so must be wired here.
            let clicks = 0, clickTimer = null;
            document.querySelector('footer')?.addEventListener('click', () => {
                clicks++;
                if (clicks === 1) {
                    clickTimer = setTimeout(() => { clicks = 0; }, 700);
                }
                if (clicks >= 3) {
                    clearTimeout(clickTimer);
                    clicks = 0;
                    showPasswordModal();
                }
            });
        });

        // ═══════════════════════════════════════════════════════════════════════
        // GAME EMBED OVERLAY

        /* ── LIGHTBOX ── */
        let lbMedia = [], lbIdx = 0, lbProjectTitle = '';

        function lbShow(idx) {
            lbIdx = (idx + lbMedia.length) % lbMedia.length;
            const src = lbMedia[lbIdx];
            const body = document.getElementById('lbBody');
            // Remove old media (keep nav buttons)
            body.querySelectorAll('.lightbox-media, .lightbox-media-video').forEach(el => el.remove());
            if (isVideo(src)) {
                const v = document.createElement('video');
                v.src = src; v.controls = true; v.autoplay = true;
                v.muted = false; v.className = 'lightbox-media-video';
                body.insertBefore(v, body.querySelector('.lightbox-nav-next'));
            } else {
                const img = document.createElement('img');
                img.src = src; img.className = 'lightbox-media'; img.alt = '';
                body.insertBefore(img, body.querySelector('.lightbox-nav-next'));
            }
            document.getElementById('lbCounter').textContent =
                lbMedia.length > 1 ? `${lbIdx + 1} / ${lbMedia.length}` : '';
            // Hide nav arrows if only one item
            document.getElementById('lbPrev').style.display = lbMedia.length > 1 ? '' : 'none';
            document.getElementById('lbNext').style.display = lbMedia.length > 1 ? '' : 'none';
        }

        function openLightbox(media, startIdx, projectTitle) {
            lbMedia = media; lbProjectTitle = projectTitle || '';
            document.getElementById('lbTitle').textContent = lbProjectTitle;
            document.getElementById('lightbox').style.display = 'flex';
            lbShow(startIdx);
        }

        function closeLightbox() {
            // Pause any playing video
            document.getElementById('lbBody').querySelectorAll('video').forEach(v => v.pause());
            document.getElementById('lightbox').style.display = 'none';
        }

        document.getElementById('lbClose').addEventListener('click', closeLightbox);
        document.getElementById('lbPrev').addEventListener('click', () => lbShow(lbIdx - 1));
        document.getElementById('lbNext').addEventListener('click', () => lbShow(lbIdx + 1));
        document.getElementById('lightbox').addEventListener('click', e => {
            if (e.target === document.getElementById('lightbox')) closeLightbox();
        });
        document.addEventListener('keydown', e => {
            if (document.getElementById('lightbox').style.display === 'none') return;
            if (e.key === 'Escape')      closeLightbox();
            if (e.key === 'ArrowLeft')   lbShow(lbIdx - 1);
            if (e.key === 'ArrowRight')  lbShow(lbIdx + 1);
        });

        function openGameEmbed(url, title, nativeW = 960, nativeH = 600) {
            const overlay = document.getElementById('playOverlay');
            const iframe  = document.getElementById('playIframe');
            document.getElementById('playOverlayTitle').textContent = title || '';
            iframe.style.transform = '';   // reset any previous scale
            overlay.style.display = 'flex';

            requestAnimationFrame(() => {
                const wrap = overlay.querySelector('.play-iframe-wrap');
                const { width: cw, height: ch } = wrap.getBoundingClientRect();

                let finalUrl = url;
                if (url.includes('embed-upload')) {
                    // Force black background so itch.io padding blends with our overlay
                    finalUrl = finalUrl.replace(/[?&]color=[^&]*/i, '');
                    const sep = finalUrl.includes('?') ? '&' : '?';
                    finalUrl += `${sep}color=000000`;

                    // Scale so the canvas fits inside the container (letterbox if needed).
                    // scaleY is based on nativeH only — the itch.io footer hangs below
                    // the container border (overflow:visible) and stays fully clickable.
                    const scaleX = cw / nativeW;
                    const scaleY = ch / nativeH;
                    const scale  = Math.min(scaleX, scaleY);
                    const ox = (cw - nativeW  * scale) / 2;
                    const oy = (ch - nativeH  * scale) / 2;
                    iframe.style.transform = `translate(${ox}px,${oy}px) scale(${scale})`;
                    iframe.style.width  = nativeW + 'px';
                    iframe.style.height = (nativeH + 42) + 'px';
                }

                iframe.src = finalUrl;
            });
        }

        function closeGameEmbed() {
            const iframe = document.getElementById('playIframe');
            iframe.src = '';   // stops the game / audio
            iframe.style.transform = '';
            iframe.style.width  = '';
            iframe.style.height = '';
            document.getElementById('playOverlay').style.display = 'none';
        }

        document.getElementById('playCloseBtn').addEventListener('click', closeGameEmbed);
        document.getElementById('playFsBtn').addEventListener('click', () => {
            const iframe = document.getElementById('playIframe');
            (iframe.requestFullscreen?.() ?? iframe.webkitRequestFullscreen?.());
        });
        document.getElementById('playOverlay').addEventListener('click', e => {
            if (e.target === document.getElementById('playOverlay')) closeGameEmbed();
        });
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape' && document.getElementById('playOverlay').style.display !== 'none') {
                closeGameEmbed();
            }
        });

        // ═══════════════════════════════════════════════════════════════════════
        // EDIT MODE
        // Change this password to whatever you like:
        const EDIT_PASSWORD = 'studio212';

        let editMode    = false;
        let editingIdx  = null;     // null = new project, number = existing index
        let editScreenshots = [];   // mutable copy for the media tab

        // ── Password modal ────────────────────────────────────────────────────
        function showPasswordModal() {
            document.getElementById('passwordInput').value = '';
            document.getElementById('passwordError').style.display = 'none';
            document.getElementById('passwordModal').style.display = 'flex';
            setTimeout(() => document.getElementById('passwordInput').focus(), 60);
        }

        function hidePasswordModal() {
            document.getElementById('passwordModal').style.display = 'none';
        }

        document.getElementById('passwordCancel').addEventListener('click', hidePasswordModal);

        document.getElementById('passwordInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') checkPassword();
            if (e.key === 'Escape') hidePasswordModal();
        });

        document.getElementById('passwordConfirm').addEventListener('click', checkPassword);

        function checkPassword() {
            if (document.getElementById('passwordInput').value === EDIT_PASSWORD) {
                hidePasswordModal();
                enterEditMode();
            } else {
                document.getElementById('passwordError').style.display = 'block';
                document.getElementById('passwordInput').value = '';
                document.getElementById('passwordInput').focus();
            }
        }

        // ── Activate / deactivate edit mode ───────────────────────────────────
        function enterEditMode() {
            editMode = true;
            document.body.classList.add('edit-mode');
            document.getElementById('editToolbar').style.display = 'flex';
            attachEditButtons();
        }

        function attachEditButtons() {
            const strips = document.querySelectorAll('.section-strip');
            const total  = strips.length;
            strips.forEach((strip, i) => {
                if (strip.querySelector('.strip-edit-btn')) return; // already attached

                // Edit button
                const btn = document.createElement('button');
                btn.className = 'strip-edit-btn';
                btn.textContent = '✎ Edit';
                btn.dataset.idx = i;
                btn.addEventListener('click', e => {
                    e.stopPropagation();
                    openEditor(parseInt(btn.dataset.idx));
                });
                strip.querySelector('.strip-header').appendChild(btn);

                // Reorder buttons
                const wrap = document.createElement('div');
                wrap.className = 'strip-reorder-btns';
                const upBtn   = document.createElement('button');
                const downBtn = document.createElement('button');
                upBtn.className = downBtn.className = 'strip-reorder-btn';
                upBtn.textContent = '▲'; downBtn.textContent = '▼';
                upBtn.title   = 'Move up';   downBtn.title = 'Move down';
                upBtn.disabled   = (i === 0);
                downBtn.disabled = (i === total - 1);
                upBtn.addEventListener('click', e => {
                    e.stopPropagation();
                    const idx = parseInt(btn.dataset.idx);
                    if (idx === 0) return;
                    [liveProjects[idx - 1], liveProjects[idx]] = [liveProjects[idx], liveProjects[idx - 1]];
                    saveToAPI();
                    rebuildAfterEdit();
                });
                downBtn.addEventListener('click', e => {
                    e.stopPropagation();
                    const idx = parseInt(btn.dataset.idx);
                    if (idx >= liveProjects.length - 1) return;
                    [liveProjects[idx], liveProjects[idx + 1]] = [liveProjects[idx + 1], liveProjects[idx]];
                    saveToAPI();
                    rebuildAfterEdit();
                });
                wrap.appendChild(upBtn);
                wrap.appendChild(downBtn);
                strip.querySelector('.strip-header').appendChild(wrap);
            });
        }

        function exitEditMode() {
            editMode = false;
            document.body.classList.remove('edit-mode');
            document.getElementById('editToolbar').style.display = 'none';
        }

        document.getElementById('exitEditBtn').addEventListener('click', exitEditMode);
        document.getElementById('addProjectBtn').addEventListener('click', () => openEditor(null));

        // ── Rebuild strips after edit ──────────────────────────────────────────
        function rebuildAfterEdit() {
            buildStrips(liveProjects);
            snapshotIconHeights();
            if (editMode) attachEditButtons();
            window.dispatchEvent(new Event('scroll'));
        }

        // ── Editor modal ──────────────────────────────────────────────────────
        function openEditor(idx) {
            editingIdx = idx;
            const p = idx !== null ? liveProjects[idx] : {};

            document.getElementById('editorTitle').textContent =
                idx !== null ? `Edit: ${p.title || '(untitled)'}` : 'New Project';
            document.getElementById('editorDelete').style.display =
                idx !== null ? 'block' : 'none';

            // Basic
            document.getElementById('ef-title').value       = p.title || '';
            document.getElementById('ef-shortDesc').value   = p.shortDescription || '';
            document.getElementById('ef-fullDesc').value    = p.fullDescription || '';
            document.getElementById('ef-tags').value        = (p.tags || []).join(', ');
            document.getElementById('ef-devTime').value     = p.developmentTime || '';
            document.getElementById('ef-teamSize').value    = p.teamSize || '';
            document.getElementById('ef-tools').value       = (p.tools || []).join(', ');
            document.getElementById('ef-challenges').value  = p.challenges || '';
            document.getElementById('ef-learnings').value   = p.learnings || '';

            // Links
            document.getElementById('ef-playLink').value    = p.playLink || '';
            document.getElementById('ef-linkText').value    = p.linkText || '';
            document.getElementById('ef-hasEmbed').checked  = p.hasEmbed || false;
            document.getElementById('ef-embedType').value   = p.embedType || 'game';
            document.getElementById('ef-embedUrl').value    = p.embedUrl || '';
            document.getElementById('ef-gradient').value    = p.gradient || '';

            // Media
            editScreenshots = [...(p.screenshots || [])];
            renderIconPreview(p.image || '');
            document.getElementById('ef-iconUrl').value = p.image || '';
            renderMediaList();

            switchTab('basic');
            document.getElementById('projectEditorModal').style.display = 'flex';
        }

        function closeEditor() {
            document.getElementById('projectEditorModal').style.display = 'none';
        }

        document.getElementById('editorClose').addEventListener('click', closeEditor);
        document.getElementById('editorCancel').addEventListener('click', closeEditor);

        // Close on backdrop click
        document.getElementById('projectEditorModal').addEventListener('click', e => {
            if (e.target === document.getElementById('projectEditorModal')) closeEditor();
        });
        document.getElementById('passwordModal').addEventListener('click', e => {
            if (e.target === document.getElementById('passwordModal')) hidePasswordModal();
        });

        // ── Tabs ──────────────────────────────────────────────────────────────
        document.querySelectorAll('.edit-tab').forEach(tab => {
            tab.addEventListener('click', () => switchTab(tab.dataset.tab));
        });

        function switchTab(name) {
            document.querySelectorAll('.edit-tab').forEach(t =>
                t.classList.toggle('active', t.dataset.tab === name));
            document.querySelectorAll('.edit-tab-content[data-tab]').forEach(c =>
                c.style.display = c.dataset.tab === name ? 'flex' : 'none');
        }

        // ── Icon preview ──────────────────────────────────────────────────────
        document.getElementById('ef-iconUrl').addEventListener('input', e =>
            renderIconPreview(e.target.value));

        document.getElementById('ef-iconUploadBtn').addEventListener('click', () =>
            document.getElementById('ef-iconUpload').click());

        document.getElementById('ef-iconUpload').addEventListener('change', async e => {
            const file = e.target.files[0];
            if (!file) return;
            const result = await uploadFile(file, 'images');
            if (result) {
                document.getElementById('ef-iconUrl').value = result;
                renderIconPreview(result);
            }
            e.target.value = '';
        });

        function renderIconPreview(src) {
            document.getElementById('ef-iconPreview').style.backgroundImage =
                src ? `url('${src}')` : 'none';
        }

        // ── Media list ────────────────────────────────────────────────────────
        function renderMediaList() {
            const list = document.getElementById('ef-mediaList');
            list.innerHTML = '';
            if (!editScreenshots.length) {
                list.innerHTML = '<p style="font-size:0.75rem;color:var(--text-muted);margin:0">No screenshots yet</p>';
                return;
            }
            editScreenshots.forEach((src, i) => {
                const item = document.createElement('div');
                item.className = 'media-item';
                const vid = isVideo(src);
                const thumbEl = vid
                    ? `<div class="media-item-thumb-vid">VIDEO</div>`
                    : `<img class="media-item-thumb" src="${src}" alt="" onerror="this.style.opacity=0.2">`;
                item.innerHTML = `
                    ${thumbEl}
                    <span class="media-item-name" title="${src}">${src.split('/').pop()}</span>
                    <div class="media-item-btns">
                        <button class="media-item-btn" data-action="up"   data-idx="${i}" ${i === 0 ? 'disabled style="opacity:0.3"' : ''}>↑</button>
                        <button class="media-item-btn" data-action="down" data-idx="${i}" ${i === editScreenshots.length - 1 ? 'disabled style="opacity:0.3"' : ''}>↓</button>
                        <button class="media-item-btn del" data-action="del" data-idx="${i}">✕</button>
                    </div>`;
                list.appendChild(item);
            });

            list.querySelectorAll('[data-action]:not([disabled])').forEach(btn => {
                btn.addEventListener('click', () => {
                    const i = parseInt(btn.dataset.idx);
                    if (btn.dataset.action === 'up') {
                        [editScreenshots[i - 1], editScreenshots[i]] = [editScreenshots[i], editScreenshots[i - 1]];
                    } else if (btn.dataset.action === 'down') {
                        [editScreenshots[i], editScreenshots[i + 1]] = [editScreenshots[i + 1], editScreenshots[i]];
                    } else if (btn.dataset.action === 'del') {
                        editScreenshots.splice(i, 1);
                    }
                    renderMediaList();
                });
            });
        }

        document.getElementById('ef-addMediaUpload').addEventListener('click', () =>
            document.getElementById('ef-mediaUpload').click());

        document.getElementById('ef-addMediaUrl').addEventListener('click', () => {
            const url = prompt('Enter image or video URL (or path relative to /projects/):');
            if (url && url.trim()) {
                editScreenshots.push(url.trim());
                renderMediaList();
            }
        });

        document.getElementById('ef-mediaUpload').addEventListener('change', async e => {
            const files = Array.from(e.target.files);
            for (const file of files) {
                const result = await uploadFile(file, 'screenshots');
                if (result) editScreenshots.push(result);
            }
            renderMediaList();
            e.target.value = '';
        });

        // ── File upload helper ────────────────────────────────────────────────
        async function uploadFile(file, subfolder) {
            return new Promise(resolve => {
                const reader = new FileReader();
                reader.onload = async ev => {
                    const safe = file.name.replace(/[^a-z0-9._\-() ]/gi, '_');
                    try {
                        const resp = await fetch('/api/upload', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ subfolder, filename: safe, data: ev.target.result })
                        });
                        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                        const json = await resp.json();
                        resolve(json.path); // e.g. "screenshots/game.png"
                    } catch (err) {
                        alert('Upload failed: ' + err.message + '\n\nNote: uploads only work in dev mode (astro dev).');
                        resolve(null);
                    }
                };
                reader.readAsDataURL(file);
            });
        }

        // ── Collect form data ─────────────────────────────────────────────────
        function collectFormData() {
            const existing = editingIdx !== null ? liveProjects[editingIdx] : {};
            return {
                ...existing,
                title:            document.getElementById('ef-title').value.trim(),
                shortDescription: document.getElementById('ef-shortDesc').value.trim(),
                fullDescription:  document.getElementById('ef-fullDesc').value.trim(),
                tags:             document.getElementById('ef-tags').value.split(',').map(t => t.trim()).filter(Boolean),
                developmentTime:  document.getElementById('ef-devTime').value.trim(),
                teamSize:         document.getElementById('ef-teamSize').value.trim(),
                tools:            document.getElementById('ef-tools').value.split(',').map(t => t.trim()).filter(Boolean),
                challenges:       document.getElementById('ef-challenges').value.trim(),
                learnings:        document.getElementById('ef-learnings').value.trim(),
                image:            document.getElementById('ef-iconUrl').value.trim(),
                screenshots:      [...editScreenshots],
                playLink:         document.getElementById('ef-playLink').value.trim(),
                linkText:         document.getElementById('ef-linkText').value.trim(),
                hasEmbed:         document.getElementById('ef-hasEmbed').checked,
                embedType:        document.getElementById('ef-embedType').value,
                embedUrl:         document.getElementById('ef-embedUrl').value.trim(),
                gradient:         document.getElementById('ef-gradient').value.trim(),
            };
        }

        // ── Save ──────────────────────────────────────────────────────────────
        document.getElementById('editorSave').addEventListener('click', async () => {
            const data = collectFormData();
            if (!data.title) { alert('Title is required.'); return; }
            if (editingIdx !== null) {
                liveProjects[editingIdx] = data;
            } else {
                liveProjects.push(data);
            }
            await saveToAPI();
            closeEditor();
            rebuildAfterEdit();
        });

        // ── Delete ────────────────────────────────────────────────────────────
        document.getElementById('editorDelete').addEventListener('click', async () => {
            const title = liveProjects[editingIdx]?.title || 'this project';
            if (!confirm(`Delete "${title}"?\n\nThis cannot be undone.`)) return;
            liveProjects.splice(editingIdx, 1);
            await saveToAPI();
            closeEditor();
            rebuildAfterEdit();
        });

        // ── POST projects.json to API ──────────────────────────────────────────
        async function saveToAPI() {
            try {
                const resp = await fetch('/api/projects', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ projects: liveProjects })
                });
                if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            } catch (err) {
                alert('Could not save to API: ' + err.message +
                    '\n\nNote: saving only works in dev mode (astro dev).\nYour changes are applied locally for this session.');
            }
        }
    </script>
</Layout>
