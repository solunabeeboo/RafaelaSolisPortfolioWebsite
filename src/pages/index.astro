---
import Layout from '../layouts/Layout.astro';
import projectsData from '../data/projects.json';
import siteData from '../data/site.json';

const projects = (projectsData as any).projects as Array<{ screenshots?: string[] }>;
const homeData = (siteData as any).home;

// All available non-video screenshots — passed to client JS for random assignment
const allImages: string[] = projects
    .flatMap(p =>
        (p.screenshots ?? [])
            .filter((s: string) => !s.endsWith('.mp4') && !s.endsWith('.webm'))
    )
    .map(s => `/projects/${s}`);

const PANEL_COUNT = 11;
---
<Layout
    title="Rafaela Solis - Game Developer Portfolio"
    description="Passionate game developer creating engaging and immersive experiences. Specializing in gameplay programming, level design, and systems design."
    ogUrl="https://rafaelasolis.work/"
>
    <style>
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: calc(var(--nav-h) + 3rem) var(--section-padding) 3rem;
            position: relative;
            overflow: hidden;
            background: var(--border); /* fills corner gaps between strips */
        }

        /* ── PANEL STRIPS ── */
        .panel-bg {
            position: absolute;
            top: 0;
            bottom: 0;
            left: -8%;
            right: -8%;
        }

        .panel-strip {
            position: absolute;
            top: -25%;
            bottom: -25%;
            overflow: hidden;
            transform: skewX(-8deg);
            transform-origin: center center;
            border-right: 3px solid var(--border);
        }

        .panel-strip:last-child { border-right: none; }

        .panel-img {
            position: absolute;
            top: -20%;
            bottom: -20%;
            left: -20vw;
            right: -20vw;
            background-size: cover;
            background-position: center;
            transform: skewX(8deg);       /* counter-skew so image stays upright */
            transform-origin: center center;
            filter: brightness(0.55);
        }

        .panel-tint {
            position: absolute;
            inset: 0;
            mix-blend-mode: color;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.6s ease;
        }

        /* ── HERO BOX ── */
        .hero-content {
            position: relative;
            z-index: 1;
            text-align: center;
            animation: fadeInUp 0.7s ease-out both;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .hero-box {
            background: var(--bg);
            border: 3px solid var(--border);
            box-shadow: 10px 10px 0 var(--border);
            padding: 3rem 4.5rem;
            display: inline-block;
        }

        .hero-name {
            font-size: clamp(3rem, 6vw, 6.5rem);
            font-weight: 700;
            letter-spacing: -0.03em;
            line-height: 1;
            color: var(--text-primary);
            white-space: nowrap;
        }

        .accent-rule {
            width: 80px;
            height: 4px;
            background: var(--accent);
            margin: 1.75rem auto;
        }

        .hero-role {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--accent-sage);
            text-transform: uppercase;
            letter-spacing: 0.22em;
            margin-bottom: 1.25rem;
        }

        .hero-tagline {
            font-size: 1.05rem;
            color: var(--text-muted);
            max-width: 500px;
            margin: 0 auto 3rem;
            line-height: 1.8;
        }

        .cta-group {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .cta-button {
            display: inline-flex;
            align-items: center;
            padding: 0.85rem 2.25rem;
            background: var(--accent);
            color: var(--bg);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            transition: transform 0.15s, box-shadow 0.15s;
        }

        .cta-button:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0 var(--border);
        }

        .cta-button.secondary {
            background: transparent;
            color: var(--accent);
            border-color: var(--accent);
            box-shadow: 4px 4px 0 var(--accent);
        }

        .cta-button.secondary:hover { box-shadow: 6px 6px 0 var(--accent); }

        @media (max-width: 768px) {
            .hero-name { font-size: clamp(2rem, 10vw, 3.5rem); white-space: normal; }
            .hero-box { padding: 2rem 1.75rem; }

            /*
             * Diagonal stripes: rotate the whole panel container 45° so its
             * vertical strips become diagonal bands going top-left → bottom-right.
             * inset: -100% extends it 3× the hero size so rotated corners still cover.
             */
            .panel-bg {
                top: -100%; bottom: -100%;
                left: -100%; right: -100%;
                transform: rotate(45deg);
            }

            /* 6 evenly-spaced strips, straight (undo desktop skew).
               JS sets left/width inline so !important is needed to override. */
            .panel-strip {
                top: 0; bottom: 0;
                transform: none;
                border-right: 3px solid var(--border);
            }
            .panel-strip:nth-child(1) { left: 0%                   !important; width: calc(100% / 6) !important; }
            .panel-strip:nth-child(2) { left: calc(1 * 100% / 6)   !important; width: calc(100% / 6) !important; }
            .panel-strip:nth-child(3) { left: calc(2 * 100% / 6)   !important; width: calc(100% / 6) !important; }
            .panel-strip:nth-child(4) { left: calc(3 * 100% / 6)   !important; width: calc(100% / 6) !important; }
            .panel-strip:nth-child(5) { left: calc(4 * 100% / 6)   !important; width: calc(100% / 6) !important; }
            .panel-strip:nth-child(6) { left: calc(5 * 100% / 6)   !important; width: calc(100% / 6) !important; border-right: none; }
            .panel-strip:nth-child(n+7) { display: none; }

            /* Counter-rotate images -45° so they appear upright inside the diagonal strips.
               scale(1.5) is the minimum to fill after rotation (1/cos45° ≈ 1.41) + small buffer. */
            .panel-img {
                transform: rotate(-45deg) scale(1.5);
                top: 0; bottom: 0;
                left: -15%; right: -15%;
            }

            .panel-tint {
                transform: none;
                top: 0; bottom: 0; left: 0; right: 0;
            }

            .cta-group { flex-direction: column; align-items: center; }
            .cta-button { width: 100%; max-width: 300px; justify-content: center; box-shadow: 2px 2px 0 var(--border); }
            .cta-button.secondary { box-shadow: 2px 2px 0 var(--accent); }
        }

        /* ── EDIT MODE STYLES ── */
        .page-edit-toolbar {
            position: fixed; top: 0; left: 0; right: 0; z-index: 2000;
            background: var(--bg); border-bottom: 2px solid var(--border);
            display: flex; align-items: center; gap: 1rem;
            padding: 0.6rem 1.5rem; font-size: 0.75rem;
        }
        .page-edit-badge { font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); }
        .page-edit-spacer { flex: 1; }
        .page-edit-btn-primary {
            background: var(--accent); color: var(--bg); border: 2px solid var(--border);
            padding: 0.4rem 1.1rem; font-weight: 700; font-size: 0.72rem;
            text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; font-family: inherit;
        }
        .page-edit-btn-secondary {
            background: transparent; color: var(--text-secondary); border: 2px solid var(--border);
            padding: 0.4rem 1.1rem; font-weight: 700; font-size: 0.72rem;
            text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; font-family: inherit;
        }
        body.page-edit-mode [data-editable] {
            outline: 2px dashed var(--accent); outline-offset: 2px; cursor: text;
        }
        body.page-edit-mode { padding-top: 2.5rem; }
        .page-pw-overlay {
            position: fixed; inset: 0; z-index: 3000; background: rgba(0,0,0,0.6);
            display: flex; align-items: center; justify-content: center;
        }
        .page-pw-box {
            background: var(--bg); border: 2px solid var(--border); box-shadow: 8px 8px 0 var(--border);
            padding: 1.75rem; width: min(90vw, 340px); display: flex; flex-direction: column; gap: 0.75rem;
        }
        .page-pw-box h3 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin: 0; }
        .page-pw-box input {
            background: var(--card-bg); border: 1.5px solid var(--border); color: var(--text-primary);
            padding: 0.5rem 0.65rem; font-size: 0.9rem; font-family: inherit; width: 100%; box-sizing: border-box;
        }
        .page-pw-error { color: #e55; font-size: 0.75rem; display: none; }
        .page-pw-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
    </style>

    <!-- Edit toolbar (hidden until edit mode) -->
    <div id="pageEditToolbar" class="page-edit-toolbar" style="display:none">
        <span class="page-edit-badge">&#9998; Edit Mode</span>
        <div class="page-edit-spacer"></div>
        <button class="page-edit-btn-secondary" id="pageEditCancel">Cancel</button>
        <button class="page-edit-btn-primary" id="pageEditSave">Save Changes</button>
    </div>

    <!-- Password modal -->
    <div id="homePwOverlay" class="page-pw-overlay" style="display:none">
        <div class="page-pw-box">
            <h3>Edit Mode</h3>
            <input type="password" id="homePwInput" placeholder="Password" autocomplete="off">
            <span class="page-pw-error" id="homePwError">Incorrect password</span>
            <div class="page-pw-actions">
                <button class="page-edit-btn-secondary" id="homePwCancel">Cancel</button>
                <button class="page-edit-btn-primary" id="homePwSubmit">Unlock</button>
            </div>
        </div>
    </div>

    <section class="hero">
        <div class="panel-bg">
            {Array.from({ length: PANEL_COUNT }, (_, i) => (
                <div
                    class="panel-strip"
                    style={`left: calc(${i} / ${PANEL_COUNT} * 100%); width: calc(100% / ${PANEL_COUNT} + 1px);`}
                >
                    <div class="panel-img"></div>
                    <div class="panel-tint"></div>
                </div>
            ))}
        </div>

        <div class="hero-content">
            <div class="hero-box">
                <h1 class="hero-name">Rafaela Solis</h1>
                <div class="accent-rule"></div>
                <p class="hero-role" data-editable="home.role" spellcheck="false">{homeData.role}</p>
                <p class="hero-tagline" data-editable="home.tagline" spellcheck="false">{homeData.tagline}</p>
                <div class="cta-group">
                    <a href="/projects/" class="cta-button">View My Work</a>
                    <a href="/contact/" class="cta-button secondary">Get In Touch</a>
                </div>
            </div>
        </div>
    </section>

    <script define:vars={{ allImages }}>
        // ── Color extraction helpers ──────────────────────────────────────────
        function extractDominantColor(src) {
            return new Promise(resolve => {
                const img = new Image();
                img.onload = () => {
                    try {
                        const size = 20;
                        const canvas = document.createElement('canvas');
                        canvas.width = size; canvas.height = size;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, size, size);
                        const data = ctx.getImageData(0, 0, size, size).data;
                        let r = 0, g = 0, b = 0, n = 0;
                        for (let i = 0; i < data.length; i += 4) {
                            const ri = data[i], gi = data[i+1], bi = data[i+2];
                            const max = Math.max(ri, gi, bi);
                            const min = Math.min(ri, gi, bi);
                            const sat = max > 0 ? (max - min) / max : 0;
                            // Weight saturated, non-dark pixels more (pop color)
                            if (sat > 0.15 && max > 40) {
                                const w = sat * (max / 255);
                                r += ri * w; g += gi * w; b += bi * w; n += w;
                            }
                        }
                        if (n < 1) { r = 128; g = 128; b = 128; n = 1; }
                        resolve({ r: r/n, g: g/n, b: b/n });
                    } catch(e) {
                        resolve({ r: 128, g: 128, b: 128 });
                    }
                };
                img.onerror = () => resolve({ r: 128, g: 128, b: 128 });
                img.src = src;
            });
        }

        function rgbToHue(r, g, b) {
            r /= 255; g /= 255; b /= 255;
            const max = Math.max(r,g,b), min = Math.min(r,g,b);
            if (max === min) return 0;
            const d = max - min;
            let h;
            if      (max === r) h = (g - b) / d + (g < b ? 6 : 0);
            else if (max === g) h = (b - r) / d + 2;
            else                h = (r - g) / d + 4;
            return h / 6;
        }

        // ── Assign images and apply rainbow tint ─────────────────────────────
        (async () => {
            const strips = Array.from(document.querySelectorAll('.panel-strip'));
            const count  = strips.length;
            const pool   = [...allImages].sort(() => Math.random() - 0.5);
            const chosen = pool.slice(0, count).concat(
                pool.slice(0, Math.max(0, count - pool.length))
            );

            // First pass: show images immediately (no delay)
            strips.forEach((strip, i) => {
                const src = chosen[i % chosen.length];
                const imgEl = strip.querySelector('.panel-img');
                if (imgEl) imgEl.style.backgroundImage = `url('${src}')`;
            });

            // Second pass: extract colors in parallel
            const colorData = await Promise.all(chosen.map(async (src, i) => {
                const { r, g, b } = await extractDominantColor(src);
                const hue = rgbToHue(r, g, b);
                return { src, hue };
            }));

            // Sort images by extracted hue so warm images land on warm strips etc.
            colorData.sort((a, b) => a.hue - b.hue);

            // Force evenly-spaced rainbow hues (red→violet) regardless of image colors
            strips.forEach((strip, i) => {
                const { src } = colorData[i % colorData.length];
                const imgEl  = strip.querySelector('.panel-img');
                const tintEl = strip.querySelector('.panel-tint');
                if (imgEl) imgEl.style.backgroundImage = `url('${src}')`;
                if (tintEl) {
                    // Spread hue evenly from 0° (red) to 300° (violet) across all strips
                    const hueDeg = Math.round((i / Math.max(count - 1, 1)) * 300);
                    tintEl.style.background = `hsl(${hueDeg}, 90%, 55%)`;
                    tintEl.style.opacity    = '0.25';
                }
            });
        })();
    </script>

    <script define:vars={{ homeData }}>
        // ── Edit mode ────────────────────────────────────────────────────────
        const EDIT_PASSWORD = 'studio212';
        let editMode = false;

        function showPasswordModal() {
            const overlay = document.getElementById('homePwOverlay');
            const input   = document.getElementById('homePwInput');
            const err     = document.getElementById('homePwError');
            if (!overlay || !input) return;
            err.style.display = 'none';
            input.value = '';
            overlay.style.display = 'flex';
            setTimeout(() => input.focus(), 50);
        }

        function hidePasswordModal() {
            const overlay = document.getElementById('homePwOverlay');
            if (overlay) overlay.style.display = 'none';
        }

        function enterEditMode() {
            editMode = true;
            document.body.classList.add('page-edit-mode');
            const toolbar = document.getElementById('pageEditToolbar');
            if (toolbar) toolbar.style.display = 'flex';
            document.querySelectorAll('[data-editable]').forEach(el => {
                el.contentEditable = 'true';
            });
        }

        function exitEditMode() {
            editMode = false;
            document.body.classList.remove('page-edit-mode');
            const toolbar = document.getElementById('pageEditToolbar');
            if (toolbar) toolbar.style.display = 'none';
            document.querySelectorAll('[data-editable]').forEach(el => {
                el.contentEditable = 'false';
            });
        }

        async function saveChanges() {
            try {
                const siteResp = await fetch('/api/site');
                const site = await siteResp.json();
                const roleEl    = document.querySelector('[data-editable="home.role"]');
                const taglineEl = document.querySelector('[data-editable="home.tagline"]');
                if (roleEl)    site.home.role    = roleEl.textContent.trim() || site.home.role;
                if (taglineEl) site.home.tagline = taglineEl.textContent.trim() || site.home.tagline;
                await fetch('/api/site', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(site)
                });
                exitEditMode();
                location.reload();
            } catch (e) {
                alert('Save failed: ' + e);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Triple-click footer to activate
            let clicks = 0, timer = null;
            document.querySelector('footer')?.addEventListener('click', () => {
                clicks++;
                if (clicks === 1) timer = setTimeout(() => { clicks = 0; }, 700);
                if (clicks >= 3) { clearTimeout(timer); clicks = 0; showPasswordModal(); }
            });

            // Password modal buttons
            document.getElementById('homePwCancel')?.addEventListener('click', hidePasswordModal);
            document.getElementById('homePwSubmit')?.addEventListener('click', () => {
                const input = document.getElementById('homePwInput');
                const err   = document.getElementById('homePwError');
                if (input.value === EDIT_PASSWORD) {
                    hidePasswordModal();
                    enterEditMode();
                } else {
                    err.style.display = 'block';
                    input.value = '';
                    input.focus();
                }
            });
            document.getElementById('homePwInput')?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') document.getElementById('homePwSubmit')?.click();
                if (e.key === 'Escape') hidePasswordModal();
            });

            // Toolbar buttons
            document.getElementById('pageEditCancel')?.addEventListener('click', exitEditMode);
            document.getElementById('pageEditSave')?.addEventListener('click', saveChanges);
        });
    </script>
</Layout>
