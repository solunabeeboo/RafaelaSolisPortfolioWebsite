---
import Layout from '../../layouts/Layout.astro';
import siteData from '../../data/site.json';
const contactData = (siteData as any).contact;
---
<Layout title="Contact - Rafaela Solis">
    <style>
        /* ===== PAGE ===== */
        .contact-page {
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            padding: calc(var(--nav-h) + 1.75rem) 1rem 0.5rem;
            overflow: hidden;
        }

        .page-header { text-align: center; flex-shrink: 0; opacity: 0; animation: header-in 0.4s ease-out 0s forwards; }

        .page-eyebrow {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--accent-sage);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            margin-bottom: 0.25rem;
        }

        .page-title {
            font-size: clamp(2.4rem, 3.6vw, 3.2rem);
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.03em;
            line-height: 1;
        }

        /* ===== WHEEL ===== */
        .wheel-container {
            position: relative;
            flex: 1;
            width: min(1300px, 98vw);
            min-height: 0;
        }

        .spokes-svg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .spoke-line {
            stroke: var(--border);
            stroke-width: 0.35;
            stroke-dasharray: 1500;
            stroke-dashoffset: 1500;
            transition: stroke 0.25s ease, stroke-width 0.25s ease;
        }

        .spoke-line.spoke-active {
            stroke: var(--accent);
            stroke-width: 1.5;
        }

        /* ===== HUB ===== */
        .hub {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: clamp(80px, 12vmin, 120px);
            height: clamp(80px, 12vmin, 120px);
            border-radius: 50%;
            background: var(--accent);
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 2;
            text-align: center;
            padding: 0.25rem;
            opacity: 0;
            animation: hub-appear 0.4s ease-out 0.15s forwards, hub-pulse 3s ease-in-out 1.5s infinite;
        }

        .hub-name {
            font-size: clamp(0.7rem, 2vmin, 1rem);
            font-weight: 700;
            color: var(--bg);
            text-transform: uppercase;
            letter-spacing: 0.18em;
            line-height: 1;
        }

        /* ===== KEYFRAMES ===== */
        @keyframes header-in {
            from { opacity: 0; transform: translateY(-10px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @keyframes hub-appear {
            from { opacity: 0; transform: translate(-50%, -50%) scale(0.6); }
            to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        }

        @keyframes hub-pulse {
            0%, 100% { box-shadow: 4px 4px 0 var(--border); }
            50%       { box-shadow: 4px 4px 0 var(--border), 0 0 0 8px rgba(45,80,22,0.12); }
        }

        @keyframes spoke-draw {
            from { stroke-dashoffset: 1500; }
            to   { stroke-dashoffset: 0; }
        }

        @keyframes node-appear {
            from { opacity: 0; transform: translate(-50%, -50%) scale(0.75); }
            to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        }

        /* ===== NODES ===== */
        .node {
            position: absolute;
            transform: translate(-50%, -50%);
            width: 22%;
            text-decoration: none;
            z-index: 3;
            opacity: 0;
        }

        .node-card {
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 3px 3px 0 var(--border);
            padding: 1.1rem 1.3rem 1.2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.4rem;
            text-align: center;
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
        }

        .node:hover .node-card {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0 var(--accent);
            border-color: var(--accent);
        }

        .node-icon {
            font-size: clamp(2rem, 5vmin, 2.8rem);
            line-height: 1;
        }

        .node-label {
            font-size: clamp(1rem, 2.5vmin, 1.4rem);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--accent);
            line-height: 1;
        }

        .node-handle {
            font-size: clamp(0.8rem, 2vmin, 1.1rem);
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
            line-height: 1;
        }

        /* Node positions — evenly spaced, clockwise from top, radius 39% */
        .node-email     { top: 11%;   left: 50%;   animation: node-appear 0.35s ease-out 0.35s forwards; }
        .node-linkedin  { top: 25.7%; left: 80.5%; animation: node-appear 0.35s ease-out 0.45s forwards; }
        .node-bluesky   { top: 58.7%; left: 88%;   animation: node-appear 0.35s ease-out 0.55s forwards; }
        .node-itch      { top: 85.1%; left: 66.9%; animation: node-appear 0.35s ease-out 0.65s forwards; }
        .node-instagram { top: 85.1%; left: 33.1%; animation: node-appear 0.35s ease-out 0.75s forwards; }
        .node-discord   { top: 58.7%; left: 12%;   animation: node-appear 0.35s ease-out 0.85s forwards; }
        .node-github    { top: 25.7%; left: 19.5%; animation: node-appear 0.35s ease-out 0.95s forwards; }

        /* ===== MOBILE ===== */
        @media (max-width: 600px) {
            .contact-page { height: auto; overflow: visible; padding-bottom: 2rem; }
            .wheel-container { display: none; }
            .mobile-list { display: flex; flex-direction: column; gap: 0.65rem; width: 100%; max-width: 400px; padding: 0 1.5rem; }
        }
        @media (min-width: 601px) {
            .mobile-list { display: none; }
        }

        .mobile-link {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.85rem 1.25rem;
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 3px 3px 0 var(--border);
            text-decoration: none;
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.88rem;
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
        }

        .mobile-link:hover {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0 var(--accent);
            border-color: var(--accent);
        }

        .mobile-link-icon { font-size: 1.3rem; line-height: 1; }
        .mobile-link-label { font-weight: 700; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.1em; color: var(--accent); }
        .mobile-link-handle { font-size: 0.78rem; color: var(--text-secondary); }
        .mobile-link-info { display: flex; flex-direction: column; gap: 0.1rem; }

        /* ===== EDIT MODE ===== */
        .page-edit-toolbar {
            position: fixed; top: 0; left: 0; right: 0; z-index: 2000;
            background: var(--bg); border-bottom: 2px solid var(--border);
            display: flex; align-items: center; gap: 1rem;
            padding: 0.6rem 1.5rem; font-size: 0.75rem;
        }
        .page-edit-badge { font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); }
        .page-edit-spacer { flex: 1; }
        .page-edit-btn-primary {
            background: var(--accent); color: var(--bg); border: 2px solid var(--border);
            padding: 0.4rem 1.1rem; font-weight: 700; font-size: 0.72rem;
            text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; font-family: inherit;
        }
        .page-edit-btn-secondary {
            background: transparent; color: var(--text-secondary); border: 2px solid var(--border);
            padding: 0.4rem 1.1rem; font-weight: 700; font-size: 0.72rem;
            text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; font-family: inherit;
        }
        body.page-edit-mode { padding-top: 2.5rem; }
        .page-edit-overlay {
            position: fixed; inset: 0; z-index: 2100; background: rgba(0,0,0,0.7);
            display: flex; align-items: center; justify-content: center;
        }
        .page-edit-modal {
            background: var(--bg); border: 2px solid var(--border); box-shadow: 8px 8px 0 var(--border);
            padding: 1.5rem 1.75rem; width: min(90vw, 420px);
            display: flex; flex-direction: column; gap: 0.75rem;
        }
        .page-edit-modal h3 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin: 0; }
        .page-edit-modal label { font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); display: flex; flex-direction: column; gap: 0.3rem; }
        .page-edit-modal input {
            background: var(--card-bg); border: 1.5px solid var(--border); color: var(--text-primary);
            padding: 0.45rem 0.65rem; font-size: 0.85rem; font-family: inherit; width: 100%; box-sizing: border-box;
        }
        .page-pw-overlay {
            position: fixed; inset: 0; z-index: 3000; background: rgba(0,0,0,0.6);
            display: flex; align-items: center; justify-content: center;
        }
        .page-pw-box {
            background: var(--bg); border: 2px solid var(--border); box-shadow: 8px 8px 0 var(--border);
            padding: 1.75rem; width: min(90vw, 340px); display: flex; flex-direction: column; gap: 0.75rem;
        }
        .page-pw-box h3 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin: 0; }
        .page-pw-box input {
            background: var(--card-bg); border: 1.5px solid var(--border); color: var(--text-primary);
            padding: 0.5rem 0.65rem; font-size: 0.9rem; font-family: inherit; width: 100%; box-sizing: border-box;
        }
        .page-pw-error { color: #e55; font-size: 0.75rem; display: none; }
        .page-pw-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
        /* Node edit button */
        .node-edit-btn {
            display: none; position: absolute; top: 4px; right: 4px;
            background: var(--accent); color: var(--bg); border: none;
            font-size: 0.65rem; padding: 2px 5px; cursor: pointer; font-family: inherit;
            z-index: 10;
        }
        body.page-edit-mode .node-edit-btn { display: block; }
    </style>

    <!-- Edit toolbar -->
    <div id="pageEditToolbar" class="page-edit-toolbar" style="display:none">
        <span class="page-edit-badge">&#9998; Edit Mode</span>
        <div class="page-edit-spacer"></div>
        <button class="page-edit-btn-secondary" id="pageEditCancel">Cancel</button>
        <button class="page-edit-btn-secondary" id="pageEditAddNode" style="color:var(--bg);background:var(--accent-sage);border-color:var(--border)">+ Add Node</button>
        <button class="page-edit-btn-primary" id="pageEditSave">Save Changes</button>
    </div>

    <!-- Password modal -->
    <div id="contactPwOverlay" class="page-pw-overlay" style="display:none">
        <div class="page-pw-box">
            <h3>Edit Mode</h3>
            <input type="password" id="contactPwInput" placeholder="Password" autocomplete="off">
            <span class="page-pw-error" id="contactPwError">Incorrect password</span>
            <div class="page-pw-actions">
                <button class="page-edit-btn-secondary" id="contactPwCancel">Cancel</button>
                <button class="page-edit-btn-primary" id="contactPwSubmit">Unlock</button>
            </div>
        </div>
    </div>

    <!-- Node editor modal -->
    <div id="nodeEditorModal" class="page-edit-overlay" style="display:none">
        <div class="page-edit-modal">
            <div style="display:flex;align-items:center;justify-content:space-between">
                <h3 style="margin:0">Edit Contact Node</h3>
                <div style="display:flex;gap:0.35rem">
                    <button id="ne-up"   class="page-edit-btn-secondary" title="Move up"   style="padding:0.3rem 0.6rem">▲</button>
                    <button id="ne-down" class="page-edit-btn-secondary" title="Move down" style="padding:0.3rem 0.6rem">▼</button>
                </div>
            </div>
            <label>Icon (emoji)<br><input id="ne-icon" type="text" autocomplete="off"></label>
            <label>Label<br><input id="ne-label" type="text" autocomplete="off"></label>
            <label>Handle / Display text<br><input id="ne-handle" type="text" autocomplete="off"></label>
            <label>URL / href<br><input id="ne-href" type="text" autocomplete="off"></label>
            <div style="display:flex;gap:0.5rem;justify-content:space-between;margin-top:0.25rem;align-items:center">
                <button id="ne-delete" class="page-edit-btn-secondary" style="color:#c0392b;border-color:#c0392b">Delete Node</button>
                <div style="display:flex;gap:0.5rem">
                    <button id="ne-cancel" class="page-edit-btn-secondary">Cancel</button>
                    <button id="ne-save" class="page-edit-btn-primary">Save Node</button>
                </div>
            </div>
        </div>
    </div>

    <div class="contact-page">

        <header class="page-header">
            <p class="page-eyebrow">Let's Talk</p>
            <h1 class="page-title">Get In Touch</h1>
        </header>

        <!-- ── WHEEL (desktop) ── -->
        <div class="wheel-container" aria-label="Contact links">

            <svg class="spokes-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
                {contactData.nodes.map((node: { id: string }) => (
                    <line id={`spoke-${node.id}`} class="spoke-line" x1="50" y1="50" x2="50" y2="50" />
                ))}
            </svg>

            <div class="hub">
                <span class="hub-name">CONTACT</span>
            </div>

            {contactData.nodes.map((node: { id: string; href: string; cssClass: string; icon: string; label: string; handle: string }) => (
                <a
                    href={node.href}
                    class={`node ${node.cssClass}`}
                    data-spoke={`spoke-${node.id}`}
                    data-node-id={node.id}
                    target={node.href.startsWith('mailto') ? undefined : '_blank'}
                    rel="noopener noreferrer"
                    style="position:absolute;"
                >
                    <div class="node-card" style="position:relative;">
                        <span class="node-icon">{node.icon}</span>
                        <span class="node-label">{node.label}</span>
                        <span class="node-handle">{node.handle}</span>
                        <button class="node-edit-btn" title="Edit node">&#9998;</button>
                    </div>
                </a>
            ))}

        </div>

        <!-- ── MOBILE fallback ── -->
        <nav class="mobile-list" aria-label="Contact links">
            {contactData.nodes.map((node: { id: string; href: string; icon: string; label: string; handle: string }) => (
                <a
                    href={node.href}
                    class="mobile-link"
                    data-node-id={node.id}
                    target={node.href.startsWith('mailto') ? undefined : '_blank'}
                    rel="noopener noreferrer"
                >
                    <span class="mobile-link-icon">{node.icon}</span>
                    <div class="mobile-link-info">
                        <span class="mobile-link-label">{node.label}</span>
                        <span class="mobile-link-handle">{node.handle}</span>
                    </div>
                </a>
            ))}
        </nav>

    </div>

    <script define:vars={{ contactData }}>
        const EDIT_PASSWORD = 'studio212';
        let editMode = false;
        let liveContactData = JSON.parse(JSON.stringify(contactData));
        let activeNodeId = null;

        function showPasswordModal() {
            const overlay = document.getElementById('contactPwOverlay');
            const input   = document.getElementById('contactPwInput');
            const err     = document.getElementById('contactPwError');
            if (!overlay || !input) return;
            err.style.display = 'none';
            input.value = '';
            overlay.style.display = 'flex';
            setTimeout(() => input.focus(), 50);
        }

        function hidePasswordModal() {
            const overlay = document.getElementById('contactPwOverlay');
            if (overlay) overlay.style.display = 'none';
        }

        function enterEditMode() {
            editMode = true;
            document.body.classList.add('page-edit-mode');
            const toolbar = document.getElementById('pageEditToolbar');
            if (toolbar) toolbar.style.display = 'flex';
            attachNodeEditButtons();
        }

        function exitEditMode() {
            editMode = false;
            document.body.classList.remove('page-edit-mode');
            const toolbar = document.getElementById('pageEditToolbar');
            if (toolbar) toolbar.style.display = 'none';
        }

        function attachNodeEditButtons() {
            document.querySelectorAll('.node[data-node-id]').forEach(nodeEl => {
                const nodeId = nodeEl.dataset.nodeId;
                const btn = nodeEl.querySelector('.node-edit-btn');
                if (!btn) return;
                btn.onclick = (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    openNodeEditor(nodeId);
                };
            });
        }

        function openNodeEditor(nodeId) {
            isAddingNode = false;
            const nodeData = liveContactData.nodes.find(n => n.id === nodeId);
            if (!nodeData) return;
            activeNodeId = nodeId;
            document.getElementById('ne-delete').style.visibility = 'visible';

            document.getElementById('ne-icon').value   = nodeData.icon   || '';
            document.getElementById('ne-label').value  = nodeData.label  || '';
            document.getElementById('ne-handle').value = nodeData.handle || '';
            document.getElementById('ne-href').value   = nodeData.href   || '';

            const idx   = liveContactData.nodes.findIndex(n => n.id === nodeId);
            const total = liveContactData.nodes.length;
            document.getElementById('ne-up').disabled   = idx <= 0;
            document.getElementById('ne-down').disabled = idx >= total - 1;

            document.getElementById('nodeEditorModal').style.display = 'flex';
            setTimeout(() => document.getElementById('ne-icon').focus(), 50);
        }

        function closeNodeEditor() {
            document.getElementById('nodeEditorModal').style.display = 'none';
            activeNodeId = null;
        }

        function saveNodeEdit() {
            // ── Add new node ──
            if (isAddingNode) {
                isAddingNode = false;
                const label = document.getElementById('ne-label').value.trim() || 'New Node';
                const usedClasses = liveContactData.nodes.map(n => n.cssClass);
                const cssClass = ALL_POSITIONS.find(p => !usedClasses.includes(p)) || ALL_POSITIONS[0];
                const id = label.toLowerCase().replace(/[^a-z0-9]/g, '-') + '-' + Date.now();
                const node = {
                    id,
                    icon:     document.getElementById('ne-icon').value.trim()   || '🔗',
                    label,
                    handle:   document.getElementById('ne-handle').value.trim() || '',
                    href:     document.getElementById('ne-href').value.trim()   || '#',
                    cssClass
                };
                liveContactData.nodes.push(node);
                addNodeToDOM(node);
                closeNodeEditor();
                autoSaveContact();
                return;
            }

            if (!activeNodeId) return;
            const nodeData = liveContactData.nodes.find(n => n.id === activeNodeId);
            if (!nodeData) return;

            nodeData.icon   = document.getElementById('ne-icon').value.trim()   || nodeData.icon;
            nodeData.label  = document.getElementById('ne-label').value.trim()  || nodeData.label;
            nodeData.handle = document.getElementById('ne-handle').value.trim() || nodeData.handle;
            nodeData.href   = document.getElementById('ne-href').value.trim()   || nodeData.href;

            // Update wheel node DOM
            const nodeEl = document.querySelector(`.node[data-node-id="${activeNodeId}"]`);
            if (nodeEl) {
                const iconEl   = nodeEl.querySelector('.node-icon');
                const labelEl  = nodeEl.querySelector('.node-label');
                const handleEl = nodeEl.querySelector('.node-handle');
                if (iconEl)   iconEl.textContent   = nodeData.icon;
                if (labelEl)  labelEl.textContent  = nodeData.label;
                if (handleEl) handleEl.textContent = nodeData.handle;
                nodeEl.href = nodeData.href;
                if (nodeData.href.startsWith('mailto')) {
                    nodeEl.removeAttribute('target');
                } else {
                    nodeEl.setAttribute('target', '_blank');
                }
            }

            // Update mobile node DOM
            const mobileEl = document.querySelector(`.mobile-link[data-node-id="${activeNodeId}"]`);
            if (mobileEl) {
                const iconEl   = mobileEl.querySelector('.mobile-link-icon');
                const labelEl  = mobileEl.querySelector('.mobile-link-label');
                const handleEl = mobileEl.querySelector('.mobile-link-handle');
                if (iconEl)   iconEl.textContent   = nodeData.icon;
                if (labelEl)  labelEl.textContent  = nodeData.label;
                if (handleEl) handleEl.textContent = nodeData.handle;
                mobileEl.href = nodeData.href;
                if (nodeData.href.startsWith('mailto')) {
                    mobileEl.removeAttribute('target');
                } else {
                    mobileEl.setAttribute('target', '_blank');
                }
            }

            closeNodeEditor();
        }

        // All 7 wheel spoke positions in clockwise order
        const ALL_POSITIONS = ['node-email','node-linkedin','node-bluesky','node-itch','node-instagram','node-discord','node-github'];

        let isAddingNode = false;

        function openNewNodeEditor() {
            isAddingNode = true;
            activeNodeId = null;
            document.getElementById('ne-icon').value   = '';
            document.getElementById('ne-label').value  = '';
            document.getElementById('ne-handle').value = '';
            document.getElementById('ne-href').value   = '';
            document.getElementById('ne-up').disabled   = true;
            document.getElementById('ne-down').disabled = true;
            document.getElementById('ne-delete').style.visibility = 'hidden';
            document.getElementById('nodeEditorModal').style.display = 'flex';
            setTimeout(() => document.getElementById('ne-icon').focus(), 50);
        }

        function addNodeToDOM(node) {
            // 1. Add SVG spoke line
            const svg = document.querySelector('.spokes-svg');
            if (svg) {
                const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                line.id = `spoke-${node.id}`;
                line.classList.add('spoke-line');
                line.setAttribute('x1', '50'); line.setAttribute('y1', '50');
                line.setAttribute('x2', '50'); line.setAttribute('y2', '50');
                svg.appendChild(line);
            }

            // 2. Add wheel node
            const wheelContainer = document.querySelector('.wheel-container');
            if (wheelContainer) {
                const a = document.createElement('a');
                a.href = node.href;
                a.className = `node ${node.cssClass}`;
                a.dataset.spoke  = `spoke-${node.id}`;
                a.dataset.nodeId = node.id;
                if (!node.href.startsWith('mailto')) a.target = '_blank';
                a.rel = 'noopener noreferrer';
                a.style.position = 'absolute';
                a.innerHTML = `<div class="node-card" style="position:relative;">
                    <span class="node-icon">${node.icon}</span>
                    <span class="node-label">${node.label}</span>
                    <span class="node-handle">${node.handle}</span>
                    <button class="node-edit-btn" title="Edit node">&#9998;</button>
                </div>`;
                const editBtn = a.querySelector('.node-edit-btn');
                if (editBtn) editBtn.onclick = (e) => { e.preventDefault(); e.stopPropagation(); openNodeEditor(node.id); };
                const line = document.getElementById(`spoke-${node.id}`);
                if (line) {
                    a.addEventListener('mouseenter', () => line.classList.add('spoke-active'));
                    a.addEventListener('mouseleave', () => line.classList.remove('spoke-active'));
                }
                wheelContainer.appendChild(a);
            }

            // 3. Add mobile link
            const mobileList = document.querySelector('.mobile-list');
            if (mobileList) {
                const a = document.createElement('a');
                a.href = node.href;
                a.className = 'mobile-link';
                a.dataset.nodeId = node.id;
                if (!node.href.startsWith('mailto')) a.target = '_blank';
                a.rel = 'noopener noreferrer';
                a.innerHTML = `<span class="mobile-link-icon">${node.icon}</span>
                    <div class="mobile-link-info">
                        <span class="mobile-link-label">${node.label}</span>
                        <span class="mobile-link-handle">${node.handle}</span>
                    </div>`;
                mobileList.appendChild(a);
            }

            positionNodesEvenly();
        }

        // Distribute all wheel nodes evenly around the ellipse based on array order
        function positionNodesEvenly() {
            const container = document.querySelector('.wheel-container');
            if (!container) return;
            const { width: cw, height: ch } = container.getBoundingClientRect();
            if (!cw || !ch) return;

            const rx = cw * 0.38;
            const ry = ch * 0.39;

            liveContactData.nodes.forEach((nodeData, i) => {
                const el = document.querySelector(`.node[data-node-id="${nodeData.id}"]`);
                if (!el) return;
                const angle = -Math.PI / 2 + (2 * Math.PI / liveContactData.nodes.length) * i;
                el.style.left = (50 + (rx / cw * 100) * Math.cos(angle)).toFixed(2) + '%';
                el.style.top  = (50 + (ry / ch * 100) * Math.sin(angle)).toFixed(2) + '%';
            });

            updateSpokeEndpoints();
        }

        function rebuildContactNodes() {
            // Re-order mobile list to match liveContactData order
            const mobileList = document.querySelector('.mobile-list');
            if (mobileList) {
                liveContactData.nodes.forEach(node => {
                    const el = mobileList.querySelector(`[data-node-id="${node.id}"]`);
                    if (el) mobileList.appendChild(el);
                });
            }

            // Reposition wheel nodes evenly
            positionNodesEvenly();
        }

        async function autoSaveContact() {
            try {
                const siteResp = await fetch('/api/site');
                const site = await siteResp.json();
                site.contact = liveContactData;
                await fetch('/api/site', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(site)
                });
            } catch (e) {
                console.error('Auto-save failed:', e);
            }
        }

        async function saveChanges() {
            try {
                const siteResp = await fetch('/api/site');
                const site = await siteResp.json();
                site.contact = liveContactData;
                await fetch('/api/site', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(site)
                });
                exitEditMode();
                location.reload();
            } catch (e) {
                alert('Save failed: ' + e);
            }
        }

        // ── Compute spoke endpoints to exactly hit each card's edge ──────────
        function updateSpokeEndpoints() {
            const svg       = document.querySelector('.spokes-svg');
            const container = document.querySelector('.wheel-container');
            if (!svg || !container) return;

            const cr  = container.getBoundingClientRect();
            if (cr.width === 0 || cr.height === 0) return; // hidden (mobile)

            const hubX = cr.width  / 2;
            const hubY = cr.height / 2;

            document.querySelectorAll('.node[data-spoke]').forEach(node => {
                const spokeId = node.dataset.spoke;
                const line    = document.getElementById(spokeId);
                const card    = node.querySelector('.node-card');
                if (!line || !card) return;

                const box = card.getBoundingClientRect();

                // Card bounds relative to container
                const cl     = box.left   - cr.left;
                const cright = box.right  - cr.left;
                const ct     = box.top    - cr.top;
                const cb     = box.bottom - cr.top;

                // Direction from hub to card center
                const cx = (cl + cright) / 2;
                const cy = (ct + cb)     / 2;
                const dx = cx - hubX;
                const dy = cy - hubY;

                // Find the smallest t where the hub→center ray hits a card edge
                const EPS = 2;
                let tMin = Infinity;

                const tryT = (t, x, y) => {
                    if (t > 0.01 && t < tMin &&
                        x >= cl - EPS && x <= cright + EPS &&
                        y >= ct - EPS && y <= cb + EPS) {
                        tMin = t;
                    }
                };

                if (Math.abs(dx) > 0.5) {
                    const tL = (cl     - hubX) / dx;
                    const tR = (cright - hubX) / dx;
                    tryT(tL, cl,     hubY + tL * dy);
                    tryT(tR, cright, hubY + tR * dy);
                }
                if (Math.abs(dy) > 0.5) {
                    const tT = (ct - hubY) / dy;
                    const tB = (cb - hubY) / dy;
                    tryT(tT, hubX + tT * dx, ct);
                    tryT(tB, hubX + tB * dx, cb);
                }

                if (tMin === Infinity) return;

                // Intersection in pixels → SVG viewBox (0–100)
                const px = hubX + tMin * dx;
                const py = hubY + tMin * dy;
                line.setAttribute('x2', ((px / cr.width)  * 100).toFixed(2));
                line.setAttribute('y2', ((py / cr.height) * 100).toFixed(2));

                // Also set x1/y1 to hub center in SVG coords
                line.setAttribute('x1', ((hubX / cr.width)  * 100).toFixed(2));
                line.setAttribute('y1', ((hubY / cr.height) * 100).toFixed(2));
            });
        }

        // ── Spoke draw-in on load ──
        function initSpokes() {
            positionNodesEvenly();
            window.addEventListener('resize', positionNodesEvenly);

            liveContactData.nodes.forEach((node, i) => {
                const delay = 350 + i * 100;
                const line = document.getElementById(`spoke-${node.id}`);
                if (!line) return;
                setTimeout(() => {
                    line.style.animation = 'spoke-draw 0.5s ease-out forwards';
                }, delay);
            });

            // Spoke green highlight on node hover
            document.querySelectorAll('.node[data-spoke]').forEach(node => {
                const spokeId = node.dataset.spoke;
                const line = document.getElementById(spokeId);
                if (!line) return;
                node.addEventListener('mouseenter', () => line.classList.add('spoke-active'));
                node.addEventListener('mouseleave', () => line.classList.remove('spoke-active'));
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            initSpokes();

            // Triple-click footer to activate
            let clicks = 0, timer = null;
            document.querySelector('footer')?.addEventListener('click', () => {
                clicks++;
                if (clicks === 1) timer = setTimeout(() => { clicks = 0; }, 700);
                if (clicks >= 3) { clearTimeout(timer); clicks = 0; showPasswordModal(); }
            });

            // Password modal buttons
            document.getElementById('contactPwCancel')?.addEventListener('click', hidePasswordModal);
            document.getElementById('contactPwSubmit')?.addEventListener('click', () => {
                const input = document.getElementById('contactPwInput');
                const err   = document.getElementById('contactPwError');
                if (input.value === EDIT_PASSWORD) {
                    hidePasswordModal();
                    enterEditMode();
                } else {
                    err.style.display = 'block';
                    input.value = '';
                    input.focus();
                }
            });
            document.getElementById('contactPwInput')?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') document.getElementById('contactPwSubmit')?.click();
                if (e.key === 'Escape') hidePasswordModal();
            });

            // Toolbar buttons
            document.getElementById('pageEditCancel')?.addEventListener('click', exitEditMode);
            document.getElementById('pageEditSave')?.addEventListener('click', saveChanges);
            document.getElementById('pageEditAddNode')?.addEventListener('click', openNewNodeEditor);

            // Node editor modal buttons
            document.getElementById('ne-cancel')?.addEventListener('click', closeNodeEditor);
            document.getElementById('ne-save')?.addEventListener('click', saveNodeEdit);
            document.getElementById('ne-delete')?.addEventListener('click', () => {
                if (!activeNodeId) return;
                if (!confirm('Delete this contact node?')) return;
                // Remove from data
                liveContactData.nodes = liveContactData.nodes.filter(n => n.id !== activeNodeId);
                // Remove deleted node from DOM
                document.querySelector(`.node[data-node-id="${activeNodeId}"]`)?.remove();
                document.querySelector(`.mobile-link[data-node-id="${activeNodeId}"]`)?.remove();
                closeNodeEditor();
                // Reposition remaining nodes evenly and auto-save
                positionNodesEvenly();
                autoSaveContact();
            });
            document.getElementById('ne-up')?.addEventListener('click', () => {
                const idx = liveContactData.nodes.findIndex(n => n.id === activeNodeId);
                if (idx <= 0) return;
                [liveContactData.nodes[idx - 1], liveContactData.nodes[idx]] =
                    [liveContactData.nodes[idx], liveContactData.nodes[idx - 1]];
                rebuildContactNodes();
                autoSaveContact();
                const newIdx = liveContactData.nodes.findIndex(n => n.id === activeNodeId);
                document.getElementById('ne-up').disabled   = newIdx <= 0;
                document.getElementById('ne-down').disabled = newIdx >= liveContactData.nodes.length - 1;
            });

            document.getElementById('ne-down')?.addEventListener('click', () => {
                const idx = liveContactData.nodes.findIndex(n => n.id === activeNodeId);
                if (idx < 0 || idx >= liveContactData.nodes.length - 1) return;
                [liveContactData.nodes[idx], liveContactData.nodes[idx + 1]] =
                    [liveContactData.nodes[idx + 1], liveContactData.nodes[idx]];
                rebuildContactNodes();
                autoSaveContact();
                const newIdx = liveContactData.nodes.findIndex(n => n.id === activeNodeId);
                document.getElementById('ne-up').disabled   = newIdx <= 0;
                document.getElementById('ne-down').disabled = newIdx >= liveContactData.nodes.length - 1;
            });

            document.getElementById('nodeEditorModal')?.addEventListener('click', (e) => {
                if (e.target === document.getElementById('nodeEditorModal')) closeNodeEditor();
            });
            document.getElementById('ne-href')?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') saveNodeEdit();
                if (e.key === 'Escape') closeNodeEditor();
            });
        });
    </script>
</Layout>
