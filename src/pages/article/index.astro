  <!-- Shell -->
  <div id="artShell">

    <!-- Sidebar -->
    <aside id="artSidebar" aria-label="Article list">
      <div class="art-sidebar-head">
        <span class="art-sidebar-label">Articles</span>
        <button id="artNewBtn" title="New article" aria-label="New article">+</button>
      </div>
      <div id="artList" role="list"></div>
    </aside>

    <!-- Reading area -->
    <main id="artMain">

      <!-- Edit strip -->
      <div id="artEditStrip" hidden>
        <span class="art-edit-hint">Ctrl+B bold &nbsp;·&nbsp; Ctrl+I italic</span>
        <span class="art-word-count" id="artWordCount"></span>
        <button id="artDeleteBtn">Delete</button>
        <button id="artSaveBtn">Save</button>
      </div>

      <!-- Cover — green band spans full width, image stays at column width -->
      <div id="artCoverWrap">
        <div id="artCover" data-seo="Cover image — hero visual shown as OG/Twitter card preview when shared"></div>
      </div>

      <div id="artContentWrapper">
        <article id="artArticle" itemscope itemtype="https://schema.org/Article" data-seo="Schema.org Article — main content block with microdata (itemscope/itemprop)">
          <header class="art-header">
            <div id="artTags" class="art-tags" aria-label="Tags" data-seo="Article tags — signals topical relevance and keyword categories to search engines"></div>
            <h1 id="artTitle" itemprop="headline" spellcheck="false" data-seo="h1 (itemprop=headline) — Primary headline; the single most important on-page SEO element"></h1>
            <div class="art-byline" data-seo="Byline — author + date signals E-E-A-T (Experience, Expertise, Authoritativeness, Trustworthiness)">
              <span>By <span id="artAuthor" itemprop="author" spellcheck="false" data-seo="itemprop=author — Author identity; E-E-A-T signal Google uses to assess content credibility"></span></span>
              <time id="artDate" itemprop="datePublished" data-seo="time (itemprop=datePublished) — Machine-readable date; used by Google for article freshness signals"></time>
              <span id="artReadTime"></span>
            </div>
          </header>
          <!-- Share bar -->
          <div class="art-share" aria-label="Share this article">
            <span class="art-share-label">Share</span>
            <a href="#" class="art-share-btn" onclick="return false" aria-label="Share on X" title="Share on X">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.73-8.835L1.254 2.25H8.08l4.259 5.631z"/></svg>
              X / Twitter
            </a>
            <a href="#" class="art-share-btn" onclick="return false" aria-label="Share on LinkedIn" title="Share on LinkedIn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
            <a href="#" class="art-share-btn" onclick="return false" aria-label="Share on Facebook" title="Share on Facebook">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <button class="art-share-btn" onclick="return false" aria-label="Copy link" title="Copy link">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
              Copy Link
            </button>
          </div>

          <div id="artBody" class="art-body" itemprop="articleBody" spellcheck="false" data-seo="itemprop=articleBody — All headings, images, and links inside are indexed by search engines"></div>
        </article>

        <!-- Popular Reads — absolutely positioned beside first h2, scrolls with article -->
        <aside id="artPopular" class="art-popular-hidden" aria-label="Popular reads">
          <div class="art-popular-header">
            <h2 class="art-popular-title">Popular Reads</h2>
            <span class="art-popular-eyebrow">Trending</span>
          </div>
