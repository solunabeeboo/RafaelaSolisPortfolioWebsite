---
<ArticleLayout
  title="Studio Journal — Rafaela Solis"
  description="A live article reading and editing environment demonstrating modern web typography, semantic HTML, and SEO best practices. Customize your reading experience and write your own articles."
  ogUrl="https://rafaelasolis.work/article/"
>
  <script slot="head" type="application/ld+json" id="artWebAppJsonLd">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Studio Journal",
    "description": "A live article reading and editing environment demonstrating modern web typography and SEO best practices.",
    "url": "https://rafaelasolis.work/article/",
    "applicationCategory": "DesignApplication",
    "operatingSystem": "Any",
    "author": { "@type": "Person", "name": "Rafaela Solis", "url": "https://rafaelasolis.work/" }
  })}</script>

  <style is:global>
    /* Override global.css overflow-x:hidden — that breaks position:fixed */
    body { overflow-x: clip; }

    :root { --toolbar-h: 52px; }

    /* ── Toolbar ── */
    #artToolbar {
      position: fixed;
      top: var(--pub-header-h, 56px);
      left: 0; right: 0;
      height: var(--toolbar-h);
      z-index: 150;
      background: #ffffff;
      border-bottom: 1px solid #d8d5d0;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0 1rem;
      overflow-x: auto;
      scrollbar-width: none;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    #artToolbar::-webkit-scrollbar { display: none; }

    .art-tb-group { display: flex; align-items: center; gap: 0.2rem; flex-shrink: 0; }
    .art-tb-sep { width: 1px; height: 18px; background: #d0cdc8; flex-shrink: 0; margin: 0 0.25rem; }
    .art-tb-spacer { flex: 1; min-width: 0.5rem; }

    #artToolbar button {
      background: transparent;
      border: 1.5px solid #d0cdc8;
      color: #3a3a3a;
      font-family: inherit;
      font-size: 0.67rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      padding: 0.27rem 0.55rem;
      cursor: pointer;
      line-height: 1;
      white-space: nowrap;
      transition: background 0.1s, color 0.1s, border-color 0.1s;
    }
    #artToolbar button:hover { background: #1a1a1a; color: #f5f2eb; border-color: #1a1a1a; }
    #artToolbar button.art-active { background: #1a1a1a; color: #f5f2eb; border-color: #1a1a1a; }

    #artSizeSlider { width: 70px; accent-color: #1a1a1a; cursor: pointer; vertical-align: middle; }
    #artSidebarToggle { font-size: 0.85rem; }

    #artSeoToggle, #artEditToggle {
      font-size: 0.78rem;
      padding: 0.42rem 1.1rem;
      letter-spacing: 0.12em;
      border-width: 2px;
    }
    #artSeoToggle { border-color: #e06020; color: #e06020; }
    #artSeoToggle:hover, #artSeoToggle.art-active { background: #e06020; color: #fff; border-color: #e06020; }
    #artEditToggle { border-color: var(--art-accent, #2d5016); color: var(--art-accent, #2d5016); }
    #artEditToggle:hover, #artEditToggle.art-active { background: var(--art-accent, #2d5016); color: #fff; border-color: var(--art-accent, #2d5016); }

    /* ── Shell ── */
    #artShell {
      display: flex;
      padding-top: calc(var(--pub-header-h, 56px) + var(--toolbar-h));
      min-height: 100vh;
    }

    /* ── Sidebar ── */
    #artSidebar {
      width: 240px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: calc(var(--pub-header-h, 56px) + var(--toolbar-h));
      height: calc(100vh - var(--pub-header-h, 56px) - var(--toolbar-h));
      overflow: hidden;
      background: #1a1a1a;
      border-right: 1px solid #2e2e2e;
      transition: width 0.25s, border-color 0.25s;
    }

    #artShell.sidebar-hidden #artSidebar { width: 0; border-right-color: transparent; }

    .art-sidebar-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.8rem 1rem;
      border-bottom: 1px solid #2e2e2e;
      flex-shrink: 0;
    }

    .art-sidebar-label {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: rgba(245,242,235,0.35);
      white-space: nowrap;
    }

    #artNewBtn {
      background: #2d5016;
      color: #f5f2eb;
      border: none;
      width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; font-weight: 400;
      cursor: pointer; padding: 0; line-height: 1;
      flex-shrink: 0;
      transition: background 0.1s;
    }
    #artNewBtn:hover { background: #3d6a20; }

    #artList { flex: 1; min-height: 0; overflow: hidden; scrollbar-width: thin; scrollbar-color: #333 #1a1a1a; }

    .art-list-item {
      width: 100%;
      background: none;
      border: none;
      border-bottom: 1px solid #252525;
      padding: 0.75rem 1rem;
      text-align: left;
      cursor: pointer;
      font-family: inherit;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      transition: background 0.1s;
      overflow: hidden;
    }
    .art-list-item:hover { background: rgba(255,255,255,0.05); }
    .art-list-item.art-list-active { background: #2d5016; }

    .art-list-title {
      font-size: 0.78rem;
      font-weight: 600;
      color: rgba(245,242,235,0.8);
      line-height: 1.35;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .art-list-item.art-list-active .art-list-title { color: #f5f2eb; }

    .art-list-date { font-size: 0.65rem; color: rgba(245,242,235,0.3); }
    .art-list-item.art-list-active .art-list-date { color: rgba(245,242,235,0.65); }

    /* ── Main ── */
    #artMain {
      flex: 1;
      background: var(--art-bg, #ffffff);
      color: var(--art-text, #1a1a1a);
      transition: background 0.25s, color 0.25s;
      min-height: calc(100vh - var(--pub-header-h, 56px) - var(--toolbar-h));
    }

    /* ── Cover hero — green band spans full width, image stays in column ── */
    #artCoverWrap {
      width: 100%;
      background: var(--art-accent, #2d5016);
      padding: 0.75rem 0;
    }

    #artCover {
      max-width: var(--art-width, 720px);
      width: calc(100% - 4rem);
      margin: 0 auto;
      aspect-ratio: 21/7;
      overflow: hidden;
      background: #d8d5d0;
      position: relative;
    }
    #artCover img { width: 100%; height: 100%; object-fit: cover; display: block; border: none; }
    #artCover .art-cover-placeholder {
      width: 100%; height: 100%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 0.5rem;
      background: repeating-linear-gradient(45deg, #e0ddd8, #e0ddd8 12px, #d4d1cc 12px, #d4d1cc 24px);
      color: #aaa8a4;
    }
    #artCover .art-cover-placeholder span {
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;
    }
    #artCover .art-cover-placeholder svg { opacity: 0.5; }

    /* ── Edit strip ── */
    #artEditStrip {
      position: sticky;
      top: 0;
      z-index: 10;
      background: var(--art-bg, #fff);
      border-bottom: 1px solid var(--art-border, #e8e8e8);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 2rem;
      font-size: 0.72rem;
      transition: background 0.25s, border-color 0.25s;
    }

    .art-edit-hint { color: var(--art-muted, #aaa); font-size: 0.66rem; font-style: italic; }
    .art-word-count { color: var(--art-muted, #aaa); font-size: 0.66rem; margin-left: auto; }

    #artEditStrip button {
      background: transparent;
      border: 1.5px solid var(--art-border, #e8e8e8);
      color: var(--art-text, #1a1a1a);
      font-family: inherit;
      font-size: 0.66rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      padding: 0.25rem 0.65rem;
      cursor: pointer; line-height: 1;
      transition: background 0.1s, color 0.1s;
      white-space: nowrap;
    }
    #artEditStrip button:hover { background: var(--art-text, #1a1a1a); color: var(--art-bg, #fff); }
    #artDeleteBtn { color: #b03030 !important; border-color: #b03030 !important; }
    #artDeleteBtn:hover { background: #b03030 !important; color: #fff !important; }
    #artSaveBtn { background: var(--art-accent, #2d5016) !important; color: #fff !important; border-color: var(--art-accent, #2d5016) !important; }

    /* ── Content wrapper ── */
    #artContentWrapper {
      max-width: var(--art-width, 720px);
      margin: 0 auto;
      padding: 0 2rem 6rem;
      position: relative;
    }

    /* ── Article content ── */
    article#artArticle {
      width: 100%;
      font-family: var(--art-font, inherit);
      font-size: var(--art-size, 18px);
      line-height: 1.8;
    }

    .art-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1.1rem; }
    .art-tag {
      font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
      padding: 0.18rem 0.55rem;
      border: 1.5px solid var(--art-accent, #2d5016);
      color: var(--art-accent, #2d5016);
    }

    #artTitle {
      font-size: clamp(1.75rem, 4vw, 3rem);
      font-weight: 700; line-height: 1.15; letter-spacing: -0.02em;
      color: var(--art-text, #1a1a1a);
      margin: 0 0 1.1rem; outline: none;
    }

    .art-byline {
      display: flex; flex-wrap: wrap; gap: 1rem;
      font-size: 0.82rem; color: var(--art-muted, #888);
      padding-bottom: 2rem; margin-bottom: 0;
      border-bottom: 1px solid var(--art-border, #e8e8e8);
    }
    #artAuthor { font-weight: 600; color: var(--art-text, #1a1a1a); outline: none; }

    .art-header { padding-top: 2rem; }

    /* ── Share bar ── */
    .art-share {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      padding: 1.25rem 0 0;
      flex-wrap: wrap;
    }
    .art-share-label {
      font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--art-muted, #888); margin-right: 0.15rem;
    }
    .art-share-btn {
      display: inline-flex; align-items: center; gap: 0.3rem;
      padding: 0.3rem 0.7rem;
      border: 1.5px solid var(--art-border, #e0e0e0);
      box-shadow: 2px 2px 0 var(--art-border, #e0e0e0);
      background: transparent;
      color: var(--art-text, #1a1a1a);
      font-size: 0.64rem; font-weight: 700; font-family: inherit;
      text-transform: uppercase; letter-spacing: 0.06em;
      cursor: pointer; text-decoration: none; line-height: 1;
      transition: background 0.12s, border-color 0.12s, color 0.12s, box-shadow 0.12s, transform 0.12s;
    }
    .art-share-btn:hover {
      background: var(--art-text, #1a1a1a);
      color: var(--art-bg, #fff);
      border-color: var(--art-text, #1a1a1a);
      box-shadow: 2px 2px 0 var(--art-text, #1a1a1a);
      transform: translate(-1px, -1px);
    }

    /* ── Body lead bolding ── */
    .art-lead { font-weight: 700; }

    /* ── Image placeholder ── */
    .art-body figure.art-figure-placeholder {
      border: 2px dashed var(--art-accent, #2d5016);
      background: rgba(45,80,22,0.04);
      aspect-ratio: 16/7;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 0.6rem;
      color: var(--art-accent, #2d5016);
      margin: 2em 0;
    }
    .art-figure-placeholder .art-ph-icon { opacity: 0.35; }
    .art-figure-placeholder .art-ph-label {
      font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.12em; opacity: 0.45;
    }

    .art-body { outline: none; caret-color: var(--art-accent, #2d5016); margin-top: 2.5rem; min-height: 80vh; }
    .art-body h2 { font-size: 1.4em; font-weight: 700; line-height: 1.25; margin: 2.5em 0 0.75em; color: var(--art-text, #1a1a1a); letter-spacing: -0.01em; }
    .art-body h3 { font-size: 1.15em; font-weight: 600; margin: 2em 0 0.5em; color: var(--art-text, #1a1a1a); }
    .art-body p { margin: 0 0 1.5em; }
    .art-body ul, .art-body ol { margin: 0 0 1.5em 1.75em; }
    .art-body li { margin-bottom: 0.4em; }
    .art-body a { color: var(--art-accent, #2d5016); }
    .art-body strong { font-weight: 700; }
    .art-body em { font-style: italic; }
    .art-body blockquote {
      border-left: 3px solid var(--art-accent, #2d5016);
      margin: 2em 0; padding: 0.75em 1.5em;
      color: var(--art-muted, #888); font-style: italic;
    }

    .art-body figure.art-figure { margin: 2em 0; width: 100%; }
    .art-body figure.art-figure img {
      width: 100%; height: auto; display: block; background: #d8d5d0;
      border: 7.5px solid var(--art-accent, #2d5016);
    }
    .art-body figure.art-figure figcaption {
      font-size: 0.75em; color: var(--art-muted, #888);
      padding: 0.55em 0.5em; font-style: italic; line-height: 1.5;
    }

    article#artArticle.art-editing #artTitle,
    article#artArticle.art-editing #artAuthor,
    article#artArticle.art-editing .art-body {
      outline: 2px dashed var(--art-accent, #2d5016); outline-offset: 6px;
    }

    /* ── Popular Reads (right rail, absolutely positioned beside first h2) ── */
    #artPopular {
      position: absolute;
      top: var(--art-popular-top, 0);
      left: var(--art-popular-left, 100%);
      width: 340px;
      background: var(--art-bg, #fff);
      color: var(--art-text, #1a1a1a);
      border: 1.5px solid var(--art-text, #1a1a1a);
      box-shadow: 6px 6px 0 var(--art-accent, #2d5016);
      padding: 1.4rem 1.4rem 0.75rem;
      z-index: 5;
      font-family: var(--art-font, inherit);
      transition: background 0.25s, color 0.25s, border-color 0.25s, box-shadow 0.25s;
    }
    #artPopular.art-popular-hidden { display: none; }

    .art-popular-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      margin: 0 0 0.5rem;
    }
    .art-popular-title {
      font-size: 1.35rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      margin: 0;
      color: var(--art-text, #1a1a1a);
    }
    .art-popular-eyebrow {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--art-accent, #2d5016);
      padding: 0.18rem 0.45rem;
      border: 1.5px solid var(--art-accent, #2d5016);
      line-height: 1;
    }
    .art-popular-divider {
      height: 2px;
      background: var(--art-text, #1a1a1a);
      margin: 0 0 0.4rem;
    }

    .art-popular-item {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      width: 100%;
      background: none;
      border: none;
      padding: 0.95rem 0;
      cursor: pointer;
      font-family: inherit;
      text-align: left;
      color: inherit;
      border-bottom: 1px solid var(--art-border, #e8e8e8);
      transition: transform 0.15s ease, opacity 0.15s;
    }
    .art-popular-item:last-child { border-bottom: none; }
    .art-popular-item:hover { transform: translateX(3px); }
    .art-popular-item:hover .art-popular-item-title { color: var(--art-accent, #2d5016); }

    .art-popular-thumb-wrap {
      width: 100%;
      aspect-ratio: 16/7;
      overflow: hidden;
      background: var(--art-border, #e8e8e8);
      border: 4px solid var(--art-accent, #2d5016);
      display: block;
    }
    .art-popular-thumb {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
    }
    .art-popular-thumb-ph {
      width: 100%; height: 100%;
      background: repeating-linear-gradient(45deg, var(--art-border, #e0ddd8), var(--art-border, #e0ddd8) 8px, var(--art-bg, #d4d1cc) 8px, var(--art-bg, #d4d1cc) 16px);
    }

    .art-popular-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
    }
    .art-popular-tag {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 0.14rem 0.4rem;
      border: 1.25px solid var(--art-accent, #2d5016);
      color: var(--art-accent, #2d5016);
      line-height: 1.2;
    }
    .art-popular-item-title {
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--art-text, #1a1a1a);
      transition: color 0.12s;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .art-popular-excerpt {
      font-size: 0.78rem;
      line-height: 1.5;
      color: var(--art-muted, #888);
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .art-popular-foot {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.62rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--art-muted, #888);
    }
    .art-popular-foot-dot {
      width: 3px; height: 3px; border-radius: 50%;
      background: var(--art-muted, #888); flex-shrink: 0;
    }

    /* Hide when there's no room beside the article column */
    @media (max-width: 1400px) {
      #artPopular { display: none; }
    }

    @media (max-width: 768px) {
      #artSidebar {
        position: fixed;
        top: calc(var(--pub-header-h, 56px) + var(--toolbar-h));
        left: 0;
        height: calc(100vh - var(--pub-header-h, 56px) - var(--toolbar-h));
        z-index: 140; width: 260px !important;
        transform: translateX(-100%); transition: transform 0.25s;
        border-right: 1px solid #2e2e2e !important;
      }
      #artSidebar.art-sidebar-open { transform: translateX(0); }
      #artShell.sidebar-hidden #artSidebar { transform: translateX(-100%); }

      #artContentWrapper { padding: 0 1.25rem 4rem; }
      #artEditStrip { padding: 0.4rem 1.25rem; }
      .art-edit-hint { display: none; }
      .art-related-card { width: calc(50% - 0.5rem); }
    }

    /* ── SEO inspector — element outlines ── */
    body.seo-active [data-seo] {
      outline: 2px dashed #e06020 !important;
      outline-offset: 2px;
      cursor: help !important;
    }

    /* ── SEO tooltip ── */
    #artSeoTooltip {
      position: fixed;
      z-index: 9999;
      background: #1a1a1a;
      color: #f5f2eb;
      font-size: 0.65rem;
      font-family: 'Space Grotesk', monospace;
      padding: 0.35rem 0.75rem;
      border: 1px solid #e06020;
      max-width: 340px;
      line-height: 1.5;
      pointer-events: none;
      box-shadow: 2px 2px 0 #e06020;
    }

    /* ── SEO panel ── */
    #artSeoPanel {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 500;
      width: 290px;
      background: #1a1a1a;
      border: 1.5px solid #e06020;
      box-shadow: 3px 3px 0 #e06020;
      font-family: 'Space Grotesk', monospace;
      color: #f5f2eb;
      max-height: calc(100vh - 3rem);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: #333 #1a1a1a;
    }
    .seo-panel-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid #2e2e2e;
      font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;
      color: #e06020; flex-shrink: 0;
      position: sticky; top: 0; background: #1a1a1a;
    }
    .seo-panel-header button {
      background: none; border: none; color: rgba(245,242,235,0.5); cursor: pointer;
      font-size: 0.8rem; padding: 0 0.15rem; line-height: 1;
    }
    .seo-panel-header button:hover { color: #f5f2eb; }
    .seo-panel-row {
      display: flex; flex-direction: column;
      padding: 0.3rem 0.75rem;
      border-bottom: 1px solid #222;
      gap: 0.1rem;
    }
    .seo-panel-label {
      font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.09em;
      color: rgba(245,242,235,0.3);
    }
    .seo-panel-value {
      font-size: 0.64rem; color: rgba(245,242,235,0.75); word-break: break-all; line-height: 1.4;
    }
    .seo-panel-value.seo-good { color: #6db56d; }
    .seo-panel-value.seo-warn { color: #e0a040; }
  </style>

  <!-- Toolbar -->
  <div id="artToolbar" role="toolbar" aria-label="Reading preferences">
    <div class="art-tb-group">
      <button id="artSidebarToggle" aria-label="Toggle article list" title="Toggle sidebar">☰</button>
