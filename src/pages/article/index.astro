  </div>

  <!-- SEO hover tooltip -->
  <div id="artSeoTooltip" role="tooltip" hidden></div>

  <!-- SEO inspector panel -->
  <div id="artSeoPanel" role="complementary" aria-label="SEO Inspector" hidden>
    <div class="seo-panel-header">
      <span>SEO Inspector</span>
      <button id="artSeoPanelClose" aria-label="Close SEO inspector">✕</button>
    </div>
    <div id="artSeoPanelContent"></div>
  </div>

  <script define:vars={{ SEED }}>
    const PREFS_KEY   = 'artPrefs_v1';
    const STORAGE_KEY = 'artArticles_v2';

    const THEMES = {
      light: { '--art-bg':'#ffffff', '--art-text':'#1a1a1a', '--art-muted':'#999999', '--art-accent':'#2d5016', '--art-border':'#ebebeb' },
      dark:  { '--art-bg':'#141414', '--art-text':'#e8e4dc', '--art-muted':'#666666', '--art-accent':'#6b8f47', '--art-border':'#282828' },
      sepia: { '--art-bg':'#f4ecd8', '--art-text':'#3d2b1f', '--art-muted':'#9b7e65', '--art-accent':'#6b4226', '--art-border':'#ddd0bb' }
    };

    const FONTS = {
      sans:  "'Space Grotesk', sans-serif",
      serif: "Georgia, 'Times New Roman', serif"
    };

    const DEFAULTS = { theme: 'light', size: 18, width: 720, font: 'sans' };

    let articles  = [];
    let currentId = null;
    let editMode  = false;
    let seoMode   = false;
    let prefs     = { ...DEFAULTS };

    // ── Storage ───────────────────────────────────────────────────────────────

    function loadPrefs() {
      try { return { ...DEFAULTS, ...JSON.parse(localStorage.getItem(PREFS_KEY) || '{}') }; }
      catch { return { ...DEFAULTS }; }
    }

    function savePrefs() { localStorage.setItem(PREFS_KEY, JSON.stringify(prefs)); }

    function loadArticles() {
      try {
        const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
        return (stored && stored.length) ? stored : JSON.parse(JSON.stringify(SEED));
      } catch { return JSON.parse(JSON.stringify(SEED)); }
    }

    function saveArticles() { localStorage.setItem(STORAGE_KEY, JSON.stringify(articles)); }

    // ── Prefs ────────────────────────────────────────────────────────────────

    function applyPrefs() {
      const main  = document.getElementById('artMain');
      const strip = document.getElementById('artEditStrip');
      const theme = THEMES[prefs.theme] || THEMES.light;

      Object.entries(theme).forEach(([k, v]) => main.style.setProperty(k, v));
      if (strip) { strip.style.background = theme['--art-bg']; strip.style.borderBottomColor = theme['--art-border']; }

      main.style.setProperty('--art-size',  prefs.size + 'px');
      main.style.setProperty('--art-width', prefs.width + 'px');
      main.style.setProperty('--art-font',  FONTS[prefs.font] || FONTS.sans);

      document.querySelectorAll('.art-theme-btn').forEach(b => b.classList.toggle('art-active', b.dataset.theme === prefs.theme));
      document.querySelectorAll('.art-width-btn').forEach(b => b.classList.toggle('art-active', String(b.dataset.width) === String(prefs.width)));
      document.querySelectorAll('.art-font-btn').forEach(b => b.classList.toggle('art-active', b.dataset.font === prefs.font));
      document.getElementById('artSizeSlider').value = prefs.size;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    function calcReadTime(html) {
      const words = html.replace(/<[^>]+>/g, ' ').trim().split(/\s+/).filter(Boolean).length;
      return Math.max(1, Math.round(words / 200)) + ' min read';
    }

    function fmtDate(dateStr) {
      return new Date(dateStr + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    function fmtDateShort(dateStr) {
      return new Date(dateStr + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    // ── Lead bolding ──────────────────────────────────────────────────────────

    function boldLeadWords() {
      const body = document.getElementById('artBody');
      if (!body) return;
      const firstP = body.querySelector('p');
      if (!firstP) return;
      let html = firstP.innerHTML;
      let count = 0, idx = 0;
      while (idx < html.length && count < 6) {
        if (html[idx] === '<') { while (idx < html.length && html[idx] !== '>') idx++; idx++; continue; }
        if (/\s/.test(html[idx])) { idx++; continue; }
        while (idx < html.length && !/[\s<]/.test(html[idx])) idx++;
        count++;
      }
      if (count > 0) firstP.innerHTML = `<strong class="art-lead">${html.slice(0, idx)}</strong>${html.slice(idx)}`;
    }

    // ── Cover image ───────────────────────────────────────────────────────────

    function coverPlaceholder() {
      return `<div class="art-cover-placeholder"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg><span>Cover Image</span></div>`;
    }

    function renderCover(art) {
      const el = document.getElementById('artCover');
      if (!el) return;
      if (art.coverSeed) {
        const img = new Image();
        img.alt = `Cover image for "${art.title}"`;
        img.setAttribute('itemprop', 'image');
        img.loading = 'eager';
        img.onerror = () => { el.innerHTML = coverPlaceholder(); };
        img.src = `https://picsum.photos/seed/${art.coverSeed}/1200/400`;
        el.innerHTML = '';
        el.appendChild(img);
      } else {
        el.innerHTML = coverPlaceholder();
      }
    }

    // ── Render article ────────────────────────────────────────────────────────

    function renderArticle(id) {
      const art = articles.find(a => a.id === id);
      if (!art) return;
      currentId = id;

      document.getElementById('artTitle').innerHTML = art.title;
      document.getElementById('artAuthor').innerHTML = art.author;

      const dateEl = document.getElementById('artDate');
      dateEl.textContent = fmtDate(art.date);
      dateEl.setAttribute('datetime', art.date);

      document.getElementById('artReadTime').textContent = calcReadTime(art.body);
      document.getElementById('artBody').innerHTML = art.body;
      boldLeadWords();
      annotateSeoTags();
      document.getElementById('artTags').innerHTML = (art.tags || []).map(t => `<span class="art-tag">${t}</span>`).join('');

      renderCover(art);
      renderPopular();

      document.querySelectorAll('.art-list-item').forEach(el =>
        el.classList.toggle('art-list-active', el.dataset.id === id));

      updateMetaTags(art);
      updateJsonLd(art);
      if (seoMode) refreshSeoPanel();
      window.scrollTo(0, 0);
    }

    // ── Popular Reads (right rail, absolute beside first h2) ─────────────────

    // NOTE: ranking is by date desc since there's no view-count data.
    // Swap this comparator if you wire up real popularity metrics.
    function renderPopular() {
      const panel = document.getElementById('artPopular');
      const list  = document.getElementById('artPopularList');
      if (!panel || !list) return;

      const others = articles
        .filter(a => a.id !== currentId)
        .sort((a, b) => (b.date || '').localeCompare(a.date || ''))
        .slice(0, 3);

      if (others.length === 0) { panel.classList.add('art-popular-hidden'); return; }

      list.innerHTML = others.map(a => {
        const thumb = a.coverSeed
          ? `<img class="art-popular-thumb" src="https://picsum.photos/seed/${a.coverSeed}/400/175" alt="" loading="lazy" onerror="this.outerHTML='&lt;div class=\\'art-popular-thumb-ph\\'&gt;&lt;/div&gt;'">`
          : `<div class="art-popular-thumb-ph"></div>`;
        const tags = (a.tags || []).slice(0, 2)
          .map(t => `<span class="art-popular-tag">${t}</span>`).join('');
        const excerpt = (a.body || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 110) + '…';
        const readTime = calcReadTime(a.body || '');
        return `
          <button class="art-popular-item" data-id="${a.id}" role="listitem">
            <div class="art-popular-thumb-wrap">${thumb}</div>
            ${tags ? `<div class="art-popular-tags">${tags}</div>` : ''}
            <span class="art-popular-item-title">${a.title}</span>
            <span class="art-popular-excerpt">${excerpt}</span>
            <span class="art-popular-foot">
              <span>${fmtDateShort(a.date)}</span>
              <span class="art-popular-foot-dot"></span>
              <span>${readTime}</span>
            </span>
          </button>`;
      }).join('');

      list.querySelectorAll('.art-popular-item').forEach(btn =>
        btn.addEventListener('click', () => {
          if (editMode) saveCurrentArticle();
          renderArticle(btn.dataset.id);
        }));

      panel.classList.remove('art-popular-hidden');
      // Wait a frame so the body's freshly-rendered first h2 has a measurable position
      requestAnimationFrame(positionPopular);
    }

    // Anchor the panel beside the first h2, in document flow (scrolls with article).
    // Computes top relative to #artContentWrapper, and left so the panel sits just
    // outside the article column with a small gap.
    function positionPopular() {
      const panel = document.getElementById('artPopular');
      if (!panel) return;
      const wrapper = document.getElementById('artContentWrapper');
      const firstH2 = document.querySelector('#artBody h2');
      if (!wrapper) return;

      const wrapperRect = wrapper.getBoundingClientRect();
      const panelW = panel.offsetWidth || 340;
      const gap = 32;

      // Hide if the panel would overflow the viewport
      if (wrapperRect.right + gap + panelW > window.innerWidth - 8) {
        panel.classList.add('art-popular-hidden');
        return;
      }

      panel.classList.remove('art-popular-hidden');

      const top = firstH2
        ? firstH2.getBoundingClientRect().top - wrapperRect.top + wrapper.scrollTop
        : 200;
      const left = wrapperRect.width + gap;

      wrapper.style.setProperty('--art-popular-top',  top  + 'px');
      wrapper.style.setProperty('--art-popular-left', left + 'px');
    }

    function updateJsonLd(art) {
      let el = document.getElementById('artArticleJsonLd');
      if (!el) { el = document.createElement('script'); el.type = 'application/ld+json'; el.id = 'artArticleJsonLd'; document.head.appendChild(el); }
      const desc = document.getElementById('artBody').textContent.slice(0, 160).trim() + '…';
      const imageUrl = art.coverSeed
        ? `https://picsum.photos/seed/${art.coverSeed}/1200/400`
        : 'https://rafaelasolis.work/headshot.jpg';
      el.textContent = JSON.stringify({
        '@context': 'https://schema.org', '@type': 'Article',
        'headline': art.title,
        'description': desc,
        'image': { '@type': 'ImageObject', 'url': imageUrl, 'width': 1200, 'height': 400 },
        'author': { '@type': 'Person', 'name': art.author, 'url': 'https://rafaelasolis.work/' },
        'publisher': { '@type': 'Person', 'name': 'Rafaela Solis', 'url': 'https://rafaelasolis.work/' },
        'datePublished': art.date,
        'dateModified': art.date,
        'url': 'https://rafaelasolis.work/article/',
        'mainEntityOfPage': { '@type': 'WebPage', '@id': 'https://rafaelasolis.work/article/' }
      });
    }

    // ── Meta tag updates ──────────────────────────────────────────────────────

    function updateMetaTags(art) {
      const desc = art.body.replace(/<[^>]+>/g, ' ').trim().slice(0, 155) + '…';
      const keywords = (art.tags || []).join(', ');
      const imageUrl = art.coverSeed
        ? `https://picsum.photos/seed/${art.coverSeed}/1200/400`
        : 'https://rafaelasolis.work/headshot.jpg';
      const setMeta = (sel, val) => { const el = document.querySelector(sel); if (el) el.setAttribute('content', val); };
      const ensureMeta = (prop, propType, val) => {
        let el = document.querySelector(`meta[${propType}="${prop}"]`);
        if (!el) { el = document.createElement('meta'); el.setAttribute(propType, prop); document.head.appendChild(el); }
        el.setAttribute('content', val);
      };
      document.title = art.title + ' — Studio Journal';
      setMeta('meta[name="description"]', desc);
      setMeta('meta[name="keywords"]', keywords);
      setMeta('meta[name="author"]', art.author);
      setMeta('meta[property="og:title"]', art.title);
      setMeta('meta[property="og:description"]', desc);
      setMeta('meta[property="og:image"]', imageUrl);
      setMeta('meta[name="twitter:title"]', art.title);
      setMeta('meta[name="twitter:description"]', desc);
      setMeta('meta[name="twitter:image"]', imageUrl);
      ensureMeta('article:published_time', 'property', art.date);
      ensureMeta('article:modified_time', 'property', art.date);
      ensureMeta('article:tag', 'property', (art.tags || []).join(', '));
    }

    // ── SEO inspector ─────────────────────────────────────────────────────────

    function annotateSeoTags() {
      const body = document.getElementById('artBody');
      if (!body) return;
      body.querySelectorAll('h2').forEach(el => { el.dataset.seo = 'h2 — Section heading; keyword targeting and semantic content structure'; });
      body.querySelectorAll('h3').forEach(el => { el.dataset.seo = 'h3 — Subsection heading; supports nested topic hierarchy'; });
      body.querySelectorAll('figure').forEach(el => { el.dataset.seo = 'figure — Semantic figure element; helps Google understand visual context'; });
      body.querySelectorAll('figcaption').forEach(el => { el.dataset.seo = 'figcaption — Image caption; supplements alt text and aids image indexing'; });
      body.querySelectorAll('img').forEach(img => {
        img.dataset.seo = img.alt
          ? `img — alt="${img.alt}" ✓ descriptive alt text present`
          : 'img — MISSING alt text ✗ (accessibility and SEO issue)';
      });
      // Ensure inline article links are crawlable by Googlebot
      body.querySelectorAll('a[data-art-id]').forEach(a => {
        if (!a.hasAttribute('href')) a.setAttribute('href', '/article/');
        a.dataset.seo = `a — Internal link → /article/ (navigates to article: ${a.dataset.artId})`;
      });
      body.querySelectorAll('a[href]:not([data-art-id])').forEach(a => {
        try {
          const isExternal = new URL(a.href, location.href).hostname !== location.hostname;
          if (isExternal) a.setAttribute('rel', 'noopener noreferrer');
          a.dataset.seo = isExternal
            ? `a — External link (rel="noopener noreferrer") → ${a.getAttribute('href')}`
            : `a — Internal link → ${a.getAttribute('href')}`;
        } catch {}
      });
    }

    function refreshSeoPanel() {
      const art = articles.find(a => a.id === currentId);
      if (!art) return;
      const body = document.getElementById('artBody');
      const text = body ? body.textContent : '';
      const words = text.trim().split(/\s+/).filter(Boolean).length;
      const h2s = body ? body.querySelectorAll('h2').length : 0;
      const h3s = body ? body.querySelectorAll('h3').length : 0;
      const allImgs = body ? body.querySelectorAll('img') : [];
      const altOk = body ? body.querySelectorAll('img[alt]').length : 0;
      const altPct = allImgs.length ? Math.round((altOk / allImgs.length) * 100) : 100;
      const desc = text.trim().slice(0, 155) + '…';
      const keywords = (art.tags || []).join(', ');
      const row = (lbl, val, ok) =>
        `<div class="seo-panel-row"><span class="seo-panel-label">${lbl}</span><span class="seo-panel-value${ok === true ? ' seo-good' : ok === false ? ' seo-warn' : ''}">${val}</span></div>`;
      document.getElementById('artSeoPanelContent').innerHTML = [
        row('Schema type', 'Article (JSON-LD + microdata)', true),
        row('OG type', 'article', true),
        row('Twitter card', 'summary_large_image', true),
        row('Breadcrumb', 'BreadcrumbList JSON-LD ✓', true),
        row('Robots', 'index, follow', true),
        row('Canonical', '/article/', true),
        row('Title', art.title, art.title.length > 0 && art.title.length <= 60),
        row('Title length', art.title.length + ' chars (≤60 ideal)', art.title.length <= 60),
        row('Meta description', desc.slice(0, 90) + '…', true),
        row('Keywords', keywords || '(none)', !!keywords),
        row('Author', art.author, !!art.author),
        row('Date published', art.date, !!art.date),
        row('h2 headings', h2s + ' found', h2s > 0),
        row('h3 headings', h3s + ' found', true),
        row('Image alt coverage', altPct + '%', altPct === 100, altPct < 100 ? false : true),
        row('Word count', words + ' words', words >= 300),
        row('Internal links', body ? body.querySelectorAll('a[data-art-id]').length + ' inline article links ✓' : '0', body && body.querySelectorAll('a[data-art-id]').length > 0),
        row('rel=noopener', 'Auto-applied to external links ✓', true),
      ].join('');
    }

    function toggleSeoMode() {
      seoMode = !seoMode;
      document.body.classList.toggle('seo-active', seoMode);
      document.getElementById('artSeoToggle').classList.toggle('art-active', seoMode);
      const panel = document.getElementById('artSeoPanel');
      panel.hidden = !seoMode;
      if (seoMode) refreshSeoPanel();
    }

    // ── Sidebar ───────────────────────────────────────────────────────────────

    function renderSidebar() {
      const list = document.getElementById('artList');
      list.innerHTML = articles.map(a => `
        <button class="art-list-item${a.id === currentId ? ' art-list-active' : ''}" data-id="${a.id}" role="listitem">
          <span class="art-list-title">${a.title}</span>
          <span class="art-list-date">${fmtDateShort(a.date)}</span>
        </button>`).join('');

      list.querySelectorAll('.art-list-item').forEach(btn =>
        btn.addEventListener('click', () => {
          if (editMode) saveCurrentArticle();
          renderArticle(btn.dataset.id);
          if (window.innerWidth <= 768) document.getElementById('artSidebar').classList.remove('art-sidebar-open');
        }));

      // Remove items that overflow the available sidebar height
      requestAnimationFrame(() => {
        const available = list.offsetHeight;
        let used = 0;
        list.querySelectorAll('.art-list-item').forEach(item => {
          used += item.offsetHeight;
          if (used > available) item.remove();
        });
      });
    }

    // ── Edit mode ─────────────────────────────────────────────────────────────

    function enterEditMode() {
      editMode = true;
      ['artTitle', 'artAuthor', 'artBody'].forEach(id => { document.getElementById(id).contentEditable = 'true'; });
      document.getElementById('artEditStrip').hidden = false;
      document.getElementById('artEditToggle').textContent = 'View';
      document.getElementById('artEditToggle').classList.add('art-active');
      document.getElementById('artArticle').classList.add('art-editing');
      updateWordCount();
    }

    function exitEditMode() {
      editMode = false;
      ['artTitle', 'artAuthor', 'artBody'].forEach(id => { document.getElementById(id).contentEditable = 'false'; });
      document.getElementById('artEditStrip').hidden = true;
      document.getElementById('artEditToggle').textContent = 'Edit';
      document.getElementById('artEditToggle').classList.remove('art-active');
      document.getElementById('artArticle').classList.remove('art-editing');
    }

    function saveCurrentArticle() {
      const art = articles.find(a => a.id === currentId);
      if (!art) return;
      art.title  = document.getElementById('artTitle').textContent.trim()  || art.title;
      art.author = document.getElementById('artAuthor').textContent.trim() || art.author;
      art.body   = document.getElementById('artBody').innerHTML;
      saveArticles();
      renderSidebar();
      document.getElementById('artReadTime').textContent = calcReadTime(art.body);
    }

    function updateWordCount() {
      const wc = document.getElementById('artWordCount');
      if (wc) wc.textContent = document.getElementById('artBody').innerHTML.replace(/<[^>]+>/g, ' ').trim().split(/\s+/).filter(Boolean).length + ' words';
    }

    function newArticle() {
      const id  = 'art-' + Date.now();
      articles.unshift({ id, tags: [], coverSeed: '', title: 'Untitled Article', author: 'Rafaela Solis', date: new Date().toISOString().slice(0, 10), body: '<p>Start writing here. Use <strong>Ctrl+B</strong> for bold and <em>Ctrl+I</em> for italic.</p>' });
      saveArticles(); renderSidebar(); renderArticle(id); enterEditMode();
    }

    function deleteArticle(id) {
      if (articles.length <= 1) { alert('You need at least one article.'); return; }
      articles = articles.filter(a => a.id !== id);
      saveArticles(); renderSidebar(); renderArticle(articles[0].id);
      if (editMode) exitEditMode();
    }

    function toggleSidebar() {
      if (window.innerWidth <= 768) document.getElementById('artSidebar').classList.toggle('art-sidebar-open');
      else document.getElementById('artShell').classList.toggle('sidebar-hidden');
    }

    // ── Init ──────────────────────────────────────────────────────────────────

    document.addEventListener('DOMContentLoaded', () => {
      articles = loadArticles();
      prefs    = loadPrefs();
      renderSidebar();
      renderArticle(articles[0].id);
      applyPrefs();

      document.querySelectorAll('.art-theme-btn').forEach(btn =>
        btn.addEventListener('click', () => { prefs.theme = btn.dataset.theme; applyPrefs(); savePrefs(); }));

      const slider = document.getElementById('artSizeSlider');
      slider.addEventListener('input', () => { prefs.size = +slider.value; applyPrefs(); savePrefs(); });
      document.getElementById('artSizeDown').addEventListener('click', () => { prefs.size = Math.max(14, prefs.size - 1); applyPrefs(); savePrefs(); });
      document.getElementById('artSizeUp').addEventListener('click',   () => { prefs.size = Math.min(24, prefs.size + 1); applyPrefs(); savePrefs(); });

      document.querySelectorAll('.art-width-btn').forEach(btn =>
        btn.addEventListener('click', () => { prefs.width = +btn.dataset.width; applyPrefs(); savePrefs(); requestAnimationFrame(positionPopular); }));

      document.querySelectorAll('.art-font-btn').forEach(btn =>
        btn.addEventListener('click', () => { prefs.font = btn.dataset.font; applyPrefs(); savePrefs(); }));

      document.getElementById('artEditToggle').addEventListener('click', () => {
        if (editMode) { saveCurrentArticle(); exitEditMode(); } else { enterEditMode(); }
      });
      document.getElementById('artSaveBtn').addEventListener('click',   () => { saveCurrentArticle(); exitEditMode(); });
      document.getElementById('artDeleteBtn').addEventListener('click', () => {
        const art = articles.find(a => a.id === currentId);
        if (art && confirm(`Delete "${art.title}"?`)) deleteArticle(currentId);
      });
      document.getElementById('artNewBtn').addEventListener('click', newArticle);
      document.getElementById('artSidebarToggle').addEventListener('click', toggleSidebar);
      document.getElementById('artBody').addEventListener('input', updateWordCount);
      document.getElementById('artBody').addEventListener('click', e => {
        const link = e.target.closest('[data-art-id]');
        if (!link) return;
        e.preventDefault();
        if (editMode) saveCurrentArticle();
        renderArticle(link.dataset.artId);
      });
      document.getElementById('artSeoToggle').addEventListener('click', toggleSeoMode);
      document.getElementById('artSeoPanelClose').addEventListener('click', toggleSeoMode);

      window.addEventListener('resize', positionPopular);

      const seoTip = document.getElementById('artSeoTooltip');
      document.addEventListener('mouseover', e => {
        if (!seoMode) return;
        const target = e.target.closest('[data-seo]');
        if (!target) { seoTip.hidden = true; return; }
        seoTip.hidden = false;
        seoTip.textContent = target.dataset.seo;
        requestAnimationFrame(() => {
          const r = target.getBoundingClientRect();
          const tipH = seoTip.offsetHeight;
          const tipW = seoTip.offsetWidth;
          const top = r.top - tipH - 8 > 0 ? r.top - tipH - 8 : r.bottom + 8;
          seoTip.style.top = Math.max(4, top) + 'px';
          seoTip.style.left = Math.max(8, Math.min(r.left, window.innerWidth - tipW - 8)) + 'px';
        });
      });
      document.addEventListener('mouseover', e => {
        if (!seoMode || e.target.closest('[data-seo]')) return;
        seoTip.hidden = true;
      });
    });
  </script>
</ArticleLayout>