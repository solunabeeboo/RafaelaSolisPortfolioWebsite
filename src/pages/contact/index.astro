---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Contact - Rafaela Solis">
    <style>
        /* ===== PAGE ===== */
        .contact-page {
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            padding: calc(var(--nav-h) + 1.75rem) 1rem 0.5rem;
            overflow: hidden;
        }

        .page-header { text-align: center; flex-shrink: 0; opacity: 0; animation: header-in 0.4s ease-out 0s forwards; }

        .page-eyebrow {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--accent-sage);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            margin-bottom: 0.25rem;
        }

        .page-title {
            font-size: clamp(2.4rem, 3.6vw, 3.2rem);
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.03em;
            line-height: 1;
        }

        /* ===== WHEEL ===== */
        .wheel-container {
            position: relative;
            flex: 1;
            width: min(1300px, 98vw);
            min-height: 0;
        }

        .spokes-svg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .spoke-line {
            stroke: var(--border);
            stroke-width: 0.35;
            stroke-dasharray: 1500;
            stroke-dashoffset: 1500;
            transition: stroke 0.25s ease, stroke-width 0.25s ease;
        }

        .spoke-line.spoke-active {
            stroke: var(--accent);
            stroke-width: 1.5;
        }

        /* ===== HUB ===== */
        .hub {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: clamp(80px, 12vmin, 120px);
            height: clamp(80px, 12vmin, 120px);
            border-radius: 50%;
            background: var(--accent);
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 2;
            text-align: center;
            padding: 0.25rem;
            opacity: 0;
            animation: hub-appear 0.4s ease-out 0.15s forwards, hub-pulse 3s ease-in-out 1.5s infinite;
        }

        .hub-name {
            font-size: clamp(0.7rem, 2vmin, 1rem);
            font-weight: 700;
            color: var(--bg);
            text-transform: uppercase;
            letter-spacing: 0.18em;
            line-height: 1;
        }

        /* ===== KEYFRAMES ===== */
        @keyframes header-in {
            from { opacity: 0; transform: translateY(-10px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @keyframes hub-appear {
            from { opacity: 0; transform: translate(-50%, -50%) scale(0.6); }
            to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        }

        @keyframes hub-pulse {
            0%, 100% { box-shadow: 4px 4px 0 var(--border); }
            50%       { box-shadow: 4px 4px 0 var(--border), 0 0 0 8px rgba(45,80,22,0.12); }
        }

        @keyframes spoke-draw {
            from { stroke-dashoffset: 1500; }
            to   { stroke-dashoffset: 0; }
        }

        @keyframes node-appear {
            from { opacity: 0; transform: translate(-50%, -50%) scale(0.75); }
            to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        }

        /* ===== NODES ===== */
        .node {
            position: absolute;
            transform: translate(-50%, -50%);
            width: 22%;
            text-decoration: none;
            z-index: 3;
            opacity: 0;
        }

        .node-card {
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 3px 3px 0 var(--border);
            padding: 1.1rem 1.3rem 1.2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.4rem;
            text-align: center;
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
        }

        .node:hover .node-card {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0 var(--accent);
            border-color: var(--accent);
        }

        .node-icon {
            font-size: clamp(2rem, 5vmin, 2.8rem);
            line-height: 1;
        }

        .node-label {
            font-size: clamp(1rem, 2.5vmin, 1.4rem);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--accent);
            line-height: 1;
        }

        .node-handle {
            font-size: clamp(0.8rem, 2vmin, 1.1rem);
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
            line-height: 1;
        }

        /* Node positions — evenly spaced, clockwise from top, radius 39% */
        .node-email     { top: 11%;   left: 50%;   animation: node-appear 0.35s ease-out 0.35s forwards; }
        .node-linkedin  { top: 25.7%; left: 80.5%; animation: node-appear 0.35s ease-out 0.45s forwards; }
        .node-bluesky   { top: 58.7%; left: 88%;   animation: node-appear 0.35s ease-out 0.55s forwards; }
        .node-itch      { top: 85.1%; left: 66.9%; animation: node-appear 0.35s ease-out 0.65s forwards; }
        .node-instagram { top: 85.1%; left: 33.1%; animation: node-appear 0.35s ease-out 0.75s forwards; }
        .node-discord   { top: 58.7%; left: 12%;   animation: node-appear 0.35s ease-out 0.85s forwards; }
        .node-github    { top: 25.7%; left: 19.5%; animation: node-appear 0.35s ease-out 0.95s forwards; }

        /* ===== MOBILE ===== */
        @media (max-width: 600px) {
            .wheel-container { display: none; }
            .mobile-list { display: flex; flex-direction: column; gap: 0.65rem; width: 100%; max-width: 400px; padding: 0 1.5rem; }
        }
        @media (min-width: 601px) {
            .mobile-list { display: none; }
        }

        .mobile-link {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.85rem 1.25rem;
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 3px 3px 0 var(--border);
            text-decoration: none;
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.88rem;
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
        }

        .mobile-link:hover {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0 var(--accent);
            border-color: var(--accent);
        }

        .mobile-link-icon { font-size: 1.3rem; line-height: 1; }
        .mobile-link-label { font-weight: 700; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.1em; color: var(--accent); }
        .mobile-link-handle { font-size: 0.78rem; color: var(--text-secondary); }
        .mobile-link-info { display: flex; flex-direction: column; gap: 0.1rem; }
    </style>

    <div class="contact-page">

        <header class="page-header">
            <p class="page-eyebrow">Let's Talk</p>
            <h1 class="page-title">Get In Touch</h1>
        </header>

        <!-- ── WHEEL (desktop) ── -->
        <div class="wheel-container" aria-label="Contact links">

            <svg class="spokes-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
                <line id="spoke-email"     class="spoke-line" x1="50" y1="50" x2="50"   y2="11"  />
                <line id="spoke-linkedin"  class="spoke-line" x1="50" y1="50" x2="80.5" y2="25.7"/>
                <line id="spoke-bluesky"   class="spoke-line" x1="50" y1="50" x2="88"   y2="58.7"/>
                <line id="spoke-itch"      class="spoke-line" x1="50" y1="50" x2="66.9" y2="85.1"/>
                <line id="spoke-instagram" class="spoke-line" x1="50" y1="50" x2="33.1" y2="85.1"/>
                <line id="spoke-discord"   class="spoke-line" x1="50" y1="50" x2="12"   y2="58.7"/>
                <line id="spoke-github"    class="spoke-line" x1="50" y1="50" x2="19.5" y2="25.7"/>
            </svg>

            <div class="hub">
                <span class="hub-name">CONTACT</span>
            </div>

            <a href="mailto:rafa@miguelsolis.com" class="node node-email" data-spoke="spoke-email">
                <div class="node-card">
                    <span class="node-icon">✉️</span>
                    <span class="node-label">Email</span>
                    <span class="node-handle">rafa@miguelsolis.com</span>
                </div>
            </a>

            <a href="https://linkedin.com/in/rafaela-solis-3463b2245/" class="node node-linkedin" data-spoke="spoke-linkedin" target="_blank" rel="noopener noreferrer">
                <div class="node-card">
                    <span class="node-icon">💼</span>
                    <span class="node-label">LinkedIn</span>
                    <span class="node-handle">/rafaela-solis</span>
                </div>
            </a>

            <a href="https://github.com/solunabeeboo" class="node node-github" data-spoke="spoke-github" target="_blank" rel="noopener noreferrer">
                <div class="node-card">
                    <span class="node-icon">💻</span>
                    <span class="node-label">GitHub</span>
                    <span class="node-handle">solunabeeboo</span>
                </div>
            </a>

            <a href="https://itch.io/profile/solunabeeboo" class="node node-itch" data-spoke="spoke-itch" target="_blank" rel="noopener noreferrer">
                <div class="node-card">
                    <span class="node-icon">🎮</span>
                    <span class="node-label">Itch.io</span>
                    <span class="node-handle">solunabeeboo</span>
                </div>
            </a>

            <a href="https://www.instagram.com/solunabeeboo/" class="node node-instagram" data-spoke="spoke-instagram" target="_blank" rel="noopener noreferrer">
                <div class="node-card">
                    <span class="node-icon">📷</span>
                    <span class="node-label">Instagram</span>
                    <span class="node-handle">@solunabeeboo</span>
                </div>
            </a>

            <a href="https://discord.com/users/633013974279127043" class="node node-discord" data-spoke="spoke-discord" target="_blank" rel="noopener noreferrer">
                <div class="node-card">
                    <span class="node-icon">💬</span>
                    <span class="node-label">Discord</span>
                    <span class="node-handle">solunabeeboo</span>
                </div>
            </a>

            <a href="https://bsky.app/profile/solunabeeboo.bsky.social" class="node node-bluesky" data-spoke="spoke-bluesky" target="_blank" rel="noopener noreferrer">
                <div class="node-card">
                    <span class="node-icon">🦋</span>
                    <span class="node-label">Bluesky</span>
                    <span class="node-handle">@solunabeeboo</span>
                </div>
            </a>

        </div>

        <!-- ── MOBILE fallback ── -->
        <nav class="mobile-list" aria-label="Contact links">
            <a href="mailto:rafa@miguelsolis.com" class="mobile-link">
                <span class="mobile-link-icon">✉️</span>
                <div class="mobile-link-info">
                    <span class="mobile-link-label">Email</span>
                    <span class="mobile-link-handle">rafa@miguelsolis.com</span>
                </div>
            </a>
            <a href="https://linkedin.com/in/rafaela-solis-3463b2245/" class="mobile-link" target="_blank" rel="noopener noreferrer">
                <span class="mobile-link-icon">💼</span>
                <div class="mobile-link-info">
                    <span class="mobile-link-label">LinkedIn</span>
                    <span class="mobile-link-handle">/rafaela-solis-3463b2245</span>
                </div>
            </a>
            <a href="https://github.com/solunabeeboo" class="mobile-link" target="_blank" rel="noopener noreferrer">
                <span class="mobile-link-icon">💻</span>
                <div class="mobile-link-info">
                    <span class="mobile-link-label">GitHub</span>
                    <span class="mobile-link-handle">solunabeeboo</span>
                </div>
            </a>
            <a href="https://itch.io/profile/solunabeeboo" class="mobile-link" target="_blank" rel="noopener noreferrer">
                <span class="mobile-link-icon">🎮</span>
                <div class="mobile-link-info">
                    <span class="mobile-link-label">Itch.io</span>
                    <span class="mobile-link-handle">solunabeeboo</span>
                </div>
            </a>
            <a href="https://www.instagram.com/solunabeeboo/" class="mobile-link" target="_blank" rel="noopener noreferrer">
                <span class="mobile-link-icon">📷</span>
                <div class="mobile-link-info">
                    <span class="mobile-link-label">Instagram</span>
                    <span class="mobile-link-handle">@solunabeeboo</span>
                </div>
            </a>
            <a href="https://discord.com/users/633013974279127043" class="mobile-link" target="_blank" rel="noopener noreferrer">
                <span class="mobile-link-icon">💬</span>
                <div class="mobile-link-info">
                    <span class="mobile-link-label">Discord</span>
                    <span class="mobile-link-handle">solunabeeboo</span>
                </div>
            </a>
            <a href="https://bsky.app/profile/solunabeeboo.bsky.social" class="mobile-link" target="_blank" rel="noopener noreferrer">
                <span class="mobile-link-icon">🦋</span>
                <div class="mobile-link-info">
                    <span class="mobile-link-label">Bluesky</span>
                    <span class="mobile-link-handle">@solunabeeboo.bsky.social</span>
                </div>
            </a>
        </nav>

    </div>

    <script>
        // ── Spoke draw-in on load ──
        const delays: Record<string, number> = {
            'spoke-email':     350,
            'spoke-linkedin':  450,
            'spoke-bluesky':   550,
            'spoke-itch':      650,
            'spoke-instagram': 750,
            'spoke-discord':   850,
            'spoke-github':    950,
        };

        Object.entries(delays).forEach(([id, delay]) => {
            const line = document.getElementById(id);
            if (!line) return;
            setTimeout(() => {
                line.style.animation = `spoke-draw 0.5s ease-out forwards`;
            }, delay);
        });

        // ── Spoke green highlight on node hover ──
        document.querySelectorAll<HTMLAnchorElement>('.node[data-spoke]').forEach(node => {
            const spokeId = node.dataset.spoke!;
            const line = document.getElementById(spokeId);
            if (!line) return;
            node.addEventListener('mouseenter', () => line.classList.add('spoke-active'));
            node.addEventListener('mouseleave', () => line.classList.remove('spoke-active'));
        });
    </script>
</Layout>
