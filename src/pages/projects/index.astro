---
import Layout from '../../layouts/Layout.astro';
import projectsData from '../../data/projects.json';

const projects = projectsData.projects;
---
<Layout title="Projects - Rafaela Solis">
    <style is:global>
        :root { --compact-h: 36px; }

        .sections-stage {
            position: sticky;
            top: var(--nav-h);
            overflow: hidden;
        }

        /* ===== STRIP ===== */
        .section-strip {
            width: 100%;
            overflow: hidden;
            border-bottom: 2px solid var(--border);
            position: relative;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }

        /* ===== THUMBNAIL — absolute, covers full left side including header ===== */
        .strip-thumbnail {
            position: absolute;
            top: 0; bottom: 0; left: 0;
            width: 58.33%; /* 7fr out of 12fr */
            z-index: 1;
            opacity: 0;
            transition: opacity 0.4s;
            overflow: hidden;
            background: #111;
        }

        .section-strip.strip-active .strip-thumbnail { opacity: 1; }

        .strip-thumb-slide {
            position: absolute;
            inset: 0;
            display: none;
        }

        .strip-thumb-slide.active { display: block; }

        .strip-thumb-slide img {
            width: 100%; height: 100%;
            object-fit: cover; object-position: center; display: block;
        }

        .strip-thumb-slide video {
            width: 100%; height: 100%;
            object-fit: contain; background: #000; display: block;
        }

        .strip-thumbnail-overlay {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            padding: 3rem 2rem 1.75rem;
            background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.35) 55%, transparent 100%);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            z-index: 2;
        }

        /* ===== CAROUSEL CONTROLS ===== */
        .gallery-btn {
            position: absolute; top: 50%; transform: translateY(-50%);
            width: 64px; height: 64px;
            background: rgba(0,0,0,0.65); border: 1px solid rgba(255,255,255,0.25);
            color: #fff; font-size: 1.8rem; line-height: 1;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 10; transition: background 0.15s; user-select: none;
        }

        .gallery-btn:hover { background: rgba(0,0,0,0.85); }
        .gallery-btn-prev { left: 0.4rem; }
        .gallery-btn-next { right: 0.4rem; }

        .gallery-counter {
            position: absolute; bottom: 0.55rem; right: 0.7rem;
            font-size: 0.62rem; font-weight: 600; color: rgba(255,255,255,0.45);
            pointer-events: none; font-variant-numeric: tabular-nums; letter-spacing: 0.04em;
            z-index: 10;
        }

        .strip-thumbnail-title {
            font-size: clamp(1.8rem, 2.8vw, 3rem);
            font-weight: 700;
            color: rgba(255,255,255,0.96);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            line-height: 1;
            text-shadow: 0 2px 16px rgba(0,0,0,0.5);
        }

        /* ===== STRIP HEADER (36px) ===== */
        .strip-header {
            height: var(--compact-h);
            min-height: var(--compact-h);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0 0.85rem 0 54px; /* 54px = icon width + gap */
            position: relative;
            z-index: 2;
            background: var(--bg);
            border-bottom: 1px solid rgba(26, 26, 26, 0.1);
            transition: background 0.3s, backdrop-filter 0.3s;
        }

        .strip-title-group {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            overflow: hidden;
            min-width: 0;
        }

        .section-strip.strip-active .strip-header {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(26, 26, 26, 0.15);
        }

        .strip-title {
            font-size: 2rem; font-weight: 700; color: var(--text-primary);
            text-transform: uppercase; letter-spacing: 0.04em;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
            line-height: 1;
        }

        .strip-hint {
            font-size: 0.6rem; color: var(--text-muted);
            flex-shrink: 0; margin-left: auto; line-height: 1;
        }

        .section-strip.strip-active .strip-hint { opacity: 0; }

        /* ===== OVERVIEW ROW ===== */
        .strip-overview-row {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0 0.85rem 0 54px;
            position: relative;
            z-index: 2;
            background: var(--bg);
            overflow: hidden;
        }

        .section-strip.strip-active .strip-overview-row { display: none; }

        /* ===== ICON — full-height circle on left ===== */
        .strip-icon {
            position: absolute;
            left: 3px; top: 3px; bottom: 3px;
            width: auto;
            aspect-ratio: 1;
            z-index: 3;
            border-radius: 50%;
            background-size: cover;
            background-position: center;
            background-color: var(--accent-sage);
            transition: opacity 0.3s;
        }

        /* Hide icon when project is expanded (thumbnail covers left side) */
        .section-strip.strip-active .strip-icon {
            opacity: 0;
            pointer-events: none;
        }

        .strip-sep { width: 1px; height: 12px; background: rgba(26,26,26,0.2); flex-shrink: 0; }

        .strip-short-desc {
            position: absolute;
            left: 18%; right: 5%; top: 0; bottom: 0;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
            font-size: 0.92rem; color: var(--text-secondary);
            pointer-events: none;
        }
        .strip-short-desc > span {
            display: inline-block; max-width: 100%;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }

        /* ===== EXPANDED CONTENT — info panel in right 41.67% ===== */
        .strip-content {
            flex: 0 0 0;
            position: relative; z-index: 2;
            opacity: 0; transition: opacity 0.35s;
            overflow: hidden; display: flex;
            margin-left: 58.33%;
        }

        .section-strip.strip-active .strip-content { opacity: 1; flex: 1; }

        /* ===== INFO PANEL ===== */
        .strip-info {
            padding: 1.5rem 1.75rem;
            background: rgba(245, 242, 235, 0.97);
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            display: flex; flex-direction: column; gap: 0.8rem;
            overflow-y: auto; border-left: 2px solid var(--border);
            width: 100%;
        }

        .strip-label {
            font-size: 0.64rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.14em; color: var(--accent);
            padding-left: 0.5rem; border-left: 3px solid var(--accent);
        }

        .strip-description { font-size: 0.87rem; color: var(--text-secondary); line-height: 1.75; white-space: pre-line; }

        .strip-meta-row { display: flex; gap: 1.5rem; flex-wrap: wrap; }
        .strip-meta-item { display: flex; flex-direction: column; gap: 0.1rem; }
        .strip-meta-label { font-size: 0.59rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.13em; color: var(--accent); }
        .strip-meta-value { font-size: 0.8rem; color: var(--text-secondary); font-weight: 500; }

        .strip-tags-full { display: flex; flex-wrap: wrap; gap: 0.35rem; }

        .tag {
            font-size: 0.72rem; font-weight: 600;
            border: 2px solid var(--border); padding: 0.2rem 0.55rem;
            color: var(--text-primary);
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }

        .tag:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }

        .strip-link {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: var(--accent); color: var(--bg); text-decoration: none;
            padding: 0.65rem 1.4rem; border: 2px solid var(--border);
            box-shadow: 3px 3px 0 var(--border); font-weight: 700; font-size: 0.78rem;
            text-transform: uppercase; letter-spacing: 0.05em;
            transition: transform 0.15s, box-shadow 0.15s;
            align-self: flex-start; margin-top: auto; flex-shrink: 0;
        }

        .strip-link:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--border); }

        /* ===== LOADING ===== */
        .loading-state {
            display: flex; align-items: center; justify-content: center;
            height: 100%; font-size: 1rem; color: var(--text-muted);
        }

        /* ===== MOBILE ===== */
        @media (max-width: 768px) {
            #scrollDriver { height: auto !important; }
            .sections-stage { position: static; height: auto !important; overflow: visible; }
            .section-strip { height: auto !important; min-height: 100svh; cursor: default; border-bottom: 3px solid var(--border); }
            .strip-icon { display: none; }
            .strip-header { background: rgba(255,255,255,0.92) !important; backdrop-filter: blur(12px); flex-wrap: wrap; height: auto !important; min-height: 36px; padding: 0.5rem 1rem; gap: 0.5rem; }
            /* Hide overview row — full content is always expanded on mobile */
            .strip-overview-row { display: none; }
            /* Thumbnail: static, full width, fixed height */
            .strip-thumbnail { position: static; width: 100%; height: 260px; opacity: 1; }
            /* Info panel: full width, no left margin */
            .strip-content { opacity: 1 !important; flex: 1 !important; margin-left: 0; min-height: calc(100svh - 300px); }
            .strip-info { border-left: none; overflow-y: visible; }
        }
    </style>

    <div id="scrollDriver">
        <div class="sections-stage" id="sectionsStage">
            <div class="loading-state">Loading projects...</div>
        </div>
    </div>

    <script define:vars={{ projects }}>
        const NAV_H     = 60;
        const COMPACT   = 36;
        const BUF_VH    = 0.25;
        const SEC_VH    = 0.80;
        const HERO_HOLD = 0.25;
        const HERO_FRAC = 0.80;

        let isMobile = false;

        function checkMobile() {
            isMobile = window.matchMedia('(max-width: 768px)').matches;
        }

        function isVideo(src) {
            return /\.(mp4|webm|ogg)$/i.test(src);
        }

        function buildThumbSlides(media) {
            return media.map((src, idx) => {
                const inner = isVideo(src)
                    ? `<video src="${src}" controls muted playsinline loop></video>`
                    : `<img src="${src}" alt="" loading="lazy" onerror="this.style.display='none'">`;
                return `<div class="strip-thumb-slide${idx === 0 ? ' active' : ''}">${inner}</div>`;
            }).join('');
        }

        function buildStrips(projects) {
            const stage  = document.getElementById('sectionsStage');
            const driver = document.getElementById('scrollDriver');
            const N = projects.length;
            const stageH = window.innerHeight - NAV_H;

            const slotSize = 1 + HERO_HOLD;
            stage.style.height  = stageH + 'px';
            driver.style.height = ((BUF_VH + N * slotSize * SEC_VH) * window.innerHeight) + 'px';
            stage.innerHTML = '';

            projects.forEach((project, i) => {
                const strip = document.createElement('div');
                strip.className = 'section-strip';
                strip.id = `strip-${i}`;

                const bgSrc      = project.image || (project.screenshots && project.screenshots[0]) || '';
                const bgFallback = project.gradient || 'linear-gradient(135deg, #2d5016, #6b8f47)';
                const bgStyle    = bgSrc ? `background-image: url('${bgSrc}')` : `background: ${bgFallback}`;

                const fullTags   = project.tags.map(t => `<span class="tag">${t}</span>`).join('');

                const metaItems = [
                    project.developmentTime && `<div class="strip-meta-item"><span class="strip-meta-label">Dev Time</span><span class="strip-meta-value">${project.developmentTime}</span></div>`,
                    project.teamSize        && `<div class="strip-meta-item"><span class="strip-meta-label">Team</span><span class="strip-meta-value">${project.teamSize}</span></div>`,
                    project.tools && project.tools.length && `<div class="strip-meta-item"><span class="strip-meta-label">Tools</span><span class="strip-meta-value">${project.tools.slice(0, 4).join(', ')}</span></div>`,
                ].filter(Boolean).join('');

                const desc     = project.fullDescription || project.shortDescription || '';
                const linkHref = project.playLink || '#';
                const linkText = project.linkText || 'View Project';

                const iconStyle = project.image
                    ? `background-image: url('${project.image}')`
                    : '';

                // Build media array: main image → videos → other screenshots
                const mediaArr = [];
                if (project.image) mediaArr.push(project.image);
                if (project.screenshots) {
                    const rest   = project.screenshots.filter(s => s !== project.image);
                    const videos = rest.filter(s => isVideo(s));
                    const imgs   = rest.filter(s => !isVideo(s));
                    videos.forEach(s => mediaArr.push(s));
                    imgs.forEach(s => mediaArr.push(s));
                }
                if (mediaArr.length === 0) mediaArr.push('');

                const hasMultiple = mediaArr.length > 1;
                const thumbSlides = buildThumbSlides(mediaArr.filter(Boolean));

                strip.innerHTML = `
                    <div class="strip-thumbnail">
                        ${thumbSlides}
                        <div class="strip-thumbnail-overlay">
                            <span class="strip-thumbnail-title">${project.title}</span>
                        </div>
                        ${hasMultiple ? `
                            <button class="gallery-btn gallery-btn-prev" aria-label="Previous">&#8592;</button>
                            <button class="gallery-btn gallery-btn-next" aria-label="Next">&#8594;</button>
                            <span class="gallery-counter"><span class="gallery-cur">1</span> / ${mediaArr.filter(Boolean).length}</span>
                        ` : ''}
                    </div>
                    <div class="strip-icon" style="${iconStyle}"></div>
                    <div class="strip-header">
                        <div class="strip-title-group">
                            <span class="strip-title">${project.title}</span>
                        </div>
                        <span class="strip-hint">&#8597;</span>
                    </div>
                    <div class="strip-overview-row">
                        <span class="strip-short-desc"><span>${project.shortDescription || ''}</span></span>
                    </div>
                    <div class="strip-content">
                        <div class="strip-info">
                            <span class="strip-label">About</span>
                            <div class="strip-description">${desc}</div>
                            ${metaItems ? `<div class="strip-meta-row">${metaItems}</div>` : ''}
                            <div class="strip-tags-full">${fullTags}</div>
                            <a href="${linkHref}" class="strip-link" target="_blank" rel="noopener noreferrer">${linkText} &rarr;</a>
                        </div>
                    </div>
                `;

                if (hasMultiple) {
                    const thumb  = strip.querySelector('.strip-thumbnail');
                    const slides = Array.from(thumb.querySelectorAll('.strip-thumb-slide'));
                    const curEl  = thumb.querySelector('.gallery-cur');
                    let cur = 0;

                    function goTo(idx) {
                        slides[cur].classList.remove('active');
                        cur = (idx + slides.length) % slides.length;
                        slides[cur].classList.add('active');
                        if (curEl) curEl.textContent = cur + 1;
                    }

                    thumb.querySelector('.gallery-btn-prev').addEventListener('click', e => { e.stopPropagation(); goTo(cur - 1); });
                    thumb.querySelector('.gallery-btn-next').addEventListener('click', e => { e.stopPropagation(); goTo(cur + 1); });
                }

                strip.querySelector('.strip-header').addEventListener('click', () => {
                    if (strip.classList.contains('strip-active') || isMobile) return;
                    const slotSize = 1 + HERO_HOLD;
                    window.scrollTo({ top: BUF_VH * window.innerHeight + i * slotSize * SEC_VH * window.innerHeight, behavior: 'smooth' });
                });

                stage.appendChild(strip);
            });
        }

        function initScrollEngine() {
            const stage = document.getElementById('sectionsStage');
            let ticking = false;

            function update() {
                if (isMobile) { ticking = false; return; }

                const strips = Array.from(stage.querySelectorAll('.section-strip'));
                const N = strips.length;
                if (!N) { ticking = false; return; }

                const stageH   = window.innerHeight - NAV_H;
                const heroH    = stageH * HERO_FRAC;
                const otherH   = N > 1 ? (stageH - heroH) / (N - 1) : 0;
                const bufPx    = BUF_VH * window.innerHeight;
                const secPx    = SEC_VH * window.innerHeight;
                const slotSize = 1 + HERO_HOLD;
                const scrollY  = window.scrollY;

                const heights = new Array(N).fill(otherH);
                let activeIdx = -1;

                if (scrollY <= bufPx) {
                    // Buffer phase: all strips equal on load, project 0 grows to heroH on scroll.
                    const t      = bufPx > 0 ? scrollY / bufPx : 1;
                    const equalH = stageH / N;
                    const h0     = equalH + (heroH - equalH) * t;
                    const hRest  = N > 1 ? (stageH - h0) / (N - 1) : 0;
                    heights[0]   = h0;
                    for (let i = 1; i < N; i++) heights[i] = hRest;
                    activeIdx = h0 >= heroH ? 0 : -1;
                } else {
                    const frac     = (scrollY - bufPx) / secPx;
                    const slotIdx  = Math.floor(frac / slotSize);
                    const slotFrac = frac - slotIdx * slotSize;
                    const lo       = Math.min(slotIdx, N - 1);

                    if (lo >= N - 1) {
                        heights[N - 1] = heroH;
                        for (let i = 0; i < N - 1; i++) heights[i] = otherH;
                        activeIdx = N - 1;
                    } else if (slotFrac <= HERO_HOLD) {
                        heights[lo] = heroH;
                        for (let i = 0; i < N; i++) if (i !== lo) heights[i] = otherH;
                        activeIdx = lo;
                    } else {
                        const t  = slotFrac - HERO_HOLD;
                        const hi = lo + 1;
                        heights[lo] = heroH * (1 - t) + otherH * t;
                        heights[hi] = otherH * (1 - t) + heroH * t;
                        for (let i = 0; i < N; i++) {
                            if (i !== lo && i !== hi) heights[i] = otherH;
                        }
                        activeIdx = t < 0.5 ? lo : hi;
                    }
                }

                strips.forEach((s, i) => {
                    s.style.height = Math.max(0, heights[i]) + 'px';
                    s.classList.toggle('strip-active', i === activeIdx);
                });
                ticking = false;
            }

            window.addEventListener('scroll', () => {
                if (!ticking) { requestAnimationFrame(update); ticking = true; }
            }, { passive: true });

            window.addEventListener('resize', () => {
                checkMobile();
                if (!isMobile) {
                    const stage  = document.getElementById('sectionsStage');
                    const driver = document.getElementById('scrollDriver');
                    const N = stage.querySelectorAll('.section-strip').length;
                    const slotSize = 1 + HERO_HOLD;
                    stage.style.height  = (window.innerHeight - NAV_H) + 'px';
                    driver.style.height = ((BUF_VH + N * slotSize * SEC_VH) * window.innerHeight) + 'px';
                    requestAnimationFrame(update);
                }
            });

            update();
        }

        document.addEventListener('DOMContentLoaded', () => {
            checkMobile();
            buildStrips(projects);
            initScrollEngine();
            // Snapshot icon heights after first layout so they don't grow during strip expansion
            requestAnimationFrame(() => {
                document.querySelectorAll('.strip-icon').forEach(icon => {
                    const h = icon.getBoundingClientRect().height;
                    if (h > 0) icon.style.maxHeight = h + 'px';
                });
            });
        });
    </script>
</Layout>
