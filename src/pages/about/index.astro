---
import Layout from '../../layouts/Layout.astro';
import siteData from '../../data/site.json';
const about = (siteData as any).about;
---
<Layout title="About - Rafaela Solis">
    <style>
        /* ===== LAYOUT ===== */
        .about-page {
            min-height: 100vh;
            display: flex;
            padding-top: var(--nav-h);
        }

        /* ===== LEFT PANEL ===== */
        .about-left {
            width: 38%;
            flex-shrink: 0;
            position: sticky;
            top: var(--nav-h);
            height: calc(100vh - var(--nav-h));
            background: var(--accent);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 3rem;
            border-right: 3px solid var(--border);
            text-align: center;
            gap: 0;
        }

        .headshot-circle {
            width: 240px;
            height: 240px;
            border-radius: 50%;
            border: 5px solid rgba(245, 242, 235, 0.9);
            box-shadow: 10px 10px 0 var(--border);
            object-fit: cover;
            display: block;
            margin-bottom: 2rem;
            flex-shrink: 0;
        }

        .left-name {
            font-size: clamp(1.9rem, 2.5vw, 2.6rem);
            font-weight: 700;
            color: var(--bg);
            letter-spacing: -0.02em;
            line-height: 1.05;
            margin-bottom: 0.6rem;
        }

        .left-title {
            font-size: 0.8rem;
            font-weight: 700;
            color: rgba(245, 242, 235, 0.65);
            text-transform: uppercase;
            letter-spacing: 0.22em;
            margin-bottom: 2.25rem;
        }

        .left-divider {
            width: 64px;
            height: 3px;
            background: rgba(245, 242, 235, 0.35);
            margin: 0 auto 2.25rem;
        }

        .left-stats {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            width: 100%;
            text-align: left;
        }

        .stat-item {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
            padding-left: 0.85rem;
            border-left: 2px solid rgba(245, 242, 235, 0.2);
        }

        .stat-label {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.16em;
            color: rgba(245, 242, 235, 0.45);
        }

        .stat-value {
            font-size: 0.97rem;
            font-weight: 600;
            color: rgba(245, 242, 235, 0.9);
            line-height: 1.4;
        }

        /* ===== RIGHT PANEL ===== */
        .about-right {
            flex: 1;
            padding: 4.5rem 3.5rem 5rem;
            min-width: 0;
        }

        .section-eyebrow {
            font-size: 0.68rem;
            font-weight: 700;
            color: var(--accent-sage);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            margin-bottom: 0.5rem;
        }

        h1 {
            font-size: clamp(2.2rem, 3.5vw, 3rem);
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 0.75rem;
        }

        .accent-rule {
            width: 60px;
            height: 4px;
            background: var(--accent);
            margin-bottom: 2.25rem;
        }

        .bio {
            font-size: 0.96rem;
            line-height: 1.9;
            color: var(--text-secondary);
        }

        .bio p + p { margin-top: 1.25rem; }

        .content-divider {
            width: 100%;
            height: 1px;
            background: var(--border);
            opacity: 0.15;
            margin: 3rem 0;
        }

        h2 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 1.25rem;
            padding-left: 0.85rem;
            border-left: 4px solid var(--accent);
            letter-spacing: 0.01em;
        }

        /* ===== SKILLS GRID ===== */
        .skills-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.85rem;
        }

        .skills-category {
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            padding: 1.1rem 1.35rem;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
        }

        .skills-category:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0 var(--border);
            border-color: var(--accent);
        }

        .skills-category.wide { grid-column: span 2; }

        .skills-category h3 {
            font-size: 0.64rem;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.14em;
            margin-bottom: 0.75rem;
            padding-bottom: 0.35rem;
            border-bottom: 1.5px solid var(--accent);
            display: inline-block;
        }

        .skills {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
        }

        .skill-badge {
            background: transparent;
            color: var(--text-primary);
            padding: 0.28rem 0.6rem;
            font-weight: 600;
            font-size: 0.77rem;
            border: 1.5px solid rgba(26,26,26,0.28);
            letter-spacing: 0.01em;
            transition: background 0.15s, color 0.15s;
            cursor: default;
        }

        .skill-badge:hover { background: var(--accent); color: var(--bg); }

        /* ===== LOOKING FOR ===== */
        .looking-for-card {
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            padding: 1.4rem 1.75rem;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            font-size: 0.94rem;
            line-height: 1.85;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        /* ===== RESUME ===== */
        .resume-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 2px solid rgba(26,26,26,0.1);
        }

        .resume-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.85rem 2rem;
            background: var(--accent);
            color: var(--bg);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            transition: transform 0.15s, box-shadow 0.15s;
        }

        .resume-button:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0 var(--border);
        }

        .resume-button.secondary {
            background: transparent;
            color: var(--accent);
            border-color: var(--accent);
            box-shadow: 4px 4px 0 var(--accent);
        }

        .resume-button.secondary:hover { box-shadow: 6px 6px 0 var(--accent); }

        /* ===== LEFT RESUME BUTTON ===== */
        .left-resume-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            margin-top: 2.5rem;
            padding: 0.7rem 1.6rem;
            background: rgba(245, 242, 235, 0.12);
            color: var(--bg);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            border: 2px solid rgba(245, 242, 235, 0.55);
            box-shadow: 3px 3px 0 rgba(26, 26, 26, 0.45);
            transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
        }

        .left-resume-btn:hover {
            background: rgba(245, 242, 235, 0.22);
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0 rgba(26, 26, 26, 0.55);
        }

        /* ===== MOBILE ===== */
        @media (max-width: 768px) {
            .about-page { flex-direction: column; }
            .about-left {
                position: relative;
                width: 100%;
                height: auto;
                padding: 3rem 2rem 2.5rem;
            }
            .about-right { padding: 2.5rem 1.5rem 4rem; }
            .skills-grid { grid-template-columns: 1fr; }
            .skills-category.wide { grid-column: span 1; }
        }

        /* ===== EDIT MODE ===== */
        .page-edit-toolbar {
            position: fixed; top: 0; left: 0; right: 0; z-index: 2000;
            background: var(--bg); border-bottom: 2px solid var(--border);
            display: flex; align-items: center; gap: 1rem;
            padding: 0.6rem 1.5rem; font-size: 0.75rem;
        }
        .page-edit-badge { font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); }
        .page-edit-spacer { flex: 1; }
        .page-edit-btn-primary {
            background: var(--accent); color: var(--bg); border: 2px solid var(--border);
            padding: 0.4rem 1.1rem; font-weight: 700; font-size: 0.72rem;
            text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; font-family: inherit;
        }
        .page-edit-btn-secondary {
            background: transparent; color: var(--text-secondary); border: 2px solid var(--border);
            padding: 0.4rem 1.1rem; font-weight: 700; font-size: 0.72rem;
            text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; font-family: inherit;
        }
        body.page-edit-mode [data-editable] {
            outline: 2px dashed var(--accent); outline-offset: 2px; cursor: text;
        }
        body.page-edit-mode { padding-top: 2.5rem; }
        .page-edit-overlay {
            position: fixed; inset: 0; z-index: 2100; background: rgba(0,0,0,0.7);
            display: flex; align-items: center; justify-content: center;
        }
        .page-edit-modal {
            background: var(--bg); border: 2px solid var(--border); box-shadow: 8px 8px 0 var(--border);
            padding: 1.5rem 1.75rem; width: min(90vw, 420px);
            display: flex; flex-direction: column; gap: 0.75rem;
        }
        .page-edit-modal h3 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin: 0; }
        .page-edit-modal label { font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); display: flex; flex-direction: column; gap: 0.3rem; }
        .page-edit-modal input {
            background: var(--card-bg); border: 1.5px solid var(--border); color: var(--text-primary);
            padding: 0.45rem 0.65rem; font-size: 0.85rem; font-family: inherit; width: 100%; box-sizing: border-box;
        }
        .page-pw-overlay {
            position: fixed; inset: 0; z-index: 3000; background: rgba(0,0,0,0.6);
            display: flex; align-items: center; justify-content: center;
        }
        .page-pw-box {
            background: var(--bg); border: 2px solid var(--border); box-shadow: 8px 8px 0 var(--border);
            padding: 1.75rem; width: min(90vw, 340px); display: flex; flex-direction: column; gap: 0.75rem;
        }
        .page-pw-box h3 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin: 0; }
        .page-pw-box input {
            background: var(--card-bg); border: 1.5px solid var(--border); color: var(--text-primary);
            padding: 0.5rem 0.65rem; font-size: 0.9rem; font-family: inherit; width: 100%; box-sizing: border-box;
        }
        .page-pw-error { color: #e55; font-size: 0.75rem; display: none; }
        .page-pw-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
        /* Skill editing */
        .skill-badge-wrap { position: relative; display: inline-flex; align-items: center; }
        body.page-edit-mode .skill-remove-btn { display: inline-flex; }
        .skill-remove-btn {
            display: none; position: absolute; top: -6px; right: -6px;
            background: var(--border); color: var(--bg); border: none;
            border-radius: 50%; width: 14px; height: 14px; font-size: 9px;
            cursor: pointer; align-items: center; justify-content: center; padding: 0; line-height: 1;
        }
        .skill-add-btn {
            display: none; background: transparent; border: 1.5px dashed var(--accent);
            color: var(--accent); padding: 0.25rem 0.55rem; font-size: 0.72rem;
            cursor: pointer; font-family: inherit;
        }
        body.page-edit-mode .skill-add-btn { display: inline-flex; }
        /* Headshot edit affordance */
        body.page-edit-mode .headshot-circle {
            cursor: pointer;
            box-shadow: 10px 10px 0 var(--border), 0 0 0 3px var(--bg), 0 0 0 5px var(--accent);
        }
        body.page-edit-mode .headshot-circle:hover { opacity: 0.85; }
        body.page-edit-mode .headshot-hint { display: block; }
        .headshot-hint {
            display: none;
            font-size: 0.65rem;
            color: rgba(245,242,235,0.6);
            margin-top: -1.25rem;
            margin-bottom: 1.5rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
    </style>

    <!-- Edit toolbar -->
    <div id="pageEditToolbar" class="page-edit-toolbar" style="display:none">
        <span class="page-edit-badge">&#9998; Edit Mode</span>
        <div class="page-edit-spacer"></div>
        <button class="page-edit-btn-secondary" id="pageEditCancel">Cancel</button>
        <button class="page-edit-btn-primary" id="pageEditSave">Save Changes</button>
    </div>

    <!-- Password modal -->
    <div id="aboutPwOverlay" class="page-pw-overlay" style="display:none">
        <div class="page-pw-box">
            <h3>Edit Mode</h3>
            <input type="password" id="aboutPwInput" placeholder="Password" autocomplete="off">
            <span class="page-pw-error" id="aboutPwError">Incorrect password</span>
            <div class="page-pw-actions">
                <button class="page-edit-btn-secondary" id="aboutPwCancel">Cancel</button>
                <button class="page-edit-btn-primary" id="aboutPwSubmit">Unlock</button>
            </div>
        </div>
    </div>

    <!-- Hidden file input for headshot upload -->
    <input type="file" id="headshotFileInput" accept="image/*" style="display:none">

    <div class="about-page">

        <!-- ── LEFT: sticky photo panel ── -->
        <aside class="about-left">
            <img
                id="aboutHeadshot"
                src={about.headshotUrl}
                alt="Rafaela Solis"
                class="headshot-circle"
                onerror="this.style.display='none'"
            >
            <span class="headshot-hint">Click to change photo</span>
            <p class="left-name">Rafaela Solis</p>
            <p class="left-title">Game Developer &amp; Designer</p>
            <div class="left-divider"></div>
            <div class="left-stats">
                {about.stats.map((s: { label: string; value: string }, i: number) => (
                    <div class="stat-item">
                        <span class="stat-label" data-editable={`about.stats.${i}.label`} spellcheck="false">{s.label}</span>
                        <span class="stat-value" data-editable={`about.stats.${i}.value`} spellcheck="false">{s.value}</span>
                    </div>
                ))}
            </div>
            <a href="/resume/" class="left-resume-btn">View Resume &#8599;</a>
        </aside>

        <!-- ── RIGHT: scrollable content ── -->
        <main class="about-right">
            <p class="section-eyebrow">Introduction</p>
            <h1>About Me</h1>
            <div class="accent-rule"></div>

            <div class="bio">
                {about.bio.map((para: string, i: number) => (
                    <p data-editable={`about.bio.${i}`} spellcheck="false">{para}</p>
                ))}
            </div>

            <div class="content-divider"></div>

            <h2>Skills &amp; Expertise</h2>
            <div class="skills-grid">
                {about.skillCategories.map((cat: { name: string; wide: boolean; skills: string[] }, ci: number) => (
                    <div class={`skills-category${cat.wide ? ' wide' : ''}`} data-cat-index={ci}>
                        <h3 data-editable={`about.skillCategories.${ci}.name`} spellcheck="false">{cat.name}</h3>
                        <div class="skills">
                            {cat.skills.map((skill: string, si: number) => (
                                <span class="skill-badge-wrap" data-cat={ci} data-skill={si}>
                                    <span class="skill-badge" spellcheck="false">{skill}</span>
                                    <button class="skill-remove-btn" title="Remove skill">&#10005;</button>
                                </span>
                            ))}
                            <button class="skill-add-btn" data-cat-add={ci} title="Add skill">+ Add</button>
                        </div>
                    </div>
                ))}
            </div>

            <div class="content-divider"></div>

            <h2>What I'm Looking For</h2>
            <div class="looking-for-card" data-editable="about.lookingFor" spellcheck="false">
                {about.lookingFor}
            </div>

            <div class="resume-buttons">
                <a href={about.resumeDownloadUrl} class="resume-button" download="Rafaela_Solis_Resume.pdf" target="_blank">Download Resume</a>
                <a href="/resume/" class="resume-button secondary">View Resume</a>
            </div>
        </main>

    </div>

    <script define:vars={{ about }}>
        const EDIT_PASSWORD = 'studio212';
        let editMode = false;

        function setNestedPath(obj, pathStr, value) {
            const parts = pathStr.split('.');
            let cur = obj;
            for (let i = 0; i < parts.length - 1; i++) {
                const key = isNaN(parts[i]) ? parts[i] : parseInt(parts[i]);
                cur = cur[key];
            }
            const last = parts[parts.length - 1];
            cur[isNaN(last) ? last : parseInt(last)] = value;
        }

        function showPasswordModal() {
            const overlay = document.getElementById('aboutPwOverlay');
            const input   = document.getElementById('aboutPwInput');
            const err     = document.getElementById('aboutPwError');
            if (!overlay || !input) return;
            err.style.display = 'none';
            input.value = '';
            overlay.style.display = 'flex';
            setTimeout(() => input.focus(), 50);
        }

        function hidePasswordModal() {
            const overlay = document.getElementById('aboutPwOverlay');
            if (overlay) overlay.style.display = 'none';
        }

        function enterEditMode() {
            editMode = true;
            document.body.classList.add('page-edit-mode');
            const toolbar = document.getElementById('pageEditToolbar');
            if (toolbar) toolbar.style.display = 'flex';

            // Make simple text fields contenteditable
            document.querySelectorAll('[data-editable]').forEach(el => {
                el.contentEditable = 'true';
            });

            // Wrap skill badges for remove buttons
            document.querySelectorAll('.skill-badge-wrap').forEach(wrap => {
                const badge = wrap.querySelector('.skill-badge');
                if (badge) badge.contentEditable = 'true';
                const btn = wrap.querySelector('.skill-remove-btn');
                if (btn) btn.style.display = 'inline-flex';
            });
        }

        function exitEditMode() {
            editMode = false;
            document.body.classList.remove('page-edit-mode');
            const toolbar = document.getElementById('pageEditToolbar');
            if (toolbar) toolbar.style.display = 'none';

            document.querySelectorAll('[data-editable]').forEach(el => {
                el.contentEditable = 'false';
            });
            document.querySelectorAll('.skill-badge-wrap .skill-badge').forEach(b => {
                b.contentEditable = 'false';
            });
            document.querySelectorAll('.skill-remove-btn').forEach(btn => {
                btn.style.display = 'none';
            });
        }

        async function saveChanges() {
            try {
                const siteResp = await fetch('/api/site');
                const site = await siteResp.json();

                // Read all simple contenteditable fields
                document.querySelectorAll('[data-editable]').forEach(el => {
                    const pathStr = el.dataset.editable;
                    setNestedPath(site, pathStr, el.textContent.trim());
                });

                // Rebuild skill categories from DOM
                site.about.skillCategories = Array.from(document.querySelectorAll('.skills-category')).map(cat => {
                    const nameEl = cat.querySelector('h3');
                    return {
                        name: nameEl ? nameEl.textContent.trim() : '',
                        wide: cat.classList.contains('wide'),
                        skills: Array.from(cat.querySelectorAll('.skill-badge')).map(b => b.textContent.trim())
                    };
                });

                await fetch('/api/site', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(site)
                });
                exitEditMode();
                location.reload();
            } catch (e) {
                alert('Save failed: ' + e);
            }
        }

        function addSkillToCategory(catIndex) {
            const skillName = prompt('Enter new skill name:');
            if (!skillName || !skillName.trim()) return;
            const catEl = document.querySelector(`.skills-category[data-cat-index="${catIndex}"]`);
            if (!catEl) return;
            const skillsEl = catEl.querySelector('.skills');
            if (!skillsEl) return;

            const wrap = document.createElement('span');
            wrap.className = 'skill-badge-wrap';

            const badge = document.createElement('span');
            badge.className = 'skill-badge';
            badge.textContent = skillName.trim();
            badge.spellcheck = false;
            if (editMode) badge.contentEditable = 'true';

            const removeBtn = document.createElement('button');
            removeBtn.className = 'skill-remove-btn';
            removeBtn.title = 'Remove skill';
            removeBtn.innerHTML = '&#10005;';
            removeBtn.style.display = editMode ? 'inline-flex' : 'none';
            removeBtn.addEventListener('click', () => wrap.remove());

            wrap.appendChild(badge);
            wrap.appendChild(removeBtn);

            // Insert before the add button
            const addBtn = skillsEl.querySelector('.skill-add-btn');
            skillsEl.insertBefore(wrap, addBtn);
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Triple-click footer to activate
            let clicks = 0, timer = null;
            document.querySelector('footer')?.addEventListener('click', () => {
                clicks++;
                if (clicks === 1) timer = setTimeout(() => { clicks = 0; }, 700);
                if (clicks >= 3) { clearTimeout(timer); clicks = 0; showPasswordModal(); }
            });

            // Password modal buttons
            document.getElementById('aboutPwCancel')?.addEventListener('click', hidePasswordModal);
            document.getElementById('aboutPwSubmit')?.addEventListener('click', () => {
                const input = document.getElementById('aboutPwInput');
                const err   = document.getElementById('aboutPwError');
                if (input.value === EDIT_PASSWORD) {
                    hidePasswordModal();
                    enterEditMode();
                } else {
                    err.style.display = 'block';
                    input.value = '';
                    input.focus();
                }
            });
            document.getElementById('aboutPwInput')?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') document.getElementById('aboutPwSubmit')?.click();
                if (e.key === 'Escape') hidePasswordModal();
            });

            // Toolbar buttons
            document.getElementById('pageEditCancel')?.addEventListener('click', exitEditMode);
            document.getElementById('pageEditSave')?.addEventListener('click', saveChangesWithHeadshot);

            // Skill remove buttons (existing from SSR)
            document.querySelectorAll('.skill-remove-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    btn.closest('.skill-badge-wrap')?.remove();
                });
            });

            // Skill add buttons
            document.querySelectorAll('.skill-add-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const catIndex = btn.dataset.catAdd;
                    addSkillToCategory(catIndex);
                });
            });

            // Headshot upload
            const headshotImg = document.getElementById('aboutHeadshot');
            const fileInput   = document.getElementById('headshotFileInput');

            headshotImg?.addEventListener('click', () => {
                if (!editMode) return;
                fileInput?.click();
            });

            fileInput?.addEventListener('change', async (e) => {
                const file = e.target.files?.[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = async (ev) => {
                    try {
                        const dataUrl = ev.target.result;
                        const resp = await fetch('/api/upload-headshot', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ filename: file.name, data: dataUrl })
                        });
                        const result = await resp.json();
                        if (result.ok) {
                            headshotImg.src = result.path + '?t=' + Date.now();
                            // Store new path so saveChanges can read it
                            headshotImg.dataset.newPath = result.path;
                        } else {
                            alert('Upload failed: ' + (result.error || 'unknown'));
                        }
                    } catch (err) {
                        alert('Upload error: ' + err);
                    }
                };
                reader.readAsDataURL(file);
                // Reset input so same file can be re-selected
                fileInput.value = '';
            });
        });

        async function saveChangesWithHeadshot() {
            // Patch headshot URL into site before saving
            const newPath = document.getElementById('aboutHeadshot')?.dataset.newPath;
            if (newPath) {
                try {
                    const siteResp = await fetch('/api/site');
                    const site = await siteResp.json();
                    // Read simple fields
                    document.querySelectorAll('[data-editable]').forEach(el => {
                        setNestedPath(site, el.dataset.editable, el.textContent.trim());
                    });
                    site.about.headshotUrl = newPath;
                    // Rebuild skills
                    site.about.skillCategories = Array.from(document.querySelectorAll('.skills-category')).map(cat => ({
                        name: cat.querySelector('h3')?.textContent.trim() || '',
                        wide: cat.classList.contains('wide'),
                        skills: Array.from(cat.querySelectorAll('.skill-badge')).map(b => b.textContent.trim())
                    }));
                    await fetch('/api/site', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(site)
                    });
                    exitEditMode();
                    location.reload();
                } catch (e) {
                    alert('Save failed: ' + e);
                }
            } else {
                await saveChanges();
            }
        }

    </script>
</Layout>
