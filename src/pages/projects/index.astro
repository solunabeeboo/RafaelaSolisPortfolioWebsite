        .media-item-btn:hover { background: var(--border); color: var(--bg); }
        .media-item-btn.del { border-color: #c0392b; color: #c0392b; }
        .media-item-btn.del:hover { background: #c0392b; color: #fff; }
        .media-add-row { display: flex; gap: 0.5rem; margin-top: 0.35rem; flex-wrap: wrap; }

        /* Misc */
        .edit-error { font-size: 0.73rem; color: #c0392b; margin: 0.2rem 0 0; }
        .edit-hint  { font-size: 0.7rem; color: var(--text-muted); margin: 0; }
        .edit-checkbox-label {
            display: flex; align-items: center; gap: 0.5rem;
            font-size: 0.82rem; color: var(--text-secondary); cursor: pointer;
        }
    </style>

    <div id="scrollDriver">
        <div class="sections-stage" id="sectionsStage">
            <div class="loading-state">Loading projects...</div>
