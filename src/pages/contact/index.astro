---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Contact - Rafaela Solis">
    <style>
        section {
            max-width: 1000px;
            margin: 0 auto;
            padding: 10rem var(--section-padding) 6rem;
            min-height: calc(100vh - 100px);
        }

        h1 {
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
            letter-spacing: -0.02em;
            display: inline-block;
            border-bottom: 4px solid var(--accent);
            padding-bottom: 0.25rem;
        }

        .intro-text {
            font-size: 1.05rem;
            color: var(--text-muted);
            margin-top: 1.25rem;
            margin-bottom: 4rem;
            max-width: 600px;
            line-height: 1.7;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
            margin-bottom: 4rem;
        }

        .contact-card {
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 4px 4px 0 var(--border);
            padding: var(--section-padding);
            text-align: center;
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
        }

        .contact-card:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0 var(--accent);
            border-color: var(--accent);
        }

        .contact-icon { font-size: 2.5rem; margin-bottom: 0.75rem; display: block; }

        .contact-card h3 {
            margin-bottom: 0.4rem;
            font-size: 1rem;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .contact-card p { color: var(--text-muted); margin-bottom: 0.75rem; font-size: 0.85rem; }

        .contact-card a {
            color: var(--text-secondary);
            text-decoration: underline;
            text-underline-offset: 3px;
            font-weight: 600;
            font-size: 0.85rem;
            word-break: break-all;
            transition: color 0.2s;
        }

        .contact-card a:hover { color: var(--accent); }

        .social-section { margin-top: 4rem; }

        .social-section h2 {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: var(--section-padding);
            color: var(--text-primary);
            padding-left: 1rem;
            border-left: 4px solid var(--accent);
        }

        .social-links { display: flex; gap: 1rem; flex-wrap: wrap; }

        .social-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: var(--text-primary);
            padding: 0.85rem 1.5rem;
            background: var(--card-bg);
            border: 2px solid var(--border);
            box-shadow: 3px 3px 0 var(--border);
            font-weight: 600;
            font-size: 0.9rem;
            transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s, color 0.15s;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
        }

        .social-link:hover {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0 var(--accent);
            border-color: var(--accent);
            color: var(--accent);
        }

        .social-icon { font-size: 1.4rem; line-height: 1; }

        @media (max-width: 768px) {
            h1 { font-size: 2rem; }
            .contact-grid { grid-template-columns: 1fr; }
            .social-links { flex-direction: column; }
            .social-link, .contact-card { box-shadow: 2px 2px 0 var(--border); }
        }
    </style>

    <section>
        <h1>Get In Touch</h1>
        <p class="intro-text">I'm always interested in hearing about new projects, collaboration opportunities, and connecting with fellow game developers. Feel free to reach out!</p>

        <div class="contact-grid">
            <div class="contact-card">
                <span class="contact-icon">📧</span>
                <h3>Email</h3>
                <p>Best for project inquiries</p>
                <a href="mailto:rafa@miguelsolis.com">rafa@miguelsolis.com</a>
            </div>
            <div class="contact-card">
                <span class="contact-icon">💼</span>
                <h3>LinkedIn</h3>
                <p>Professional networking</p>
                <a href="https://linkedin.com/in/rafaela-solis-3463b2245/" target="_blank">linkedin.com/in/rafaela-solis-3463b2245/</a>
            </div>
            <div class="contact-card">
                <span class="contact-icon">💻</span>
                <h3>GitHub</h3>
                <p>Check out my code</p>
                <a href="https://github.com/solunabeeboo" target="_blank">github.com/solunabeeboo</a>
            </div>
            <div class="contact-card">
                <span class="contact-icon">🎮</span>
                <h3>Itch</h3>
                <p>Play my games</p>
                <a href="https://itch.io/profile/solunabeeboo" target="_blank">itch.io/profile/solunabeeboo</a>
            </div>
        </div>

        <div class="social-section">
            <h2>Connect With Me</h2>
            <div class="social-links">
                <a href="https://www.instagram.com/solunabeeboo/" class="social-link" target="_blank">
                    <span class="social-icon">📷</span><span>Instagram</span>
                </a>
                <a href="https://discord.com/users/633013974279127043" class="social-link" target="_blank">
                    <span class="social-icon">💬</span><span>Discord</span>
                </a>
                <a href="https://bsky.app/profile/solunabeeboo.bsky.social" class="social-link" target="_blank">
                    <span class="social-icon">🕹️</span><span>Bluesky</span>
                </a>
            </div>
        </div>
    </section>
</Layout>
